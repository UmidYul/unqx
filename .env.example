NODE_ENV=production
PORT=3100

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/unqplus"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/unqplus"

APP_URL="https://your-domain.com"
NEXTAUTH_URL="https://your-domain.com"
NEXT_PUBLIC_APP_URL="https://your-domain.com"

SESSION_SECRET="change-me-session-secret"
NEXTAUTH_SECRET="change-me-nextauth-secret"

ADMIN_LOGIN="admin"
ADMIN_PASSWORD_HASH="$2b$10$replace_me_with_real_bcrypt_hash"

# Public order form -> Telegram delivery
TELEGRAM_BOT_TOKEN="123456:replace_me"
TELEGRAM_CHAT_ID="-1001234567890"

TIMEZONE="Asia/Tashkent"

# Reverse-proxy/session tuning for shared hosting:
# TRUST_PROXY accepts: true | false | integer hop count (for example 1)
TRUST_PROXY=1
# SESSION_COOKIE_SECURE accepts: auto | true | false
SESSION_COOKIE_SECURE=auto
# Temporary local-only switch: disables HSTS + CSP upgrade-insecure-requests
DISABLE_HTTPS_ENFORCEMENT=false
