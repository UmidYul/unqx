NODE_ENV=production
PORT=3100

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/unqplus"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/unqplus"

APP_URL="https://your-domain.com"
NEXTAUTH_URL="https://your-domain.com"
NEXT_PUBLIC_APP_URL="https://your-domain.com"

SESSION_SECRET="change-me-session-secret"
NEXTAUTH_SECRET="change-me-nextauth-secret"

ADMIN_LOGIN="admin"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD_HASH="$2b$10$replace_me_with_real_bcrypt_hash"

# Public order form -> Telegram delivery
TELEGRAM_BOT_TOKEN="123456:replace_me"
TELEGRAM_BOT_USERNAME="your_bot_username"
TELEGRAM_CHAT_ID="-1001234567890"
EMAIL_FROM="UNQX <no-reply@unqx.uz>"
SMTP_HOST="smtp.yourmail.com"
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER="no-reply@unqx.uz"
SMTP_PASS="replace_me"
SLUG_TOTAL_LIMIT=17576

TIMEZONE="Asia/Tashkent"

# Reverse-proxy/session tuning for shared hosting:
# TRUST_PROXY accepts: true | false | integer hop count (for example 1)
TRUST_PROXY=1
# SESSION_COOKIE_SECURE accepts: auto | true | false
SESSION_COOKIE_SECURE=auto
# Idle timeout in minutes for site sessions (default: 120)
SESSION_MAX_AGE_MINUTES=120
# Extend session on each request while user is active (default: true)
SESSION_ROLLING=true
# Temporary local-only switch: disables HSTS + CSP upgrade-insecure-requests
DISABLE_HTTPS_ENFORCEMENT=false

# Auto cleanup for unverified accounts
UNVERIFIED_ACCOUNT_CLEANUP_ENABLED=true
# Delete unverified accounts older than N hours (default: 72)
UNVERIFIED_ACCOUNT_TTL_HOURS=72

# Backup to Google Drive (via rclone)
# 1) Install rclone and run: rclone config
# 2) Create remote (example): gdrive
# 3) Set destination path: gdrive:unqx-backups
BACKUP_RCLONE_REMOTE="gdrive:unqx-backups"
BACKUP_KEEP_FILES=14
BACKUP_FILE_PREFIX="unqx-db"
BACKUP_NOTIFY_TELEGRAM=true
# Optional override; defaults to TELEGRAM_CHAT_ID
BACKUP_TELEGRAM_CHAT_ID=""
# Optional button URL in Telegram message (example admin page)
BACKUP_STATUS_URL="https://your-domain.com/admin/dashboard"
