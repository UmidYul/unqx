# Database (Neon/Vercel recommended setup)
# DATABASE_URL: pooled connection (used by the app runtime)
# DIRECT_URL: direct connection (used by Prisma migrations)
# For local Postgres you can point both to the same URL.
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.us-east-1.aws.neon.tech/unqplus?sslmode=require&pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/unqplus?sslmode=require"

# Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-in-production"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Admin credentials
ADMIN_LOGIN="admin"
# bcrypt hash for password 'admin' (change for production)
ADMIN_PASSWORD_HASH=\$2b\$10\$nXEG5Nb9BeOLV1OkQPFqyOXI73zc/JFsd2wXmuU.5wlqjVwrrRPOu
BACKUP_DIR="/backups"
