# Database
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public
# If hosting requires SSL, add: &sslmode=require
DATABASE_URL="postgresql://db_user:db_password@127.0.0.1:5432/unqplus?schema=public"

# Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-in-production"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Admin credentials
ADMIN_LOGIN="admin"
# bcrypt hash for password 'admin' (change for production)
ADMIN_PASSWORD_HASH=\$2b\$10\$nXEG5Nb9BeOLV1OkQPFqyOXI73zc/JFsd2wXmuU.5wlqjVwrrRPOu
BACKUP_DIR="/backups"
