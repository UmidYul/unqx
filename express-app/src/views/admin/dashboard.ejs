<%
  const pageTitle = typeof title !== "undefined" ? title : "Дашборд";
  const pageRows = typeof rows !== "undefined" && Array.isArray(rows) ? rows : [];
  const pageFilters = typeof filters !== "undefined" && filters ? filters : { q: "", status: "all" };
  const pagePagination =
    typeof pagination !== "undefined" && pagination
      ? pagination
      : { page: 1, totalPages: 1, total: 0 };
  const pagePublicBaseUrl =
    typeof publicBaseUrl !== "undefined" && publicBaseUrl ? publicBaseUrl : "";
  const pageBuildDashboardUrl =
    typeof buildDashboardUrl !== "undefined" && typeof buildDashboardUrl === "function"
      ? buildDashboardUrl
      : () => "/admin/dashboard";
%>
<!doctype html>
<html lang="ru">
<head>
  <%- include('../partials/head', { title: pageTitle, styles: ['/css/admin.css'] }) %>
</head>
<body class="admin-body" data-public-base-url="<%= pagePublicBaseUrl %>">
  <%- include('../partials/admin-header') %>

  <main class="container admin-main">
    <section class="admin-heading-row">
      <h1>Визитки</h1>
      <a href="/admin/cards/new" class="btn btn-dark">+ Создать визитку</a>
    </section>

    <form action="/admin/dashboard" method="get" class="filter-grid">
      <input type="text" name="q" value="<%= pageFilters.q %>" placeholder="Поиск по slug или имени" />
      <select name="status">
        <option value="all" <%= pageFilters.status === 'all' ? 'selected' : '' %>>Все</option>
        <option value="active" <%= pageFilters.status === 'active' ? 'selected' : '' %>>Активные</option>
        <option value="inactive" <%= pageFilters.status === 'inactive' ? 'selected' : '' %>>Неактивные</option>
      </select>
      <button type="submit" class="btn btn-outline">Применить</button>
    </form>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Slug</th>
            <th>Имя</th>
            <th>Статус</th>
            <th>Просмотры</th>
            <th>Уникальные</th>
            <th>Создана</th>
            <th>Действия</th>
          </tr>
        </thead>
        <tbody>
          <% if (!pageRows.length) { %>
          <tr>
            <td colspan="7" class="empty-cell">Ничего не найдено</td>
          </tr>
          <% } %>
          <% pageRows.forEach((row) => { %>
          <tr>
            <td><a href="/<%= row.slug %>" target="_blank" rel="noopener noreferrer">#<%= row.slug %></a></td>
            <td><%= row.name %></td>
            <td>
              <button
                class="pill-toggle <%= row.isActive ? 'is-active' : '' %>"
                type="button"
                data-action="toggle"
                data-id="<%= row.id %>"
                data-active="<%= row.isActive ? '1' : '0' %>"
              >
                <%= row.isActive ? 'Активна' : 'Неактивна' %>
              </button>
            </td>
            <td><%= row.viewsCount %></td>
            <td><%= row.uniqueViewsCount %></td>
            <td><%= new Date(row.createdAt).toLocaleDateString('ru-RU') %></td>
            <td>
              <div class="action-row">
                <a href="/admin/cards/<%= row.id %>/edit" class="btn btn-outline btn-sm">Редактировать</a>
                <button type="button" class="btn btn-outline btn-sm" data-action="qr" data-slug="<%= row.slug %>">QR</button>
                <button type="button" class="btn btn-danger btn-sm" data-action="delete" data-id="<%= row.id %>" data-slug="<%= row.slug %>">Удалить</button>
              </div>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

    <footer class="pager-row">
      <span>Страница <%= pagePagination.page %> из <%= pagePagination.totalPages %> (всего <%= pagePagination.total %>)</span>
      <div class="action-row">
        <a href="<%= pageBuildDashboardUrl(Math.max(1, pagePagination.page - 1)) %>" class="btn btn-outline btn-sm">Назад</a>
        <a href="<%= pageBuildDashboardUrl(Math.min(pagePagination.totalPages, pagePagination.page + 1)) %>" class="btn btn-outline btn-sm">Вперёд</a>
      </div>
    </footer>
  </main>

  <div class="modal" id="qr-modal" hidden>
    <div class="modal-backdrop" data-close-modal></div>
    <section class="modal-content">
      <header class="modal-header">
        <h3>QR-код <span id="qr-title-slug"></span></h3>
        <button type="button" class="btn btn-outline btn-sm" data-close-modal>Закрыть</button>
      </header>
      <div class="qr-box">
        <canvas id="qr-canvas" width="256" height="256"></canvas>
      </div>
      <div class="action-row">
        <button type="button" class="btn btn-dark btn-sm" id="download-qr-png">Скачать PNG</button>
        <button type="button" class="btn btn-outline btn-sm" id="download-qr-svg">Скачать SVG</button>
      </div>
    </section>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/qrcode@1.5.4/build/qrcode.min.js"></script>
  <script src="/js/admin-dashboard.js"></script>
</body>
</html>
