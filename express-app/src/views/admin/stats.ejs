<%
  const pageTitle = typeof title !== "undefined" ? title : "Общая статистика";
  const pageStats =
    typeof stats !== "undefined" && stats
      ? stats
      : {
          totalCards: 0,
          activeCards: 0,
          totalViews: 0,
          totalUniqueViews: 0,
          topCards: [],
          dailySeries: [],
        };
%>
<!doctype html>
<html lang="ru">
<head>
  <%- include('../partials/head', { title: pageTitle, styles: ['/css/admin.css'] }) %>
</head>
<body class="admin-body">
  <%- include('../partials/admin-header') %>

  <main class="container admin-main">
    <h1>Общая статистика</h1>

    <section class="stat-grid">
      <article><p>Всего карточек</p><strong><%= pageStats.totalCards %></strong></article>
      <article><p>Активные</p><strong><%= pageStats.activeCards %></strong></article>
      <article><p>Всего просмотров</p><strong><%= pageStats.totalViews %></strong></article>
      <article><p>Уникальные просмотры</p><strong><%= pageStats.totalUniqueViews %></strong></article>
    </section>

    <section class="panel">
      <h2>Просмотры за 30 дней</h2>
      <canvas id="global-stats-chart" height="130"></canvas>
    </section>

    <section class="panel">
      <h2>Топ-10 визиток по просмотрам</h2>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Slug</th>
              <th>Имя</th>
              <th>Просмотры</th>
              <th>Уникальные</th>
            </tr>
          </thead>
          <tbody>
            <% pageStats.topCards.forEach((card) => { %>
            <tr>
              <td><a href="/admin/cards/<%= card.id %>/edit">#<%= card.slug %></a></td>
              <td><%= card.name %></td>
              <td><%= card.viewsCount %></td>
              <td><%= card.uniqueViewsCount %></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </section>
  </main>

  <script id="global-stats-data" type="application/json"><%- JSON.stringify(pageStats.dailySeries) %></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.5.0/dist/chart.umd.min.js"></script>
  <script src="/js/admin-stats.js"></script>
</body>
</html>
