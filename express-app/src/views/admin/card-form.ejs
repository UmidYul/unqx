<!doctype html>
<html lang="ru">
<head>
  <%- include('../partials/head', { title, styles: ['/css/admin.css'] }) %>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/cropperjs@1.6.2/dist/cropper.min.css" />
</head>
<body class="admin-body card-form-body" data-mode="<%= mode %>" data-card-id="<%= cardId || '' %>">
  <%- include('../partials/admin-header') %>

  <main class="container admin-main">
    <h1><%= mode === 'create' ? 'Создать визитку' : `Редактирование #${initialValues.slug}` %></h1>

    <form id="card-editor-form" class="editor-grid" novalidate>
      <section class="panel">
        <div class="panel-head">
          <h2>Основные данные</h2>
        </div>

        <div class="field-grid two-col">
          <label>
            <span>Slug</span>
            <div class="input-row">
              <input id="field-slug" type="text" value="<%= initialValues.slug %>" placeholder="AAA001" maxlength="6" required />
              <button type="button" class="btn btn-outline btn-sm" id="generate-slug-btn">Авто</button>
            </div>
          </label>

          <label class="checkbox-row">
            <input id="field-is-active" type="checkbox" <%= initialValues.isActive ? 'checked' : '' %> />
            <span>Активна</span>
          </label>

          <label>
            <span>Имя клиента</span>
            <input id="field-name" type="text" value="<%= initialValues.name %>" maxlength="100" required />
          </label>

          <label>
            <span>Телефон</span>
            <input id="field-phone" type="text" value="<%= initialValues.phone %>" maxlength="30" required />
          </label>

          <label>
            <span>Нижний хэштег</span>
            <input id="field-hashtag" type="text" value="<%= initialValues.hashtag %>" maxlength="50" />
          </label>

          <label class="checkbox-row">
            <input id="field-verified" type="checkbox" <%= initialValues.verified ? 'checked' : '' %> />
            <span>Верифицирован</span>
          </label>
        </div>
      </section>

      <section class="panel">
        <div class="panel-head">
          <h2>Аватар</h2>
        </div>

        <% if (!cardId) { %>
        <p class="helper-text">Для загрузки аватара сначала сохраните визитку.</p>
        <% } %>

        <div class="field-grid">
          <label>
            <span>Файл (JPG/PNG/WEBP, до 5MB)</span>
            <input id="avatar-file-input" type="file" accept="image/png,image/jpeg,image/webp" <%= !cardId ? 'disabled' : '' %> />
          </label>

          <div id="avatar-crop-wrap" class="crop-wrap" hidden>
            <img id="avatar-crop-image" alt="Crop source" />
          </div>

          <div class="avatar-preview-row">
            <div class="avatar-preview">
              <img id="avatar-current-image" src="<%= initialAvatarUrl || '' %>" alt="Avatar" <%= initialAvatarUrl ? '' : 'hidden' %> />
              <span id="avatar-fallback" <%= initialAvatarUrl ? 'hidden' : '' %>>Нет аватара</span>
            </div>
            <button type="button" class="btn btn-dark btn-sm" id="upload-avatar-btn" <%= !cardId ? 'disabled' : '' %>>Сохранить обрезку</button>
          </div>
        </div>
      </section>

      <section class="panel">
        <div class="panel-head">
          <h2>Теги-ссылки</h2>
          <button type="button" class="btn btn-outline btn-sm" id="add-tag-btn">+ Добавить тег</button>
        </div>

        <div id="tags-list" class="sortable-list">
          <% initialValues.tags.forEach((tag) => { %>
          <div class="editor-row" data-item="tag">
            <button type="button" class="drag-btn" data-drag-handle>≡</button>
            <label>
              <span>Текст тега</span>
              <input type="text" class="tag-label" value="<%= tag.label %>" maxlength="50" />
            </label>
            <label>
              <span>Ссылка</span>
              <input type="text" class="tag-url" value="<%= tag.url || '' %>" placeholder="https://..." />
            </label>
            <button type="button" class="btn btn-danger btn-sm" data-remove-row>Удалить</button>
          </div>
          <% }); %>
        </div>

        <p class="helper-text" id="tags-preview">Предпросмотр: теги появятся после ввода</p>
      </section>

      <section class="panel">
        <div class="panel-head">
          <h2>Кнопки</h2>
          <button type="button" class="btn btn-outline btn-sm" id="add-button-btn">+ Добавить кнопку</button>
        </div>

        <div id="buttons-list" class="sortable-list">
          <% initialValues.buttons.forEach((button) => { %>
          <div class="editor-row" data-item="button">
            <button type="button" class="drag-btn" data-drag-handle>≡</button>
            <label>
              <span>Текст кнопки</span>
              <input type="text" class="button-label" value="<%= button.label %>" maxlength="50" />
            </label>
            <label>
              <span>Ссылка</span>
              <input type="text" class="button-url" value="<%= button.url %>" placeholder="https://..." />
            </label>
            <label class="checkbox-row mini">
              <input type="checkbox" class="button-active" <%= button.isActive ? 'checked' : '' %> />
              <span>Показывать</span>
            </label>
            <button type="button" class="btn btn-danger btn-sm" data-remove-row>Удалить</button>
          </div>
          <% }); %>
        </div>
      </section>

      <section class="panel">
        <div class="panel-head">
          <h2>Контакты</h2>
        </div>

        <div class="field-grid two-col">
          <label>
            <span>Адрес</span>
            <input id="field-address" type="text" value="<%= initialValues.address %>" maxlength="300" />
          </label>
          <label>
            <span>Индекс</span>
            <input id="field-postcode" type="text" value="<%= initialValues.postcode %>" maxlength="20" />
          </label>
          <label>
            <span>Email</span>
            <input id="field-email" type="email" value="<%= initialValues.email %>" maxlength="100" />
          </label>
          <label>
            <span>Дополнительный телефон</span>
            <input id="field-extra-phone" type="text" value="<%= initialValues.extraPhone %>" maxlength="30" />
          </label>
        </div>
      </section>

      <% if (mode === 'edit' && stats) { %>
      <section class="panel">
        <div class="panel-head">
          <h2>Статистика</h2>
        </div>

        <div class="stat-grid compact">
          <article><p>Всего просмотров</p><strong><%= stats.totalViews %></strong></article>
          <article><p>Уникальные</p><strong><%= stats.totalUniqueViews %></strong></article>
          <article><p>Mobile/Desktop</p><strong><%= stats.deviceSplit.mobile %>/<%= stats.deviceSplit.desktop %></strong></article>
          <article><p>Последний просмотр</p><strong><%= stats.lastViewAt ? new Date(stats.lastViewAt).toLocaleString('ru-RU') : 'Нет данных' %></strong></article>
        </div>

        <canvas id="card-stats-chart" height="130"></canvas>
      </section>
      <% } %>

      <p id="card-form-error" class="error-text" hidden></p>

      <section class="panel actions-panel">
        <div class="action-row">
          <button type="submit" class="btn btn-dark" id="save-card-btn">Сохранить</button>
          <button type="button" class="btn btn-outline" id="preview-card-btn">Предпросмотр</button>
          <a href="/admin/dashboard" class="btn btn-outline">Отмена</a>
        </div>
      </section>
    </form>
  </main>

  <script id="card-editor-initial" type="application/json"><%- JSON.stringify(initialValues) %></script>
  <script id="card-editor-stats" type="application/json"><%- JSON.stringify(stats) %></script>
  <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.6/Sortable.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/cropperjs@1.6.2/dist/cropper.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.5.0/dist/chart.umd.min.js"></script>
  <script src="/js/admin-card-editor.js"></script>
</body>
</html>