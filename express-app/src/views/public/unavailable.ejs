<%
  const pageTitle = typeof title !== "undefined" ? title : "Визитка недоступна";
  const pageSlug = typeof slug !== "undefined" && slug ? slug : "unknown";
%>
<!doctype html>
<html lang="ru">
<head>
  <%- include('../partials/head', { title: pageTitle, styles: ['/css/public-card.css'] }) %>
</head>
<body>
  <main class="center-page">
    <section class="center-card">
      <p class="muted-code">#<%= pageSlug %></p>
      <h1>Визитка недоступна</h1>
      <p>Эта визитка временно отключена администратором.</p>
      <a href="/" class="btn btn-outline">На главную</a>
    </section>
  </main>
</body>
</html>
