<%
  const pageTitle = typeof title !== "undefined" ? title : "UNQ+";
  const pageDescription =
    typeof description !== "undefined" && description ? description : "UNQ+ platform for digital business cards";
  const pageImage = typeof image !== "undefined" ? image : null;
  const pageCardRaw = typeof card !== "undefined" && card ? card : {};
  const pageCard = {
    slug: pageCardRaw.slug || "UNKNOWN",
    avatarUrl: pageCardRaw.avatarUrl || null,
    name: pageCardRaw.name || "Unknown",
    verified: Boolean(pageCardRaw.verified),
    phone: pageCardRaw.phone || "",
    tags: Array.isArray(pageCardRaw.tags) ? pageCardRaw.tags : [],
    buttons: Array.isArray(pageCardRaw.buttons) ? pageCardRaw.buttons : [],
    hashtag: pageCardRaw.hashtag || "",
    address: pageCardRaw.address || "",
    postcode: pageCardRaw.postcode || "",
    email: pageCardRaw.email || "",
    extraPhone: pageCardRaw.extraPhone || "",
  };
  const initials = (pageCard.name || "")
    .split(" ")
    .filter(Boolean)
    .slice(0, 2)
    .map((part) => (part[0] ? part[0].toUpperCase() : ""))
    .join("");
%>
<!doctype html>
<html lang="ru">
<head>
  <%- include('../partials/head', { title: pageTitle, description: pageDescription, image: pageImage, styles: ['/css/public-card.css'] }) %>
</head>
<body>
  <div class="public-bg-decor" aria-hidden="true">
    <span class="bolt bolt-a"></span>
    <span class="bolt bolt-b"></span>
    <span class="bolt bolt-c"></span>
    <span class="bolt bolt-d"></span>
  </div>

  <main class="card-page" data-slug="<%= pageCard.slug %>">
    <article class="card-root">
      <p class="card-slug">#<%= pageCard.slug %></p>

      <div class="card-brand">
        <div class="brand-title">UNQ+</div>
        <div class="brand-subtitle">powered by scxr</div>
      </div>

      <div class="avatar-wrap">
        <% if (pageCard.avatarUrl) { %>
        <img src="<%= pageCard.avatarUrl %>" alt="<%= pageCard.name %>" class="avatar-img" />
        <% } else { %>
        <span class="avatar-fallback"><%= initials %></span>
        <% } %>
      </div>

      <div class="identity-row">
        <h1><%= pageCard.name %></h1>
        <% if (pageCard.verified) { %>
        <span class="verified-mark" aria-label="verified">✓</span>
        <% } %>
      </div>

      <p class="phone-row">
        <span><%= pageCard.phone %></span>
        <button type="button" class="icon-btn" data-copy-phone="<%= pageCard.phone %>" title="Скопировать телефон">⧉</button>
      </p>

      <% if (pageCard.tags.length > 0) { %>
      <div class="tag-row">
        <% pageCard.tags.forEach((tag, index) => { %>
          <% if (index > 0) { %><span class="tag-sep">·</span><% } %>
          <% if (tag.url) { %>
          <a href="<%= tag.url %>" target="_blank" rel="noopener noreferrer"><%= tag.label %></a>
          <% } else { %>
          <span><%= tag.label %></span>
          <% } %>
        <% }); %>
      </div>
      <% } %>

      <div class="button-col">
        <% pageCard.buttons.forEach((button) => { %>
        <a href="<%= button.url %>" target="_blank" rel="noopener noreferrer" class="btn-shimmer card-cta"><%= button.label %></a>
        <% }); %>
      </div>

      <div class="public-actions" data-share-url="<%= pageCard.slug %>">
        <a href="/api/cards/<%= pageCard.slug %>/vcf" class="btn btn-light">Сохранить контакт</a>
        <button type="button" class="btn btn-outline" data-share-button>Поделиться</button>
        <span class="hint" data-share-hint></span>
      </div>

      <div class="card-footer">
        <% if (pageCard.hashtag) { %>
        <p class="hashtag"><%= pageCard.hashtag %></p>
        <% } %>

        <% if (pageCard.address || pageCard.postcode || pageCard.email || pageCard.extraPhone) { %>
        <section class="about-info">
          <h2>About info</h2>
          <div>
            <% if (pageCard.address) { %><p>Address: <%= pageCard.address %></p><% } %>
            <% if (pageCard.postcode) { %><p>Postcode: <%= pageCard.postcode %></p><% } %>
            <% if (pageCard.email) { %><p>Email: <%= pageCard.email %></p><% } %>
            <% if (pageCard.extraPhone) { %><p>Phone: <%= pageCard.extraPhone %></p><% } %>
          </div>
        </section>
        <% } %>
      </div>
    </article>
  </main>

  <script src="/js/public-card.js"></script>
</body>
</html>