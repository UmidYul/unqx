generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Tariff {
  basic
  premium
}

enum CardTheme {
  default_dark
  light_minimal
  gradient
  neon
  corporate
}

enum OrderStatus {
  NEW
  CONTACTED
  PAID
  ACTIVATED
  REJECTED
}

enum SlugState {
  TAKEN
  BLOCKED
}

enum CheckerResult {
  AVAILABLE
  TAKEN
  BLOCKED
  INVALID
}

enum BraceletDeliveryStatus {
  ORDERED
  SHIPPED
  DELIVERED
}

enum UserPlan {
  none
  basic
  premium
}

enum UserStatus {
  active
  blocked
  deactivated
}

enum SlugStatus {
  free
  pending
  approved
  active
  paused
  private
  blocked
  reserved_drop
}

enum ReferralStatus {
  registered
  paid
  rewarded
}

enum ReferralRewardType {
  discount
  free_month
  bonus_slug
}

enum FlashSaleConditionType {
  all
  pattern_000
  pattern_aaa
  sequential_digits
  custom
}

enum DropSlugPatternType {
  random
  sequential
  themed
  manual
}

enum SlugRequestStatus {
  new
  contacted
  paid
  approved
  rejected
  expired
}

model Card {
  id         String    @id @default(uuid())
  slug       String    @unique @db.VarChar(20)
  isActive   Boolean   @default(true) @map("is_active")
  tariff     Tariff    @default(basic)
  theme      CardTheme @default(default_dark)
  avatarUrl  String?   @map("avatar_url")
  name       String    @db.VarChar(100)
  phone      String    @db.VarChar(30)
  verified   Boolean   @default(false)
  hashtag    String?   @db.VarChar(50)
  address    String?
  postcode   String?   @db.VarChar(20)
  email      String?   @db.VarChar(100)
  extraPhone String?   @map("extra_phone") @db.VarChar(30)
  viewsCount Int       @default(0) @map("views_count")
  uniqueViewsCount Int @default(0) @map("unique_views_count")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  buttons    Button[]
  tags       Tag[]
  viewsLog   ViewLog[]
  orderRequests OrderRequest[]
  slugRecord SlugRecord?

  @@index([isActive])
  @@index([createdAt])
  @@map("cards")
}

model Tag {
  id        String @id @default(uuid())
  cardId    String @map("card_id")
  card      Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label     String @db.VarChar(50)
  url       String?
  sortOrder Int    @map("sort_order")

  @@index([cardId, sortOrder])
  @@map("tags")
}

model Button {
  id        String  @id @default(uuid())
  cardId    String  @map("card_id")
  card      Card    @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label     String  @db.VarChar(50)
  url       String
  sortOrder Int     @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  @@index([cardId, sortOrder])
  @@map("buttons")
}

model ViewLog {
  id       String   @id @default(uuid())
  cardId   String   @map("card_id")
  card     Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  viewedAt DateTime @default(now()) @map("viewed_at")
  device   String?  @db.VarChar(20)
  ipHash   String?  @map("ip_hash") @db.VarChar(64)
  isUnique Boolean  @default(false) @map("is_unique")

  @@index([cardId, viewedAt])
  @@index([cardId, ipHash, viewedAt])
  @@index([viewedAt])
  @@map("views_log")
}

model ErrorLog {
  id         String   @id @default(uuid())
  type       String   @db.VarChar(30)
  path       String
  message    String?
  userAgent  String?  @map("user_agent")
  occurredAt DateTime @default(now()) @map("occurred_at")

  @@index([type, occurredAt])
  @@index([occurredAt])
  @@map("error_logs")
}

model OrderRequest {
  id        String      @id @default(uuid())
  name      String      @db.VarChar(100)
  slug      String      @db.VarChar(20)
  slugPrice Int         @map("slug_price")
  tariff    Tariff
  theme     CardTheme?
  bracelet  Boolean     @default(false)
  contact   String      @db.VarChar(120)
  status    OrderStatus @default(NEW)
  cardId    String?     @map("card_id")
  card      Card?       @relation(fields: [cardId], references: [id], onDelete: SetNull)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  braceletOrder BraceletOrder?

  @@index([slug, createdAt])
  @@index([status, createdAt])
  @@index([cardId])
  @@map("order_requests")
}

model BraceletOrder {
  id            String                 @id @default(uuid())
  orderId       String                 @unique @map("order_id")
  order         OrderRequest           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  name          String                 @db.VarChar(100)
  slug          String                 @db.VarChar(20)
  contact       String                 @db.VarChar(120)
  deliveryStatus BraceletDeliveryStatus @default(ORDERED) @map("delivery_status")
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")

  @@index([deliveryStatus, createdAt])
  @@map("bracelet_orders")
}

model SlugRecord {
  id             String    @id @default(uuid())
  slug           String    @unique @db.VarChar(20)
  state          SlugState @default(TAKEN)
  ownerName      String?   @map("owner_name") @db.VarChar(100)
  priceOverride  Int?      @map("price_override")
  activationDate DateTime? @map("activation_date")
  cardId         String?   @unique @map("card_id")
  card           Card?     @relation(fields: [cardId], references: [id], onDelete: SetNull)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([state])
  @@index([activationDate])
  @@map("slug_records")
}

model SlugCheckerLog {
  id       String        @id @default(uuid())
  slug     String?       @db.VarChar(20)
  pattern  String        @db.VarChar(20)
  source   String        @db.VarChar(20)
  result   CheckerResult
  checkedAt DateTime     @default(now()) @map("checked_at")

  @@index([checkedAt])
  @@index([pattern, checkedAt])
  @@index([source, checkedAt])
  @@map("slug_checker_logs")
}

model Testimonial {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  slug      String   @db.VarChar(20)
  tariff    Tariff
  text      String
  isVisible Boolean  @default(true) @map("is_visible")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isVisible, sortOrder])
  @@map("testimonials")
}

model User {
  id                   String        @id @default(uuid())
  telegramId           String        @unique @map("telegram_id") @db.VarChar(40)
  firstName            String        @map("first_name") @db.VarChar(120)
  lastName             String?       @map("last_name") @db.VarChar(120)
  username             String?       @db.VarChar(120)
  photoUrl             String?       @map("photo_url")
  displayName          String?       @map("display_name") @db.VarChar(120)
  plan                 UserPlan      @default(none)
  planPurchasedAt      DateTime?     @map("plan_purchased_at")
  planUpgradedAt       DateTime?     @map("plan_upgraded_at")
  notificationsEnabled Boolean       @default(true) @map("notifications_enabled")
  status               UserStatus    @default(active)
  refCode              String?       @unique @map("ref_code") @db.VarChar(40)
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")
  slugs                Slug[]
  profileCard          ProfileCard?
  slugRequests         SlugRequest[]
  referralsMade        Referral[]    @relation("ReferrerReferrals")
  referralsReceived    Referral[]    @relation("ReferredReferrals")
  dropWaitlistEntries  DropWaitlist[]
  unqScore             UnqScore?
  scoreHistory         ScoreHistory[]
  purchases            Purchase[]

  @@index([plan, planPurchasedAt])
  @@index([status])
  @@map("users")
}

model Slug {
  id              String      @id @default(uuid())
  letters         String      @db.VarChar(3)
  digits          String      @db.VarChar(3)
  fullSlug        String      @unique @map("full_slug") @db.VarChar(20)
  ownerTelegramId String?     @map("owner_telegram_id") @db.VarChar(40)
  owner           User?       @relation(fields: [ownerTelegramId], references: [telegramId], onDelete: SetNull)
  status          SlugStatus  @default(free)
  isPrimary       Boolean     @default(false) @map("is_primary")
  price           Int?
  pauseMessage    String?     @map("pause_message") @db.VarChar(220)
  requestedAt     DateTime?   @map("requested_at")
  pendingExpiresAt DateTime?  @map("pending_expires_at")
  approvedAt      DateTime?   @map("approved_at")
  activatedAt     DateTime?   @map("activated_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  @@index([ownerTelegramId, status])
  @@index([status, updatedAt])
  @@map("slugs")
}

model SlugWaitlist {
  id         String   @id @default(uuid())
  fullSlug   String   @map("full_slug") @db.VarChar(20)
  telegramId String?  @map("telegram_id") @db.VarChar(40)
  ipHash     String?  @map("ip_hash") @db.VarChar(64)
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([fullSlug, createdAt])
  @@index([telegramId, createdAt])
  @@map("slug_waitlist")
}

model ProfileCard {
  id              String    @id @default(uuid())
  ownerTelegramId String    @unique @map("owner_telegram_id") @db.VarChar(40)
  owner           User      @relation(fields: [ownerTelegramId], references: [telegramId], onDelete: Cascade)
  name            String    @db.VarChar(120)
  role            String?   @db.VarChar(120)
  bio             String?   @db.VarChar(120)
  hashtag         String?   @db.VarChar(50)
  address         String?
  postcode        String?   @db.VarChar(20)
  email           String?   @db.VarChar(100)
  extraPhone      String?   @map("extra_phone") @db.VarChar(30)
  avatarUrl       String?   @map("avatar_url")
  tags            Json      @default("[]")
  buttons         Json      @default("[]")
  theme           CardTheme @default(default_dark)
  customColor     String?   @map("custom_color") @db.VarChar(20)
  showBranding    Boolean   @default(true) @map("show_branding")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("profile_cards")
}

model SlugRequest {
  id            String            @id @default(uuid())
  telegramId    String            @map("telegram_id") @db.VarChar(40)
  user          User              @relation(fields: [telegramId], references: [telegramId], onDelete: Cascade)
  slug          String            @db.VarChar(20)
  slugPrice     Int               @map("slug_price")
  requestedPlan UserPlan          @map("requested_plan")
  planPrice     Int               @default(0) @map("plan_price")
  bracelet      Boolean           @default(false)
  contact       String            @db.VarChar(140)
  status        SlugRequestStatus @default(new)
  adminNote     String?           @map("admin_note")
  dropId        String?           @map("drop_id")
  drop          Drop?             @relation(fields: [dropId], references: [id], onDelete: SetNull)
  flashSaleId   String?           @map("flash_sale_id")
  flashSale     FlashSale?        @relation(fields: [flashSaleId], references: [id], onDelete: SetNull)
  flashDiscountAmount Int         @default(0) @map("flash_discount_amount")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  @@index([telegramId, createdAt])
  @@index([status, createdAt])
  @@index([slug])
  @@map("slug_requests")
}

enum PurchaseType {
  slug
  basic_plan
  premium_plan
  upgrade_to_premium
  bracelet
}

model Purchase {
  id              String       @id @default(uuid())
  telegramId      String       @map("telegram_id") @db.VarChar(40)
  user            User         @relation(fields: [telegramId], references: [telegramId], onDelete: Cascade)
  type            PurchaseType
  amount          Int
  slug            String?      @db.VarChar(20)
  purchasedAt     DateTime     @default(now()) @map("purchased_at")
  approvedByAdmin String?      @map("approved_by_admin") @db.VarChar(40)
  approvedAt      DateTime?    @map("approved_at")
  note            String?

  @@index([telegramId, purchasedAt(sort: Desc)])
  @@index([type, purchasedAt(sort: Desc)])
  @@index([slug])
  @@map("purchases")
}

model SlugView {
  id       String   @id @default(uuid())
  fullSlug String   @map("full_slug") @db.VarChar(20)
  viewedAt DateTime @default(now()) @map("viewed_at")
  device   String?  @db.VarChar(20)
  ipHash   String?  @map("ip_hash") @db.VarChar(64)
  isUnique Boolean  @default(false) @map("is_unique")

  @@index([fullSlug, viewedAt])
  @@index([fullSlug, ipHash, viewedAt])
  @@index([viewedAt])
  @@index([isUnique, viewedAt])
  @@map("slug_views")
}

model SlugClick {
  id       String   @id @default(uuid())
  fullSlug String   @map("full_slug") @db.VarChar(20)
  clickedAt DateTime @default(now()) @map("clicked_at")
  device   String?  @db.VarChar(20)
  ipHash   String?  @map("ip_hash") @db.VarChar(64)
  isUnique Boolean  @default(false) @map("is_unique")

  @@index([fullSlug, clickedAt])
  @@index([fullSlug, ipHash, clickedAt])
  @@index([clickedAt])
  @@map("slug_clicks")
}

model UnqScore {
  telegramId      String   @id @map("telegram_id") @db.VarChar(40)
  user            User     @relation(fields: [telegramId], references: [telegramId], onDelete: Cascade)
  score           Int      @default(0)
  scoreViews      Int      @default(0) @map("score_views")
  scoreSlugRarity Int      @default(0) @map("score_slug_rarity")
  scoreTenure     Int      @default(0) @map("score_tenure")
  scoreCtr        Int      @default(0) @map("score_ctr")
  scoreBracelet   Int      @default(0) @map("score_bracelet")
  scorePlan       Int      @default(0) @map("score_plan")
  percentile      Float    @default(0)
  calculatedAt    DateTime @default(now()) @map("calculated_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([score(sort: Desc)])
  @@index([percentile(sort: Desc)])
  @@map("unq_scores")
}

model ScoreHistory {
  id         String   @id @default(uuid())
  telegramId String   @map("telegram_id") @db.VarChar(40)
  user       User     @relation(fields: [telegramId], references: [telegramId], onDelete: Cascade)
  score      Int
  recordedAt DateTime @map("recorded_at")

  @@unique([telegramId, recordedAt])
  @@index([recordedAt])
  @@index([telegramId, recordedAt])
  @@map("score_history")
}

model ScoreRecalculationRun {
  id              String   @id @default(uuid())
  processedUsers  Int      @default(0) @map("processed_users")
  averageMsPerUser Float   @default(0) @map("average_ms_per_user")
  startedAt       DateTime @default(now()) @map("started_at")
  finishedAt      DateTime @default(now()) @map("finished_at")

  @@index([startedAt(sort: Desc)])
  @@map("score_recalculation_runs")
}

model ReferralRewardRule {
  id                 String             @id @default(uuid())
  requiredPaidFriends Int               @unique @map("required_paid_friends")
  rewardType         ReferralRewardType @map("reward_type")
  rewardValue        Int?               @map("reward_value")
  isActive           Boolean            @default(true) @map("is_active")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  referrals          Referral[]

  @@map("referral_reward_rules")
}

model Referral {
  id                 String             @id @default(uuid())
  referrerTelegramId String             @map("referrer_telegram_id") @db.VarChar(40)
  referrer           User               @relation("ReferrerReferrals", fields: [referrerTelegramId], references: [telegramId], onDelete: Cascade)
  referredTelegramId String             @unique @map("referred_telegram_id") @db.VarChar(40)
  referred           User               @relation("ReferredReferrals", fields: [referredTelegramId], references: [telegramId], onDelete: Cascade)
  refCode            String             @map("ref_code") @db.VarChar(40)
  status             ReferralStatus     @default(registered)
  rewardType         ReferralRewardType? @map("reward_type")
  rewardedRuleId     String?            @map("rewarded_rule_id")
  rewardedRule       ReferralRewardRule? @relation(fields: [rewardedRuleId], references: [id], onDelete: SetNull)
  createdAt          DateTime           @default(now()) @map("created_at")
  rewardedAt         DateTime?          @map("rewarded_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  @@index([referrerTelegramId, status])
  @@index([createdAt])
  @@map("referrals")
}

model FeatureSetting {
  key       String   @id @db.VarChar(80)
  value     Json     @default("{}")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("feature_settings")
}

model FlashSale {
  id                        String                 @id @default(uuid())
  title                     String                 @db.VarChar(180)
  description               String?
  discountPercent           Int                    @map("discount_percent")
  conditionType             FlashSaleConditionType @map("condition_type")
  conditionValue            Json?                  @map("condition_value")
  startsAt                  DateTime               @map("starts_at")
  endsAt                    DateTime               @map("ends_at")
  isActive                  Boolean                @default(true) @map("is_active")
  notifyTelegram            Boolean                @default(false) @map("notify_telegram")
  telegramTarget            String?                @map("telegram_target") @db.VarChar(120)
  createdByAdmin            String?                @map("created_by_admin") @db.VarChar(80)
  startedNotificationSentAt DateTime?              @map("started_notification_sent_at")
  createdAt                 DateTime               @default(now()) @map("created_at")
  updatedAt                 DateTime               @updatedAt @map("updated_at")
  slugRequests              SlugRequest[]

  @@index([isActive, startsAt, endsAt])
  @@map("flash_sales")
}

model Drop {
  id              String              @id @default(uuid())
  title           String              @db.VarChar(180)
  description     String?
  dropAt          DateTime            @map("drop_at")
  slugCount       Int                 @map("slug_count")
  slugPatternType DropSlugPatternType @map("slug_pattern_type")
  slugsPool       Json                @default("[]") @map("slugs_pool")
  soldSlugs       Json                @default("[]") @map("sold_slugs")
  isAnnounced     Boolean             @default(false) @map("is_announced")
  isLive          Boolean             @default(false) @map("is_live")
  isSoldOut       Boolean             @default(false) @map("is_sold_out")
  isFinished      Boolean             @default(false) @map("is_finished")
  notifyTelegram  Boolean             @default(false) @map("notify_telegram")
  telegramTarget  String?             @map("telegram_target") @db.VarChar(120)
  notified15mAt   DateTime?           @map("notified_15m_at")
  notifiedStartAt DateTime?           @map("notified_start_at")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  waitlist        DropWaitlist[]
  slugRequests    SlugRequest[]

  @@index([dropAt])
  @@index([isLive, isFinished, isSoldOut])
  @@map("drops")
}

model DropWaitlist {
  id              String   @id @default(uuid())
  dropId          String   @map("drop_id")
  drop            Drop     @relation(fields: [dropId], references: [id], onDelete: Cascade)
  telegramId      String   @map("telegram_id") @db.VarChar(40)
  user            User     @relation(fields: [telegramId], references: [telegramId], onDelete: Cascade)
  joinedAt        DateTime @default(now()) @map("joined_at")
  notifiedAt      DateTime? @map("notified_at")
  notified15mAt   DateTime? @map("notified_15m_at")
  notifiedStartAt DateTime? @map("notified_start_at")

  @@unique([dropId, telegramId])
  @@index([dropId, joinedAt])
  @@map("drop_waitlist")
}

model LeaderboardExclusion {
  fullSlug   String   @id @map("full_slug") @db.VarChar(20)
  reason     String?
  excludedBy String?  @map("excluded_by") @db.VarChar(80)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("leaderboard_exclusions")
}

model LeaderboardSuspiciousLog {
  id            String   @id @default(uuid())
  fullSlug      String   @map("full_slug") @db.VarChar(20)
  viewsCount    Int      @map("views_count")
  windowMinutes Int      @map("window_minutes")
  threshold     Int
  occurredAt    DateTime @default(now()) @map("occurred_at")

  @@index([fullSlug, occurredAt])
  @@map("leaderboard_suspicious_log")
}
