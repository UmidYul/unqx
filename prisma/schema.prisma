generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Tariff {
  basic
  premium
}

enum CardTheme {
  default_dark
  light_minimal
  gradient
  neon
  corporate
}

enum OrderStatus {
  NEW
  CONTACTED
  PAID
  ACTIVATED
  REJECTED
}

enum SlugState {
  TAKEN
  BLOCKED
}

enum CheckerResult {
  AVAILABLE
  TAKEN
  BLOCKED
  INVALID
}

enum BraceletDeliveryStatus {
  ORDERED
  SHIPPED
  DELIVERED
}

enum UserPlan {
  basic
  premium
}

enum UserStatus {
  active
  blocked
  deactivated
}

enum SlugStatus {
  free
  pending
  approved
  active
  paused
  private
  blocked
}

enum SlugRequestStatus {
  new
  contacted
  paid
  approved
  rejected
}

model Card {
  id         String    @id @default(uuid())
  slug       String    @unique @db.VarChar(20)
  isActive   Boolean   @default(true) @map("is_active")
  tariff     Tariff    @default(basic)
  theme      CardTheme @default(default_dark)
  avatarUrl  String?   @map("avatar_url")
  name       String    @db.VarChar(100)
  phone      String    @db.VarChar(30)
  verified   Boolean   @default(false)
  hashtag    String?   @db.VarChar(50)
  address    String?
  postcode   String?   @db.VarChar(20)
  email      String?   @db.VarChar(100)
  extraPhone String?   @map("extra_phone") @db.VarChar(30)
  viewsCount Int       @default(0) @map("views_count")
  uniqueViewsCount Int @default(0) @map("unique_views_count")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  buttons    Button[]
  tags       Tag[]
  viewsLog   ViewLog[]
  orderRequests OrderRequest[]
  slugRecord SlugRecord?

  @@index([isActive])
  @@index([createdAt])
  @@map("cards")
}

model Tag {
  id        String @id @default(uuid())
  cardId    String @map("card_id")
  card      Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label     String @db.VarChar(50)
  url       String?
  sortOrder Int    @map("sort_order")

  @@index([cardId, sortOrder])
  @@map("tags")
}

model Button {
  id        String  @id @default(uuid())
  cardId    String  @map("card_id")
  card      Card    @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label     String  @db.VarChar(50)
  url       String
  sortOrder Int     @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  @@index([cardId, sortOrder])
  @@map("buttons")
}

model ViewLog {
  id       String   @id @default(uuid())
  cardId   String   @map("card_id")
  card     Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  viewedAt DateTime @default(now()) @map("viewed_at")
  device   String?  @db.VarChar(20)
  ipHash   String?  @map("ip_hash") @db.VarChar(64)
  isUnique Boolean  @default(false) @map("is_unique")

  @@index([cardId, viewedAt])
  @@index([cardId, ipHash, viewedAt])
  @@index([viewedAt])
  @@map("views_log")
}

model ErrorLog {
  id         String   @id @default(uuid())
  type       String   @db.VarChar(30)
  path       String
  message    String?
  userAgent  String?  @map("user_agent")
  occurredAt DateTime @default(now()) @map("occurred_at")

  @@index([type, occurredAt])
  @@index([occurredAt])
  @@map("error_logs")
}

model OrderRequest {
  id        String      @id @default(uuid())
  name      String      @db.VarChar(100)
  slug      String      @db.VarChar(20)
  slugPrice Int         @map("slug_price")
  tariff    Tariff
  theme     CardTheme?
  bracelet  Boolean     @default(false)
  contact   String      @db.VarChar(120)
  status    OrderStatus @default(NEW)
  cardId    String?     @map("card_id")
  card      Card?       @relation(fields: [cardId], references: [id], onDelete: SetNull)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  braceletOrder BraceletOrder?

  @@index([slug, createdAt])
  @@index([status, createdAt])
  @@index([cardId])
  @@map("order_requests")
}

model BraceletOrder {
  id            String                 @id @default(uuid())
  orderId       String                 @unique @map("order_id")
  order         OrderRequest           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  name          String                 @db.VarChar(100)
  slug          String                 @db.VarChar(20)
  contact       String                 @db.VarChar(120)
  deliveryStatus BraceletDeliveryStatus @default(ORDERED) @map("delivery_status")
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")

  @@index([deliveryStatus, createdAt])
  @@map("bracelet_orders")
}

model SlugRecord {
  id             String    @id @default(uuid())
  slug           String    @unique @db.VarChar(20)
  state          SlugState @default(TAKEN)
  ownerName      String?   @map("owner_name") @db.VarChar(100)
  priceOverride  Int?      @map("price_override")
  activationDate DateTime? @map("activation_date")
  cardId         String?   @unique @map("card_id")
  card           Card?     @relation(fields: [cardId], references: [id], onDelete: SetNull)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([state])
  @@index([activationDate])
  @@map("slug_records")
}

model SlugCheckerLog {
  id       String        @id @default(uuid())
  slug     String?       @db.VarChar(20)
  pattern  String        @db.VarChar(20)
  source   String        @db.VarChar(20)
  result   CheckerResult
  checkedAt DateTime     @default(now()) @map("checked_at")

  @@index([checkedAt])
  @@index([pattern, checkedAt])
  @@index([source, checkedAt])
  @@map("slug_checker_logs")
}

model Testimonial {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  slug      String   @db.VarChar(20)
  tariff    Tariff
  text      String
  isVisible Boolean  @default(true) @map("is_visible")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isVisible, sortOrder])
  @@map("testimonials")
}

model User {
  id                   String        @id @default(uuid())
  telegramId           String        @unique @map("telegram_id") @db.VarChar(40)
  firstName            String        @map("first_name") @db.VarChar(120)
  lastName             String?       @map("last_name") @db.VarChar(120)
  username             String?       @db.VarChar(120)
  photoUrl             String?       @map("photo_url")
  displayName          String?       @map("display_name") @db.VarChar(120)
  plan                 UserPlan      @default(basic)
  planExpiresAt        DateTime?     @map("plan_expires_at")
  notificationsEnabled Boolean       @default(true) @map("notifications_enabled")
  status               UserStatus    @default(active)
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")
  slugs                Slug[]
  profileCard          ProfileCard?
  slugRequests         SlugRequest[]

  @@index([plan, planExpiresAt])
  @@index([status])
  @@map("users")
}

model Slug {
  id              String      @id @default(uuid())
  letters         String      @db.VarChar(3)
  digits          String      @db.VarChar(3)
  fullSlug        String      @unique @map("full_slug") @db.VarChar(20)
  ownerTelegramId String?     @map("owner_telegram_id") @db.VarChar(40)
  owner           User?       @relation(fields: [ownerTelegramId], references: [telegramId], onDelete: SetNull)
  status          SlugStatus  @default(free)
  isPrimary       Boolean     @default(false) @map("is_primary")
  price           Int?
  pauseMessage    String?     @map("pause_message") @db.VarChar(220)
  requestedAt     DateTime?   @map("requested_at")
  approvedAt      DateTime?   @map("approved_at")
  activatedAt     DateTime?   @map("activated_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  @@index([ownerTelegramId, status])
  @@index([status, updatedAt])
  @@map("slugs")
}

model ProfileCard {
  id              String    @id @default(uuid())
  ownerTelegramId String    @unique @map("owner_telegram_id") @db.VarChar(40)
  owner           User      @relation(fields: [ownerTelegramId], references: [telegramId], onDelete: Cascade)
  name            String    @db.VarChar(120)
  role            String?   @db.VarChar(120)
  bio             String?   @db.VarChar(120)
  avatarUrl       String?   @map("avatar_url")
  tags            Json      @default("[]")
  buttons         Json      @default("[]")
  theme           CardTheme @default(default_dark)
  customColor     String?   @map("custom_color") @db.VarChar(20)
  showBranding    Boolean   @default(true) @map("show_branding")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("profile_cards")
}

model SlugRequest {
  id            String            @id @default(uuid())
  telegramId    String            @map("telegram_id") @db.VarChar(40)
  user          User              @relation(fields: [telegramId], references: [telegramId], onDelete: Cascade)
  slug          String            @db.VarChar(20)
  slugPrice     Int               @map("slug_price")
  requestedPlan UserPlan          @map("requested_plan")
  bracelet      Boolean           @default(false)
  contact       String            @db.VarChar(140)
  status        SlugRequestStatus @default(new)
  adminNote     String?           @map("admin_note")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  @@index([telegramId, createdAt])
  @@index([status, createdAt])
  @@index([slug])
  @@map("slug_requests")
}

model SlugView {
  id       String   @id @default(uuid())
  fullSlug String   @map("full_slug") @db.VarChar(20)
  viewedAt DateTime @default(now()) @map("viewed_at")
  device   String?  @db.VarChar(20)
  ipHash   String?  @map("ip_hash") @db.VarChar(64)
  isUnique Boolean  @default(false) @map("is_unique")

  @@index([fullSlug, viewedAt])
  @@index([fullSlug, ipHash, viewedAt])
  @@map("slug_views")
}
