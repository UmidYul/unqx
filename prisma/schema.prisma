generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Tariff {
  basic
  premium
}

enum CardTheme {
  default_dark
  arctic
  linen
  marble
  forest
}

enum CheckerResult {
  AVAILABLE
  TAKEN
  BLOCKED
  INVALID
}

enum BraceletDeliveryStatus {
  ORDERED
  SHIPPED
  DELIVERED
}

enum UserPlan {
  none
  basic
  premium
}

enum UserStatus {
  active
  blocked
  deactivated
}

enum SlugStatus {
  free
  pending
  approved
  active
  paused
  private
  blocked
  reserved_drop
}

enum ReferralStatus {
  registered
  paid
  rewarded
}

enum ReferralRewardType {
  discount
  free_month
  bonus_slug
}

enum FlashSaleConditionType {
  all
  pattern_000
  pattern_aaa
  sequential_digits
  custom
}

enum SettingValueType {
  number
  text
  boolean
  json
  textarea
  color
}

enum DropSlugPatternType {
  random
  sequential
  themed
  manual
}

enum SlugRequestStatus {
  new
  contacted
  paid
  approved
  rejected
  expired
}

enum PurchaseType {
  slug
  basic_plan
  premium_plan
  upgrade_to_premium
  bracelet
}

model ErrorLog {
  id         String   @id @default(uuid())
  type       String   @db.VarChar(30)
  path       String
  message    String?
  userAgent  String?  @map("user_agent")
  occurredAt DateTime @default(now()) @map("occurred_at")

  @@index([type, occurredAt])
  @@index([occurredAt])
  @@map("error_logs")
}

model BraceletOrder {
  id             String                 @id @default(uuid())
  orderId        String                 @unique @map("order_id")
  name           String                 @db.VarChar(100)
  slug           String                 @db.VarChar(20)
  deliveryStatus BraceletDeliveryStatus @default(ORDERED) @map("delivery_status")
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")

  @@index([deliveryStatus, createdAt])
  @@map("bracelet_orders")
}

model SlugCheckerLog {
  id        String        @id @default(uuid())
  slug      String?       @db.VarChar(20)
  pattern   String        @db.VarChar(20)
  source    String        @db.VarChar(20)
  result    CheckerResult
  checkedAt DateTime      @default(now()) @map("checked_at")

  @@index([checkedAt])
  @@index([pattern, checkedAt])
  @@index([source, checkedAt])
  @@map("slug_checker_logs")
}

model Testimonial {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  slug      String   @db.VarChar(20)
  tariff    Tariff
  text      String
  isVisible Boolean  @default(true) @map("is_visible")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isVisible, sortOrder])
  @@map("testimonials")
}

model User {
  id                     String                @id @default(uuid())
  telegramChatId         String?               @unique @map("telegram_chat_id") @db.VarChar(40)
  telegramUsername       String?               @map("telegram_username") @db.VarChar(120)
  email                  String?               @unique @db.VarChar(190)
  pendingEmail           String?               @map("pending_email") @db.VarChar(190)
  passwordHash           String?               @map("password_hash")
  emailVerified          Boolean               @default(false) @map("email_verified")
  otpCode                String?               @map("otp_code")
  otpExpiresAt           DateTime?             @map("otp_expires_at")
  otpAttempts            Int                   @default(0) @map("otp_attempts")
  resetPasswordToken     String?               @map("reset_password_token")
  resetPasswordExpiresAt DateTime?             @map("reset_password_expires_at")
  lastLoginAt            DateTime?             @map("last_login_at")
  loginAttempts          Int                   @default(0) @map("login_attempts")
  lockedUntil            DateTime?             @map("locked_until")
  firstName              String                @map("first_name") @db.VarChar(120)
  lastName               String?               @map("last_name") @db.VarChar(120)
  username               String?               @db.VarChar(120)
  displayName            String?               @map("display_name") @db.VarChar(120)
  plan                   UserPlan              @default(none)
  planPurchasedAt        DateTime?             @map("plan_purchased_at")
  planUpgradedAt         DateTime?             @map("plan_upgraded_at")
  welcomeDismissed       Boolean               @default(false) @map("welcome_dismissed")
  notificationsEnabled   Boolean               @default(true) @map("notifications_enabled")
  status                 UserStatus            @default(active)
  isVerified             Boolean               @default(false) @map("is_verified")
  verifiedCompany        String?               @map("verified_company") @db.VarChar(160)
  verifiedAt             DateTime?             @map("verified_at")
  showInDirectory        Boolean               @default(true) @map("show_in_directory")
  directorySector        String?               @map("directory_sector") @db.VarChar(20)
  refCode                String?               @unique @map("ref_code") @db.VarChar(40)
  createdAt              DateTime              @default(now()) @map("created_at")
  updatedAt              DateTime              @updatedAt @map("updated_at")
  slugs                  Slug[]
  profileCard            ProfileCard?
  slugRequests           SlugRequest[]
  slugWaitlistEntries    SlugWaitlist[]
  referralsMade          Referral[]            @relation("ReferrerReferrals")
  referralsReceived      Referral[]            @relation("ReferredReferrals")
  dropWaitlistEntries    DropWaitlist[]
  unqScore               UnqScore?
  scoreHistory           ScoreHistory[]
  purchases              Purchase[]
  verificationRequests   VerificationRequest[]

  @@index([plan, planPurchasedAt])
  @@index([status])
  @@map("users")
}

model Slug {
  id                 String      @id @default(uuid())
  letters            String      @db.VarChar(3)
  digits             String      @db.VarChar(3)
  fullSlug           String      @unique @map("full_slug") @db.VarChar(20)
  ownerId            String?     @map("owner_id")
  owner              User?       @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  status             SlugStatus  @default(free)
  isPrimary          Boolean     @default(false) @map("is_primary")
  price              Int?
  pauseMessage       String?     @map("pause_message") @db.VarChar(220)
  requestedAt        DateTime?   @map("requested_at")
  pendingExpiresAt   DateTime?   @map("pending_expires_at")
  analyticsViewsCount Int        @default(0) @map("analytics_views_count")
  approvedAt         DateTime?   @map("approved_at")
  activatedAt        DateTime?   @map("activated_at")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  @@index([ownerId, status])
  @@index([status, updatedAt])
  @@index([analyticsViewsCount(sort: Desc)])
  @@map("slugs")
}

model SlugWaitlist {
  id        String   @id @default(uuid())
  fullSlug  String   @map("full_slug") @db.VarChar(20)
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipHash    String?  @map("ip_hash") @db.VarChar(64)
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([fullSlug, createdAt])
  @@index([userId, createdAt])
  @@map("slug_waitlist")
}

model ProfileCard {
  id           String    @id @default(uuid())
  ownerId      String    @unique @map("owner_id")
  owner        User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name         String    @db.VarChar(120)
  role         String?   @db.VarChar(120)
  bio          String?   @db.VarChar(120)
  hashtag      String?   @db.VarChar(50)
  address      String?
  postcode     String?   @db.VarChar(20)
  email        String?   @db.VarChar(100)
  extraPhone   String?   @map("extra_phone") @db.VarChar(30)
  avatarUrl    String?   @map("avatar_url")
  tags         Json      @default("[]")
  buttons      Json      @default("[]")
  theme        CardTheme @default(default_dark)
  customColor  String?   @map("custom_color") @db.VarChar(20)
  showBranding Boolean   @default(true) @map("show_branding")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("profile_cards")
}

model SlugRequest {
  id                 String            @id @default(uuid())
  userId             String            @map("user_id")
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug               String            @db.VarChar(20)
  slugPrice          Int               @map("slug_price")
  requestedPlan      UserPlan          @map("requested_plan")
  planPrice          Int               @default(0) @map("plan_price")
  bracelet           Boolean           @default(false)
  status             SlugRequestStatus @default(new)
  adminNote          String?           @map("admin_note")
  dropId             String?           @map("drop_id")
  drop               Drop?             @relation(fields: [dropId], references: [id], onDelete: SetNull)
  flashSaleId        String?           @map("flash_sale_id")
  flashSale          FlashSale?        @relation(fields: [flashSaleId], references: [id], onDelete: SetNull)
  flashDiscountAmount Int              @default(0) @map("flash_discount_amount")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([slug])
  @@map("slug_requests")
}

model Purchase {
  id              String       @id @default(uuid())
  userId          String       @map("user_id")
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            PurchaseType
  amount          Int
  slug            String?      @db.VarChar(20)
  purchasedAt     DateTime     @default(now()) @map("purchased_at")
  approvedByAdmin String?      @map("approved_by_admin") @db.VarChar(40)
  approvedAt      DateTime?    @map("approved_at")
  note            String?

  @@index([userId, purchasedAt(sort: Desc)])
  @@index([type, purchasedAt(sort: Desc)])
  @@index([slug])
  @@map("purchases")
}

model AnalyticsView {
  id        String   @id @default(uuid())
  slug      String   @db.VarChar(20)
  visitedAt DateTime @default(now()) @map("visited_at")
  source    String   @default("direct") @db.VarChar(20)
  city      String   @default("Неизвестно") @db.VarChar(120)
  device    String   @default("desktop") @db.VarChar(20)
  sessionId String   @map("session_id") @db.VarChar(80)

  @@index([slug, visitedAt])
  @@index([visitedAt])
  @@index([slug, sessionId, visitedAt])
  @@map("analytics_views")
}

model AnalyticsClick {
  id         String   @id @default(uuid())
  slug       String   @db.VarChar(20)
  buttonType String   @default("other") @map("button_type") @db.VarChar(40)
  clickedAt  DateTime @default(now()) @map("clicked_at")

  @@index([slug, clickedAt])
  @@index([buttonType, clickedAt])
  @@map("analytics_clicks")
}

model VerificationRequest {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug        String   @db.VarChar(20)
  companyName String   @map("company_name") @db.VarChar(160)
  role        String   @db.VarChar(160)
  sector      String   @default("other") @db.VarChar(20)
  proofType   String   @map("proof_type") @db.VarChar(20)
  proofValue  String   @map("proof_value") @db.VarChar(320)
  comment     String?
  status      String   @default("pending") @db.VarChar(20)
  adminNote   String?  @map("admin_note")
  requestedAt DateTime @default(now()) @map("requested_at")
  reviewedAt  DateTime? @map("reviewed_at")

  @@index([userId, status])
  @@index([status, requestedAt(sort: Desc)])
  @@map("verification_requests")
}

model DirectoryExclusion {
  slug       String   @id @db.VarChar(20)
  reason     String?
  excludedBy String?  @map("excluded_by") @db.VarChar(80)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("directory_exclusions")
}

model UnqScore {
  userId          String   @id @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score           Int      @default(0)
  scoreViews      Int      @default(0) @map("score_views")
  scoreSlugRarity Int      @default(0) @map("score_slug_rarity")
  scoreTenure     Int      @default(0) @map("score_tenure")
  scoreCtr        Int      @default(0) @map("score_ctr")
  scoreBracelet   Int      @default(0) @map("score_bracelet")
  scorePlan       Int      @default(0) @map("score_plan")
  percentile      Float    @default(0)
  calculatedAt    DateTime @default(now()) @map("calculated_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([score(sort: Desc)])
  @@index([percentile(sort: Desc)])
  @@map("unq_scores")
}

model ScoreHistory {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score      Int
  recordedAt DateTime @map("recorded_at")

  @@unique([userId, recordedAt])
  @@index([recordedAt])
  @@index([userId, recordedAt])
  @@map("score_history")
}

model ScoreRecalculationRun {
  id               String   @id @default(uuid())
  processedUsers   Int      @default(0) @map("processed_users")
  averageMsPerUser Float    @default(0) @map("average_ms_per_user")
  startedAt        DateTime @default(now()) @map("started_at")
  finishedAt       DateTime @default(now()) @map("finished_at")

  @@index([startedAt(sort: Desc)])
  @@map("score_recalculation_runs")
}

model ReferralRewardRule {
  id                  String             @id @default(uuid())
  requiredPaidFriends Int                @unique @map("required_paid_friends")
  rewardType          ReferralRewardType @map("reward_type")
  rewardValue         Int?               @map("reward_value")
  isActive            Boolean            @default(true) @map("is_active")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  referrals           Referral[]

  @@map("referral_reward_rules")
}

model Referral {
  id             String              @id @default(uuid())
  referrerId     String              @map("referrer_id")
  referrer       User                @relation("ReferrerReferrals", fields: [referrerId], references: [id], onDelete: Cascade)
  referredId     String              @unique @map("referred_id")
  referred       User                @relation("ReferredReferrals", fields: [referredId], references: [id], onDelete: Cascade)
  refCode        String              @map("ref_code") @db.VarChar(40)
  status         ReferralStatus      @default(registered)
  rewardType     ReferralRewardType? @map("reward_type")
  rewardedRuleId String?             @map("rewarded_rule_id")
  rewardedRule   ReferralRewardRule? @relation(fields: [rewardedRuleId], references: [id], onDelete: SetNull)
  createdAt      DateTime            @default(now()) @map("created_at")
  rewardedAt     DateTime?           @map("rewarded_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  @@index([referrerId, status])
  @@index([createdAt])
  @@map("referrals")
}

model PlatformSetting {
  key         String                 @id @db.VarChar(120)
  value       Json                   @default("{}")
  group       String                 @db.VarChar(60)
  label       String                 @db.VarChar(180)
  description String?
  type        SettingValueType
  updatedAt   DateTime               @updatedAt @map("updated_at")
  updatedBy   String?                @map("updated_by") @db.VarChar(80)
  changes     PlatformSettingChange[]

  @@index([group])
  @@map("platform_settings")
}

model PlatformSettingChange {
  id         String          @id @default(uuid())
  settingKey String          @map("setting_key") @db.VarChar(120)
  setting    PlatformSetting @relation(fields: [settingKey], references: [key], onDelete: Cascade)
  group      String          @db.VarChar(60)
  oldValue   Json?           @map("old_value")
  newValue   Json?           @map("new_value")
  changedBy  String?         @map("changed_by") @db.VarChar(80)
  changedAt  DateTime        @default(now()) @map("changed_at")

  @@index([settingKey, changedAt(sort: Desc)])
  @@index([group, changedAt(sort: Desc)])
  @@map("platform_setting_changes")
}

model FlashSale {
  id                        String                 @id @default(uuid())
  title                     String                 @db.VarChar(180)
  description               String?
  discountPercent           Int                    @map("discount_percent")
  conditionType             FlashSaleConditionType @map("condition_type")
  conditionValue            Json?                  @map("condition_value")
  startsAt                  DateTime               @map("starts_at")
  endsAt                    DateTime               @map("ends_at")
  isActive                  Boolean                @default(true) @map("is_active")
  notifyTelegram            Boolean                @default(false) @map("notify_telegram")
  telegramTarget            String?                @map("telegram_target") @db.VarChar(120)
  createdByAdmin            String?                @map("created_by_admin") @db.VarChar(80)
  startedNotificationSentAt DateTime?              @map("started_notification_sent_at")
  createdAt                 DateTime               @default(now()) @map("created_at")
  updatedAt                 DateTime               @updatedAt @map("updated_at")
  slugRequests              SlugRequest[]

  @@index([isActive, startsAt, endsAt])
  @@map("flash_sales")
}

model Drop {
  id              String              @id @default(uuid())
  title           String              @db.VarChar(180)
  description     String?
  dropAt          DateTime            @map("drop_at")
  slugCount       Int                 @map("slug_count")
  slugPatternType DropSlugPatternType @map("slug_pattern_type")
  slugsPool       Json                @default("[]") @map("slugs_pool")
  soldSlugs       Json                @default("[]") @map("sold_slugs")
  isAnnounced     Boolean             @default(false) @map("is_announced")
  isLive          Boolean             @default(false) @map("is_live")
  isSoldOut       Boolean             @default(false) @map("is_sold_out")
  isFinished      Boolean             @default(false) @map("is_finished")
  notifyTelegram  Boolean             @default(false) @map("notify_telegram")
  telegramTarget  String?             @map("telegram_target") @db.VarChar(120)
  notified15mAt   DateTime?           @map("notified_15m_at")
  notifiedStartAt DateTime?           @map("notified_start_at")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  waitlist        DropWaitlist[]
  slugRequests    SlugRequest[]

  @@index([dropAt])
  @@index([isLive, isFinished, isSoldOut])
  @@map("drops")
}

model DropWaitlist {
  id              String   @id @default(uuid())
  dropId          String   @map("drop_id")
  drop            Drop     @relation(fields: [dropId], references: [id], onDelete: Cascade)
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt        DateTime @default(now()) @map("joined_at")
  notifiedAt      DateTime? @map("notified_at")
  notified15mAt   DateTime? @map("notified_15m_at")
  notifiedStartAt DateTime? @map("notified_start_at")

  @@unique([dropId, userId])
  @@index([dropId, joinedAt])
  @@map("drop_waitlist")
}

model LeaderboardExclusion {
  fullSlug   String   @id @map("full_slug") @db.VarChar(20)
  reason     String?
  excludedBy String?  @map("excluded_by") @db.VarChar(80)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("leaderboard_exclusions")
}

model LeaderboardSuspiciousLog {
  id            String   @id @default(uuid())
  fullSlug      String   @map("full_slug") @db.VarChar(20)
  viewsCount    Int      @map("views_count")
  windowMinutes Int      @map("window_minutes")
  threshold     Int
  occurredAt    DateTime @default(now()) @map("occurred_at")

  @@index([fullSlug, occurredAt])
  @@map("leaderboard_suspicious_log")
}
