generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Tariff {
  basic
  premium
}

enum CardTheme {
  default_dark
  light_minimal
  gradient
  neon
  corporate
}

enum OrderStatus {
  NEW
  CONTACTED
  PAID
  ACTIVATED
  REJECTED
}

enum SlugState {
  TAKEN
  BLOCKED
}

enum CheckerResult {
  AVAILABLE
  TAKEN
  BLOCKED
  INVALID
}

enum BraceletDeliveryStatus {
  ORDERED
  SHIPPED
  DELIVERED
}

model Card {
  id         String    @id @default(uuid())
  slug       String    @unique @db.VarChar(20)
  isActive   Boolean   @default(true) @map("is_active")
  tariff     Tariff    @default(basic)
  theme      CardTheme @default(default_dark)
  avatarUrl  String?   @map("avatar_url")
  name       String    @db.VarChar(100)
  phone      String    @db.VarChar(30)
  verified   Boolean   @default(false)
  hashtag    String?   @db.VarChar(50)
  address    String?
  postcode   String?   @db.VarChar(20)
  email      String?   @db.VarChar(100)
  extraPhone String?   @map("extra_phone") @db.VarChar(30)
  viewsCount Int       @default(0) @map("views_count")
  uniqueViewsCount Int @default(0) @map("unique_views_count")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  buttons    Button[]
  tags       Tag[]
  viewsLog   ViewLog[]
  orderRequests OrderRequest[]
  slugRecord SlugRecord?

  @@index([isActive])
  @@index([createdAt])
  @@map("cards")
}

model Tag {
  id        String @id @default(uuid())
  cardId    String @map("card_id")
  card      Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label     String @db.VarChar(50)
  url       String?
  sortOrder Int    @map("sort_order")

  @@index([cardId, sortOrder])
  @@map("tags")
}

model Button {
  id        String  @id @default(uuid())
  cardId    String  @map("card_id")
  card      Card    @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label     String  @db.VarChar(50)
  url       String
  sortOrder Int     @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  @@index([cardId, sortOrder])
  @@map("buttons")
}

model ViewLog {
  id       String   @id @default(uuid())
  cardId   String   @map("card_id")
  card     Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  viewedAt DateTime @default(now()) @map("viewed_at")
  device   String?  @db.VarChar(20)
  ipHash   String?  @map("ip_hash") @db.VarChar(64)
  isUnique Boolean  @default(false) @map("is_unique")

  @@index([cardId, viewedAt])
  @@index([cardId, ipHash, viewedAt])
  @@index([viewedAt])
  @@map("views_log")
}

model ErrorLog {
  id         String   @id @default(uuid())
  type       String   @db.VarChar(30)
  path       String
  message    String?
  userAgent  String?  @map("user_agent")
  occurredAt DateTime @default(now()) @map("occurred_at")

  @@index([type, occurredAt])
  @@index([occurredAt])
  @@map("error_logs")
}

model OrderRequest {
  id        String      @id @default(uuid())
  name      String      @db.VarChar(100)
  slug      String      @db.VarChar(20)
  slugPrice Int         @map("slug_price")
  tariff    Tariff
  theme     CardTheme?
  bracelet  Boolean     @default(false)
  contact   String      @db.VarChar(120)
  status    OrderStatus @default(NEW)
  cardId    String?     @map("card_id")
  card      Card?       @relation(fields: [cardId], references: [id], onDelete: SetNull)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  braceletOrder BraceletOrder?

  @@index([slug, createdAt])
  @@index([status, createdAt])
  @@index([cardId])
  @@map("order_requests")
}

model BraceletOrder {
  id            String                 @id @default(uuid())
  orderId       String                 @unique @map("order_id")
  order         OrderRequest           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  name          String                 @db.VarChar(100)
  slug          String                 @db.VarChar(20)
  contact       String                 @db.VarChar(120)
  deliveryStatus BraceletDeliveryStatus @default(ORDERED) @map("delivery_status")
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")

  @@index([deliveryStatus, createdAt])
  @@map("bracelet_orders")
}

model SlugRecord {
  id             String    @id @default(uuid())
  slug           String    @unique @db.VarChar(20)
  state          SlugState @default(TAKEN)
  ownerName      String?   @map("owner_name") @db.VarChar(100)
  priceOverride  Int?      @map("price_override")
  activationDate DateTime? @map("activation_date")
  cardId         String?   @unique @map("card_id")
  card           Card?     @relation(fields: [cardId], references: [id], onDelete: SetNull)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([state])
  @@index([activationDate])
  @@map("slug_records")
}

model SlugCheckerLog {
  id       String        @id @default(uuid())
  slug     String?       @db.VarChar(20)
  pattern  String        @db.VarChar(20)
  source   String        @db.VarChar(20)
  result   CheckerResult
  checkedAt DateTime     @default(now()) @map("checked_at")

  @@index([checkedAt])
  @@index([pattern, checkedAt])
  @@index([source, checkedAt])
  @@map("slug_checker_logs")
}

model Testimonial {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  slug      String   @db.VarChar(20)
  tariff    Tariff
  text      String
  isVisible Boolean  @default(true) @map("is_visible")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isVisible, sortOrder])
  @@map("testimonials")
}
