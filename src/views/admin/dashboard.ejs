<%
  const pageTitle = typeof title === "string" && title ? title : "Дашборд";
  const pageActiveTab =
    typeof activeTab === "string" && activeTab
      ? activeTab
      : "analytics";
  const pagePublicBaseUrl = typeof publicBaseUrl === "string" && publicBaseUrl ? publicBaseUrl : "";
  const pageQuery = typeof query === "object" && query ? query : {};
%>
<!doctype html>
<html lang="ru">
<head>
  <%- include('../partials/head', { title: pageTitle, styles: ['/css/admin.css'] }) %>
</head>
<body class="antialiased" data-admin-layout="1" data-page="admin-dashboard" data-public-base-url="<%= pagePublicBaseUrl %>" data-active-tab="<%= pageActiveTab %>">
  <%- include('../partials/admin-layout-start', { activeTab: pageActiveTab }) %>
      <div class="mx-auto w-full max-w-6xl space-y-5">
        <div class="flex flex-wrap items-start justify-between gap-3 border-b border-neutral-200 pb-4">
          <div>
            <h1 class="text-2xl font-black">Управление платформой</h1>
            <p class="mt-1 text-sm text-neutral-500">Мониторинг заявок, пользователей и маркетинговых инструментов</p>
          </div>
          <a
            href="/admin/cards/new"
            class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-neutral-900 px-4 py-2 text-center text-sm font-semibold text-white transition hover:bg-neutral-700 sm:w-auto"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
            <span>Создать визитку</span>
          </a>
        </div>

        <section id="tab-analytics" class="<%= pageActiveTab === 'analytics' ? '' : 'hidden' %> space-y-4">
          <div id="analytics-kpis" class="grid gap-3 md:grid-cols-4"></div>
          <div class="grid gap-4 lg:grid-cols-2">
            <article class="rounded-2xl border border-neutral-200 bg-white p-4">
              <h2 class="text-sm font-semibold text-neutral-900">Заявки по дням (30 дней)</h2>
              <div class="mt-3 h-[280px]"><canvas id="analytics-orders-chart"></canvas></div>
            </article>
            <article class="rounded-2xl border border-neutral-200 bg-white p-4">
              <h2 class="text-sm font-semibold text-neutral-900">Разбивка по тарифам</h2>
              <div class="mt-3 h-[280px]"><canvas id="analytics-tariff-chart"></canvas></div>
            </article>
          </div>
          <article class="rounded-2xl border border-neutral-200 bg-white p-4">
            <h2 class="text-sm font-semibold text-neutral-900">Распределение UNQ Score</h2>
            <div class="mt-3 h-[260px]"><canvas id="analytics-score-distribution-chart"></canvas></div>
          </article>
          <article class="rounded-2xl border border-neutral-200 bg-white p-4">
            <h2 class="text-sm font-semibold text-neutral-900">Топ-10 паттернов ищут, но не покупают</h2>
            <div class="mt-3 overflow-hidden rounded-xl border border-neutral-200">
              <table class="min-w-full text-left text-sm">
                <thead class="bg-neutral-50 text-xs uppercase tracking-wide text-neutral-500">
                  <tr>
                    <th class="px-3 py-2">Паттерн</th>
                    <th class="px-3 py-2">Проверок</th>
                  </tr>
                </thead>
                <tbody id="analytics-checker-table"></tbody>
              </table>
            </div>
          </article>
        </section>

        <section id="tab-orders" class="<%= pageActiveTab === 'orders' ? '' : 'hidden' %> space-y-4">
          <form id="orders-filters" class="grid gap-3 rounded-2xl border border-neutral-200 bg-white p-4 md:grid-cols-6">
            <select name="status" class="rounded-xl border border-neutral-300 px-3 py-2 text-sm">
              <option value="all">Все статусы</option>
              <option value="new">Новая</option>
              <option value="contacted">Связались</option>
              <option value="paid">Ожидает оплаты</option>
              <option value="approved">Одобрено</option>
              <option value="rejected">Отклонено</option>
              <option value="expired">Истекла</option>
            </select>
            <select name="tariff" class="rounded-xl border border-neutral-300 px-3 py-2 text-sm">
              <option value="all">Все тарифы</option>
              <option value="basic">Базовый</option>
              <option value="premium">Премиум</option>
            </select>
            <select name="bracelet" class="rounded-xl border border-neutral-300 px-3 py-2 text-sm">
              <option value="all">Браслет: все</option>
              <option value="yes">С браслетом</option>
              <option value="no">Без браслета</option>
            </select>
            <input type="date" name="dateFrom" class="rounded-xl border border-neutral-300 px-3 py-2 text-sm" />
            <input type="date" name="dateTo" class="rounded-xl border border-neutral-300 px-3 py-2 text-sm" />
            <input type="hidden" name="page" value="1" />
            <button type="submit" class="inline-flex min-h-11 w-full items-center justify-center justify-self-start rounded-xl border border-neutral-300 px-4 py-2 text-sm font-semibold text-neutral-700 transition hover:bg-neutral-100 md:w-auto">Применить</button>
          </form>
          <div class="flex justify-end">
            <a id="orders-export-link" href="/api/admin/orders/export.csv" class="rounded-xl border border-neutral-300 bg-white px-3 py-2 text-sm font-semibold text-neutral-700 transition hover:bg-neutral-100">
              Скачать CSV
            </a>
          </div>
          <div class="overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-sm">
            <div class="overflow-x-auto">
              <table class="min-w-[980px] w-full text-left text-sm">
                <thead class="bg-neutral-50 text-xs uppercase tracking-wide text-neutral-500">
                  <tr>
                    <th class="px-4 py-3">Дата</th>
                    <th class="px-4 py-3">Имя</th>
                    <th class="px-4 py-3">Slug</th>
                    <th class="px-4 py-3">Цена slug</th>
                    <th class="px-4 py-3">Тариф</th>
                    <th class="px-4 py-3">Браслет</th>
                    <th class="px-4 py-3">Контакт</th>
                    <th class="px-4 py-3">Статус</th>
                    <th class="px-4 py-3">Действия</th>
                  </tr>
                </thead>
                <tbody id="orders-table"></tbody>
              </table>
            </div>
          </div>
          <div id="orders-pagination" class="flex items-center justify-end gap-2 text-sm text-neutral-600"></div>
        </section>

        <section id="tab-users" class="<%= pageActiveTab === 'users' ? '' : 'hidden' %> space-y-4">
          <form id="users-filters" class="grid gap-3 rounded-2xl border border-neutral-200 bg-white p-4 md:grid-cols-[1fr_200px_auto]">
            <input type="text" name="q" placeholder="Поиск по Telegram или имени" class="rounded-xl border border-neutral-300 px-3 py-2 text-sm" />
            <select name="sort" class="rounded-xl border border-neutral-300 px-3 py-2 text-sm">
              <option value="created_desc">Сначала новые</option>
              <option value="score_desc">По UNQ Score</option>
            </select>
            <input type="hidden" name="page" value="1" />
            <button type="submit" class="inline-flex min-h-11 w-full items-center justify-center justify-self-start rounded-xl border border-neutral-300 px-4 py-2 text-sm font-semibold text-neutral-700 transition hover:bg-neutral-100 md:w-auto">Применить</button>
          </form>
          <div class="overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-sm">
            <div class="overflow-x-auto">
              <table class="min-w-[1100px] w-full text-left text-sm">
                <thead class="bg-neutral-50 text-xs uppercase tracking-wide text-neutral-500">
                  <tr>
                    <th class="px-4 py-3">Telegram</th>
                    <th class="px-4 py-3">Имя</th>
                    <th class="px-4 py-3">Тариф</th>
                    <th class="px-4 py-3">До тарифа</th>
                    <th class="px-4 py-3">Slug(и)</th>
                    <th class="px-4 py-3">Визитка</th>
                    <th class="px-4 py-3">UNQ Score</th>
                    <th class="px-4 py-3">Статус</th>
                    <th class="px-4 py-3">Дата регистрации</th>
                    <th class="px-4 py-3">Действия</th>
                  </tr>
                </thead>
                <tbody id="users-table"></tbody>
              </table>
            </div>
          </div>
          <div id="users-pagination" class="flex items-center justify-end gap-2 text-sm text-neutral-600"></div>
        </section>

        <section id="tab-slugs" class="<%= pageActiveTab === 'slugs' ? '' : 'hidden' %> space-y-4">
          <div id="slugs-stats" class="grid gap-3 md:grid-cols-4"></div>
          <form id="slugs-filters" class="grid gap-3 rounded-2xl border border-neutral-200 bg-white p-4 md:grid-cols-4">
            <input type="text" name="q" placeholder="Поиск slug" class="rounded-xl border border-neutral-300 px-3 py-2 text-sm" />
            <select name="state" class="rounded-xl border border-neutral-300 px-3 py-2 text-sm">
              <option value="all">Все статусы</option>
              <option value="free">Свободен</option>
              <option value="taken">Занят</option>
              <option value="blocked">Заблокирован</option>
            </select>
            <input type="hidden" name="page" value="1" />
            <button type="submit" class="inline-flex min-h-11 w-full items-center justify-center justify-self-start rounded-xl border border-neutral-300 px-4 py-2 text-sm font-semibold text-neutral-700 transition hover:bg-neutral-100 md:w-auto">Применить</button>
          </form>
          <div class="overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-sm">
            <div class="overflow-x-auto">
              <table class="min-w-[980px] w-full text-left text-sm">
                <thead class="bg-neutral-50 text-xs uppercase tracking-wide text-neutral-500">
                  <tr>
                    <th class="px-4 py-3">Slug</th>
                    <th class="px-4 py-3">Статус</th>
                    <th class="px-4 py-3">Владелец</th>
                    <th class="px-4 py-3">Основной</th>
                    <th class="px-4 py-3">Цена</th>
                    <th class="px-4 py-3">Запрошен</th>
                    <th class="px-4 py-3">Одобрен</th>
                    <th class="px-4 py-3">Активирован</th>
                    <th class="px-4 py-3">Действия</th>
                  </tr>
                </thead>
                <tbody id="slugs-table"></tbody>
              </table>
            </div>
          </div>
          <div id="slugs-pagination" class="flex items-center justify-end gap-2 text-sm text-neutral-600"></div>
        </section>

        <section id="tab-cards" class="<%= pageActiveTab === 'cards' ? '' : 'hidden' %> space-y-4">
          <form id="cards-filters" class="grid gap-3 rounded-2xl border border-neutral-200 bg-white p-4 md:grid-cols-[1fr_180px_auto]">
            <input type="text" name="q" placeholder="Поиск по slug или имени" class="rounded-xl border border-neutral-300 px-3 py-2 text-sm" />
            <select name="status" class="rounded-xl border border-neutral-300 px-3 py-2 text-sm">
              <option value="all">Все</option>
              <option value="active">Активные</option>
              <option value="inactive">Выключенные</option>
            </select>
            <input type="hidden" name="page" value="1" />
            <button type="submit" class="inline-flex min-h-11 w-full items-center justify-center justify-self-start rounded-xl border border-neutral-300 px-4 py-2 text-sm font-semibold text-neutral-700 transition hover:bg-neutral-100 md:w-auto">Применить</button>
          </form>
          <div class="overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-sm">
            <div class="overflow-x-auto">
              <table class="min-w-[980px] w-full text-left text-sm">
                <thead class="bg-neutral-50 text-xs uppercase tracking-wide text-neutral-500">
                  <tr>
                    <th class="px-4 py-3">Slug</th>
                    <th class="px-4 py-3">Имя владельца</th>
                    <th class="px-4 py-3">Тариф</th>
                    <th class="px-4 py-3">Статус</th>
                    <th class="px-4 py-3">Просмотры</th>
                    <th class="px-4 py-3">Дата создания</th>
                    <th class="px-4 py-3">Действия</th>
                  </tr>
                </thead>
                <tbody id="cards-table"></tbody>
              </table>
            </div>
          </div>
          <div id="cards-pagination" class="flex items-center justify-end gap-2 text-sm text-neutral-600"></div>
        </section>

        <section id="tab-bracelets" class="<%= pageActiveTab === 'bracelets' ? '' : 'hidden' %> space-y-4">
          <form id="bracelets-filters" class="grid gap-3 rounded-2xl border border-neutral-200 bg-white p-4 md:grid-cols-[220px_auto]">
            <select name="status" class="rounded-xl border border-neutral-300 px-3 py-2 text-sm">
              <option value="all">Все статусы</option>
              <option value="ORDERED">Заказан</option>
              <option value="SHIPPED">Отправлен</option>
              <option value="DELIVERED">Доставлен</option>
            </select>
            <input type="hidden" name="page" value="1" />
            <button type="submit" class="inline-flex min-h-11 w-full items-center justify-center justify-self-start rounded-xl border border-neutral-300 px-4 py-2 text-sm font-semibold text-neutral-700 transition hover:bg-neutral-100 md:w-auto">Применить</button>
          </form>
          <div class="overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-sm">
            <div class="overflow-x-auto">
              <table class="min-w-[860px] w-full text-left text-sm">
                <thead class="bg-neutral-50 text-xs uppercase tracking-wide text-neutral-500">
                  <tr>
                    <th class="px-4 py-3">Дата</th>
                    <th class="px-4 py-3">Имя</th>
                    <th class="px-4 py-3">Slug</th>
                    <th class="px-4 py-3">Контакт</th>
                    <th class="px-4 py-3">Статус доставки</th>
                  </tr>
                </thead>
                <tbody id="bracelets-table"></tbody>
              </table>
            </div>
          </div>
          <div id="bracelets-pagination" class="flex items-center justify-end gap-2 text-sm text-neutral-600"></div>
        </section>

        <section id="tab-score" class="<%= pageActiveTab === 'score' ? '' : 'hidden' %> space-y-4">
          <div class="flex flex-wrap items-center justify-between gap-2 rounded-2xl border border-neutral-200 bg-white p-4">
            <button id="score-recalculate-all-btn" type="button" class="interactive-btn min-h-11 rounded-xl bg-neutral-900 px-4 py-2 text-sm font-semibold text-white">Пересчитать всех</button>
            <label class="inline-flex items-center gap-2 text-sm text-neutral-700">
              <input id="score-visibility-toggle" type="checkbox" class="h-4 w-4 rounded border-neutral-300 text-neutral-900" />
              Показывать Score на визитках
            </label>
          </div>
          <div class="overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-sm">
            <div class="overflow-x-auto">
              <table class="min-w-[980px] w-full text-left text-sm">
                <thead class="bg-neutral-50 text-xs uppercase tracking-wide text-neutral-500">
                  <tr>
                    <th class="px-4 py-3">Пользователь</th>
                    <th class="px-4 py-3">Slug</th>
                    <th class="px-4 py-3">Score</th>
                    <th class="px-4 py-3">Percentile</th>
                    <th class="px-4 py-3">Последний расчёт</th>
                    <th class="px-4 py-3">Действие</th>
                  </tr>
                </thead>
                <tbody id="score-table"></tbody>
              </table>
            </div>
          </div>
          <article class="rounded-2xl border border-neutral-200 bg-white p-4">
            <h2 class="text-sm font-semibold text-neutral-900">Последние 10 запусков пересчёта</h2>
            <div class="mt-3 overflow-auto">
              <table class="min-w-full text-left text-sm">
                <thead class="bg-neutral-50 text-xs uppercase tracking-wide text-neutral-500">
                  <tr>
                    <th class="px-3 py-2">Время</th>
                    <th class="px-3 py-2">Пользователей обработано</th>
                    <th class="px-3 py-2">Среднее время</th>
                  </tr>
                </thead>
                <tbody id="score-runs-table"></tbody>
              </table>
            </div>
          </article>
        </section>

        <section id="tab-leaderboard" class="<%= pageActiveTab === 'leaderboard' ? '' : 'hidden' %> space-y-4">
          <form id="leaderboard-settings-form" class="rounded-2xl border border-neutral-200 bg-white p-4 md:p-5">
            <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
              <label class="flex min-h-11 items-center gap-2 rounded-xl border border-neutral-200 bg-neutral-50 px-3 py-2 text-sm font-medium text-neutral-800 lg:col-span-4">
                <input type="checkbox" name="enabled" class="h-4 w-4 rounded border-neutral-300 text-neutral-900" />
                Показать лидерборд
              </label>

              <label class="block">
                <span class="mb-1.5 block text-xs font-semibold uppercase tracking-[0.08em] text-neutral-500">Лимит публичных позиций</span>
                <input
                  type="number"
                  name="publicLimit"
                  min="1"
                  max="200"
                  class="min-h-11 w-full rounded-xl border border-neutral-300 px-3 py-2 text-sm text-neutral-900 outline-none transition-colors focus:border-neutral-500"
                />
              </label>

              <label class="block">
                <span class="mb-1.5 block text-xs font-semibold uppercase tracking-[0.08em] text-neutral-500">Порог всплеска</span>
                <input
                  type="number"
                  name="suspiciousThreshold"
                  min="1"
                  class="min-h-11 w-full rounded-xl border border-neutral-300 px-3 py-2 text-sm text-neutral-900 outline-none transition-colors focus:border-neutral-500"
                />
              </label>

              <label class="block">
                <span class="mb-1.5 block text-xs font-semibold uppercase tracking-[0.08em] text-neutral-500">Окно (минуты)</span>
                <input
                  type="number"
                  name="suspiciousWindowMinutes"
                  min="1"
                  class="min-h-11 w-full rounded-xl border border-neutral-300 px-3 py-2 text-sm text-neutral-900 outline-none transition-colors focus:border-neutral-500"
                />
              </label>

              <div class="flex items-end">
                <button type="submit" class="interactive-btn min-h-11 w-full rounded-xl bg-neutral-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-neutral-800">
                  Сохранить
                </button>
              </div>
            </div>
          </form>
          <div class="overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-sm">
            <div class="overflow-x-auto">
              <table class="min-w-[980px] w-full text-left text-sm">
                <thead class="bg-neutral-50 text-xs uppercase tracking-wide text-neutral-500">
                  <tr>
                    <th class="px-4 py-3">#</th>
                    <th class="px-4 py-3">Slug</th>
                    <th class="px-4 py-3">Владелец</th>
                    <th class="px-4 py-3">Просмотры</th>
                    <th class="px-4 py-3">Динамика</th>
                    <th class="px-4 py-3">Тариф</th>
                    <th class="px-4 py-3">Действия</th>
                  </tr>
                </thead>
                <tbody id="leaderboard-table"></tbody>
              </table>
            </div>
          </div>
          <div class="overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-sm">
            <table class="min-w-full text-left text-sm">
              <thead class="bg-neutral-50 text-xs uppercase tracking-wide text-neutral-500"><tr><th class="px-4 py-3">Подозрительная активность</th><th class="px-4 py-3">Просмотры</th><th class="px-4 py-3">Окно</th><th class="px-4 py-3">Время</th></tr></thead>
              <tbody id="leaderboard-suspicious-table"></tbody>
            </table>
          </div>
        </section>

        <section id="tab-referrals" class="<%= pageActiveTab === 'referrals' ? '' : 'hidden' %> space-y-4">
          <div id="referrals-stats" class="grid gap-3 md:grid-cols-3"></div>
          <form id="referrals-settings-form" class="grid gap-3 rounded-2xl border border-neutral-200 bg-white p-4 md:grid-cols-3">
            <label class="flex items-center gap-2 text-sm"><input type="checkbox" name="enabled" /> Включить программу</label>
            <label class="flex items-center gap-2 text-sm"><input type="checkbox" name="requirePaid" /> Учитывать только оплативших</label>
            <button type="submit" class="rounded-xl border border-neutral-300 px-4 py-2 text-sm font-semibold text-neutral-700 transition hover:bg-neutral-100">Сохранить</button>
          </form>
          <div class="overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-sm">
            <div class="overflow-x-auto">
              <table class="min-w-[980px] w-full text-left text-sm">
                <thead class="bg-neutral-50 text-xs uppercase tracking-wide text-neutral-500">
                  <tr><th class="px-4 py-3">Реферер</th><th class="px-4 py-3">Приглашённый</th><th class="px-4 py-3">Дата</th><th class="px-4 py-3">Статус</th><th class="px-4 py-3">Награда</th><th class="px-4 py-3">Действие</th></tr>
                </thead>
                <tbody id="referrals-table"></tbody>
              </table>
            </div>
          </div>
        </section>

        <section id="tab-flash-sales" class="<%= pageActiveTab === 'flash-sales' ? '' : 'hidden' %> space-y-4">
          <form id="flash-sales-create-form" class="grid gap-3 rounded-2xl border border-neutral-200 bg-white p-4 md:grid-cols-4">
            <input name="title" type="text" placeholder="Название" class="rounded-xl border border-neutral-300 px-3 py-2 text-sm" required />
            <input name="description" type="text" placeholder="Текст баннера" class="rounded-xl border border-neutral-300 px-3 py-2 text-sm" />
            <input name="discountPercent" type="number" min="1" max="95" placeholder="Скидка %" class="rounded-xl border border-neutral-300 px-3 py-2 text-sm" required />
            <select name="conditionType" class="rounded-xl border border-neutral-300 px-3 py-2 text-sm"><option value="all">Все slug</option><option value="pattern_000">000</option><option value="pattern_aaa">AAA</option><option value="sequential_digits">123/456</option><option value="custom">Кастом</option></select>
            <input name="startsAt" type="datetime-local" class="rounded-xl border border-neutral-300 px-3 py-2 text-sm" required />
            <input name="endsAt" type="datetime-local" class="rounded-xl border border-neutral-300 px-3 py-2 text-sm" required />
            <label class="flex items-center gap-2 text-sm"><input type="checkbox" name="notifyTelegram" /> Уведомить Telegram</label>
            <input name="telegramTarget" type="text" placeholder="@channel или chat_id" class="rounded-xl border border-neutral-300 px-3 py-2 text-sm" />
            <button type="submit" class="rounded-xl border border-neutral-300 px-4 py-2 text-sm font-semibold text-neutral-700 transition hover:bg-neutral-100">Запустить</button>
          </form>
          <div class="overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-sm">
            <table class="min-w-full text-left text-sm">
              <thead class="bg-neutral-50 text-xs uppercase tracking-wide text-neutral-500"><tr><th class="px-4 py-3">Название</th><th class="px-4 py-3">Скидка</th><th class="px-4 py-3">Период</th><th class="px-4 py-3">Статус</th><th class="px-4 py-3">Статистика</th><th class="px-4 py-3">Действие</th></tr></thead>
              <tbody id="flash-sales-table"></tbody>
            </table>
          </div>
        </section>

        <section id="tab-drops" class="<%= pageActiveTab === 'drops' ? '' : 'hidden' %> space-y-4">
          <form id="drops-create-form" class="grid gap-3 rounded-2xl border border-neutral-200 bg-white p-4 md:grid-cols-4">
            <input name="title" type="text" placeholder="Название дропа" class="rounded-xl border border-neutral-300 px-3 py-2 text-sm" required />
            <input name="description" type="text" placeholder="Описание" class="rounded-xl border border-neutral-300 px-3 py-2 text-sm" />
            <input name="dropAt" type="datetime-local" class="rounded-xl border border-neutral-300 px-3 py-2 text-sm" required />
            <input name="slugCount" type="number" min="1" max="500" placeholder="Количество slug" class="rounded-xl border border-neutral-300 px-3 py-2 text-sm" required />
            <select name="slugPatternType" class="rounded-xl border border-neutral-300 px-3 py-2 text-sm"><option value="random">Случайные</option><option value="sequential">Последовательные</option><option value="manual">Вручную</option></select>
            <textarea name="manualSlugs" rows="2" placeholder="Slug по одному в строке (для manual)" class="rounded-xl border border-neutral-300 px-3 py-2 text-sm md:col-span-2"></textarea>
            <label class="flex items-center gap-2 text-sm"><input type="checkbox" name="notifyTelegram" /> Уведомить Telegram</label>
            <input name="telegramTarget" type="text" placeholder="@channel или chat_id" class="rounded-xl border border-neutral-300 px-3 py-2 text-sm" />
            <button type="submit" class="rounded-xl border border-neutral-300 px-4 py-2 text-sm font-semibold text-neutral-700 transition hover:bg-neutral-100">Создать дроп</button>
          </form>
          <div class="overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-sm">
            <table class="min-w-full text-left text-sm">
              <thead class="bg-neutral-50 text-xs uppercase tracking-wide text-neutral-500"><tr><th class="px-4 py-3">Название</th><th class="px-4 py-3">Дата</th><th class="px-4 py-3">Slug</th><th class="px-4 py-3">Статус</th><th class="px-4 py-3">Итоги</th><th class="px-4 py-3">Действие</th></tr></thead>
              <tbody id="drops-table"></tbody>
            </table>
          </div>
        </section>

        <section id="tab-testimonials" class="<%= pageActiveTab === 'testimonials' ? '' : 'hidden' %> space-y-4">
          <form id="testimonial-create-form" class="rounded-2xl border border-neutral-200 bg-white p-4">
            <h2 class="text-sm font-semibold text-neutral-900">Добавить отзыв</h2>
            <div class="mt-3 grid gap-3 md:grid-cols-4">
              <input name="name" type="text" placeholder="Имя" class="rounded-xl border border-neutral-300 px-3 py-2 text-sm" required />
              <input name="slug" type="text" placeholder="Slug" maxlength="6" class="rounded-xl border border-neutral-300 px-3 py-2 text-sm" required />
              <select name="tariff" class="rounded-xl border border-neutral-300 px-3 py-2 text-sm">
                <option value="basic">Базовый</option>
                <option value="premium">Премиум</option>
              </select>
              <button type="submit" class="rounded-xl bg-neutral-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-neutral-700">Добавить</button>
            </div>
            <textarea name="text" rows="3" placeholder="Текст отзыва" class="mt-3 w-full rounded-xl border border-neutral-300 px-3 py-2 text-sm" required></textarea>
          </form>
          <div class="overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-sm">
            <div class="overflow-x-auto">
              <table class="min-w-[860px] w-full text-left text-sm">
                <thead class="bg-neutral-50 text-xs uppercase tracking-wide text-neutral-500">
                  <tr>
                    <th class="px-4 py-3">Имя</th>
                    <th class="px-4 py-3">Slug</th>
                    <th class="px-4 py-3">Тариф</th>
                    <th class="px-4 py-3">Текст</th>
                    <th class="px-4 py-3">Видимость</th>
                    <th class="px-4 py-3">Действия</th>
                  </tr>
                </thead>
                <tbody id="testimonials-table"></tbody>
              </table>
            </div>
          </div>
          <div id="testimonials-pagination" class="flex items-center justify-end gap-2 text-sm text-neutral-600"></div>
        </section>

        <section id="tab-logs" class="<%= pageActiveTab === 'logs' ? '' : 'hidden' %> space-y-4">
          <div class="flex items-center justify-between gap-3">
            <h2 class="text-lg font-bold">Логи ошибок</h2>
            <button id="cleanup-logs-btn" type="button" class="rounded-xl border border-neutral-300 px-3 py-2 text-sm font-semibold text-neutral-700 transition hover:bg-neutral-100">Очистить старше 30 дней</button>
          </div>
          <form id="logs-filters" class="grid gap-3 rounded-2xl border border-neutral-200 bg-white p-4 md:grid-cols-[220px_1fr_auto] md:items-end">
            <select name="type" class="rounded-xl border border-neutral-300 px-3 py-2 text-sm">
              <option value="all">Все типы</option>
              <option value="not_found">Not found</option>
              <option value="server_error">Server error</option>
            </select>
            <input type="hidden" name="page" value="1" />
            <button type="submit" class="inline-flex min-h-11 w-full items-center justify-center justify-self-start rounded-xl border border-neutral-300 px-4 py-2 text-sm font-semibold text-neutral-700 transition hover:bg-neutral-100 md:w-auto">
              Применить
            </button>
          </form>
          <div class="overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-sm">
            <div class="overflow-x-auto">
              <table class="min-w-[860px] w-full text-left text-sm">
                <thead class="bg-neutral-50 text-xs uppercase tracking-wide text-neutral-500">
                  <tr>
                    <th class="px-4 py-3">Тип</th>
                    <th class="px-4 py-3">Путь</th>
                    <th class="px-4 py-3">Сообщение</th>
                    <th class="px-4 py-3">Браузер</th>
                    <th class="px-4 py-3">Время</th>
                  </tr>
                </thead>
                <tbody id="logs-table"></tbody>
              </table>
            </div>
          </div>
          <div id="logs-pagination" class="flex items-center justify-end gap-2 text-sm text-neutral-600"></div>
        </section>
      </div>
  <%- include('../partials/admin-layout-end') %>

  <div id="activation-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4" aria-hidden="true">
    <div class="w-full max-w-md rounded-2xl bg-white p-5" role="dialog" aria-modal="true">
      <div class="flex items-center justify-between">
        <h3 class="text-lg font-bold">Активация заявки</h3>
        <button type="button" id="activation-close-btn" class="inline-flex h-8 w-8 items-center justify-center rounded-lg border border-neutral-300 text-neutral-500 hover:text-neutral-900" aria-label="Закрыть">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
        </button>
      </div>
      <form id="activation-form" class="mt-4 space-y-3">
        <input type="hidden" name="orderId" />
        <label class="block text-sm font-medium text-neutral-700">
          Тариф
          <select name="tariff" class="mt-1 w-full rounded-xl border border-neutral-300 px-3 py-2 text-sm">
            <option value="basic">Базовый</option>
            <option value="premium">Премиум</option>
          </select>
        </label>
        <label class="block text-sm font-medium text-neutral-700">
          Тема
          <select name="theme" class="mt-1 w-full rounded-xl border border-neutral-300 px-3 py-2 text-sm">
            <option value="default_dark">Default Dark</option>
            <option value="light_minimal">Light Minimal</option>
            <option value="gradient">Gradient</option>
            <option value="neon">Neon</option>
            <option value="corporate">Corporate</option>
          </select>
        </label>
        <button type="submit" class="w-full rounded-xl bg-neutral-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-neutral-700">Активировать</button>
      </form>
    </div>
  </div>

  <div id="qr-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 px-4" aria-hidden="true">
    <div class="w-full max-w-md rounded-2xl bg-white p-5" role="dialog" aria-modal="true">
      <div class="flex items-center justify-between">
        <h3 class="flex items-center gap-2 text-lg font-bold">
          <img src="/brand/unq-mark.svg" alt="UNQ+" class="h-6 w-6 rounded-md border border-neutral-200 bg-white p-0.5" />
          <span>QR-код <span id="qr-title-slug"></span></span>
        </h3>
        <button type="button" class="inline-flex h-8 w-8 items-center justify-center rounded-lg border border-neutral-300 text-neutral-500 hover:text-neutral-900" data-close-modal aria-label="Закрыть">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
        </button>
      </div>

      <div class="mt-4 flex justify-center">
        <div class="rounded-xl border border-neutral-200 p-3" id="qr-svg-wrap"></div>
      </div>

      <p id="qr-error" class="mt-3 hidden rounded-lg bg-red-50 px-3 py-2 text-sm text-red-700"></p>

      <div class="mt-4 flex flex-col gap-2 sm:flex-row">
        <button type="button" id="download-qr-png" class="w-full rounded-xl bg-neutral-900 px-3 py-2 text-sm font-semibold text-white transition hover:bg-neutral-700">
          Скачать PNG 1000x1000
        </button>
        <button type="button" id="download-qr-svg" class="w-full rounded-xl border border-neutral-300 px-3 py-2 text-sm font-semibold text-neutral-800 transition hover:bg-neutral-100">
          Скачать SVG
        </button>
      </div>

      <div class="hidden">
        <canvas id="qr-canvas" width="1000" height="1000"></canvas>
      </div>
    </div>
  </div>

  <div id="testimonial-edit-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4" aria-hidden="true">
    <div class="w-full max-w-lg rounded-2xl bg-white p-5" role="dialog" aria-modal="true">
      <div class="flex items-center justify-between">
        <h3 class="text-lg font-bold">Редактировать отзыв</h3>
        <button type="button" id="testimonial-edit-close-btn" class="inline-flex h-8 w-8 items-center justify-center rounded-lg border border-neutral-300 text-neutral-500 hover:text-neutral-900" aria-label="Закрыть">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
        </button>
      </div>
      <form id="testimonial-edit-form" class="mt-4 space-y-3">
        <input type="hidden" name="id" />
        <label class="block text-sm font-medium text-neutral-700">
          Имя
          <input name="name" type="text" class="mt-1 w-full rounded-xl border border-neutral-300 px-3 py-2 text-sm" required />
        </label>
        <label class="block text-sm font-medium text-neutral-700">
          Slug
          <input name="slug" type="text" maxlength="6" class="mt-1 w-full rounded-xl border border-neutral-300 px-3 py-2 text-sm font-mono uppercase" required />
        </label>
        <label class="block text-sm font-medium text-neutral-700">
          Тариф
          <select name="tariff" class="mt-1 w-full rounded-xl border border-neutral-300 px-3 py-2 text-sm">
            <option value="basic">Базовый</option>
            <option value="premium">Премиум</option>
          </select>
        </label>
        <label class="block text-sm font-medium text-neutral-700">
          Текст
          <textarea name="text" rows="3" class="mt-1 w-full rounded-xl border border-neutral-300 px-3 py-2 text-sm" required></textarea>
        </label>
        <button type="submit" class="w-full rounded-xl bg-neutral-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-neutral-700">Сохранить</button>
      </form>
    </div>
  </div>

  <script nonce="<%= cspNonce %>" id="admin-dashboard-query" type="application/json"><%- JSON.stringify(pageQuery) %></script>
  <script nonce="<%= cspNonce %>" src="/js/admin-layout.js"></script>
  <script nonce="<%= cspNonce %>" src="/vendor/qrcode/qrcode.min.js"></script>
  <script nonce="<%= cspNonce %>" src="/vendor/chartjs/chart.umd.min.js"></script>
  <script nonce="<%= cspNonce %>" src="/js/admin-dashboard.js"></script>
  <script nonce="<%= cspNonce %>" src="/js/admin-features.js"></script>
</body>
</html>
