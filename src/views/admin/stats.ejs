<%
  const pageTitle = typeof title === "string" && title ? title : "Общая статистика";
  const pageStats =
    typeof stats === "object" && stats
      ? stats
      : {
          totalCards: 0,
          activeCards: 0,
          totalViews: 0,
          totalUniqueViews: 0,
          topCards: [],
          dailySeries: [],
        };
%>
<!doctype html>
<html lang="ru">
<head>
  <%- include('../partials/head', { title: pageTitle, styles: ['/css/admin.css'] }) %>
</head>
<body class="antialiased" data-admin-layout="1">
  <%- include('../partials/admin-layout-start', { activeTab: 'analytics' }) %>
      <div class="mx-auto w-full max-w-6xl space-y-4">
        <div class="border-b border-neutral-200 pb-4">
          <h1 class="text-2xl font-black">Общая статистика</h1>
          <p class="mt-1 text-sm text-neutral-500">Сводные метрики платформы и динамика просмотров</p>
        </div>

        <div class="grid gap-3 md:grid-cols-4">
          <div class="rounded-2xl border border-neutral-200 bg-white p-4">
            <p class="text-xs uppercase tracking-wide text-neutral-500">Всего карточек</p>
            <p class="mt-2 text-2xl font-black"><%= pageStats.totalCards %></p>
          </div>
          <div class="rounded-2xl border border-neutral-200 bg-white p-4">
            <p class="text-xs uppercase tracking-wide text-neutral-500">Активные</p>
            <p class="mt-2 text-2xl font-black"><%= pageStats.activeCards %></p>
          </div>
          <div class="rounded-2xl border border-neutral-200 bg-white p-4">
            <p class="text-xs uppercase tracking-wide text-neutral-500">Всего просмотров</p>
            <p class="mt-2 text-2xl font-black"><%= pageStats.totalViews %></p>
          </div>
          <div class="rounded-2xl border border-neutral-200 bg-white p-4">
            <p class="text-xs uppercase tracking-wide text-neutral-500">Уникальные просмотры</p>
            <p class="mt-2 text-2xl font-black"><%= pageStats.totalUniqueViews %></p>
          </div>
        </div>

        <section class="rounded-2xl border border-neutral-200 bg-white p-4">
          <h2 class="text-lg font-bold">Просмотры за 30 дней</h2>
          <div class="mt-3 h-[280px]">
            <canvas id="global-stats-chart"></canvas>
          </div>
        </section>

        <section class="rounded-2xl border border-neutral-200 bg-white p-4">
          <h2 class="text-lg font-bold">Топ-10 визиток по просмотрам</h2>
          <div class="mt-3 overflow-hidden rounded-xl border border-neutral-200">
            <div class="overflow-x-auto">
            <table class="min-w-[680px] w-full text-left text-sm">
              <thead class="bg-neutral-50 text-xs uppercase tracking-wide text-neutral-500">
                <tr>
                  <th class="px-3 py-2">Slug</th>
                  <th class="px-3 py-2">Имя</th>
                  <th class="px-3 py-2">Просмотры</th>
                  <th class="px-3 py-2">Уникальные</th>
                </tr>
              </thead>
              <tbody>
                <% pageStats.topCards.forEach((card) => { %>
                <tr class="border-t border-neutral-100">
                  <td class="px-3 py-2">
                    <a href="/admin/cards/<%= card.id %>/edit" class="text-blue-700 hover:underline">#<%= card.slug %></a>
                  </td>
                  <td class="px-3 py-2"><%= card.name %></td>
                  <td class="px-3 py-2 font-semibold"><%= card.viewsCount %></td>
                  <td class="px-3 py-2 font-semibold"><%= card.uniqueViewsCount %></td>
                </tr>
                <% }); %>

                <% if (!pageStats.topCards.length) { %>
                <tr>
                  <td colspan="4" class="px-3 py-8 text-center text-neutral-500">Нет данных</td>
                </tr>
                <% } %>
              </tbody>
            </table>
            </div>
          </div>
        </section>
      </div>
  <%- include('../partials/admin-layout-end') %>

  <script nonce="<%= cspNonce %>" id="global-stats-data" type="application/json"><%- JSON.stringify(pageStats.dailySeries) %></script>
  <script nonce="<%= cspNonce %>" src="/js/admin-layout.js"></script>
  <script nonce="<%= cspNonce %>" src="/vendor/chartjs/chart.umd.min.js"></script>
  <script nonce="<%= cspNonce %>" src="/js/admin-stats.js"></script>
</body>
</html>
