<%
  const pageTitle = typeof title === "string" && title ? title : "Логи ошибок";
  const pageType = typeof type === "string" ? type : "all";
  const pageLogs = Array.isArray(logs) ? logs : [];
  const pageNumber = Number(page) || 1;
  const pageTotalPages = Number(totalPages) || 1;
  const pageTotal = Number(total) || 0;
  const pageBuildLogsUrl =
    typeof buildLogsUrl === "function" ? buildLogsUrl : (nextPage) => `/admin/logs?page=${nextPage}`;
%>
<!doctype html>
<html lang="ru">
<head>
  <%- include('../partials/head', { title: pageTitle, styles: ['/css/admin.css'] }) %>
</head>
<body class="antialiased" data-admin-layout="1" data-page="admin-logs">
  <%- include('../partials/admin-layout-start', { activeTab: 'logs' }) %>
      <div class="mx-auto w-full max-w-6xl space-y-4">
        <div class="flex flex-wrap items-start justify-between gap-3 border-b border-neutral-200 pb-4">
          <div>
            <h1 class="text-2xl font-black">Логи ошибок</h1>
            <p class="mt-1 text-sm text-neutral-500">Системные ошибки 404/500 и служебные сообщения</p>
          </div>
          <div class="flex w-full flex-col gap-2 sm:w-auto sm:flex-row sm:items-center">
            <button
              type="button"
              id="cleanup-logs-btn"
              class="rounded-xl border border-neutral-300 px-3 py-2 text-sm font-semibold text-neutral-700 transition hover:bg-neutral-100 disabled:opacity-60"
            >
              Очистить старше 30 дней
            </button>
            <span id="cleanup-message" class="text-xs text-neutral-600"></span>
          </div>
        </div>

        <form action="/admin/logs" class="grid gap-3 rounded-2xl border border-neutral-200 bg-white p-4 md:grid-cols-[220px_auto]">
          <select
            name="type"
            class="rounded-xl border border-neutral-300 px-3 py-2 text-sm outline-none transition focus:border-neutral-500"
          >
            <option value="all" <%= pageType === 'all' ? 'selected' : '' %>>Все типы</option>
            <option value="not_found" <%= pageType === 'not_found' ? 'selected' : '' %>>404 (not_found)</option>
            <option value="server_error" <%= pageType === 'server_error' ? 'selected' : '' %>>500 (server_error)</option>
          </select>
          <button
            type="submit"
            class="rounded-xl border border-neutral-300 px-4 py-2 text-sm font-semibold text-neutral-700 transition hover:bg-neutral-100"
          >
            Применить
          </button>
        </form>

        <div class="overflow-hidden rounded-2xl border border-neutral-200 bg-white">
          <div class="overflow-x-auto">
          <table class="min-w-[860px] w-full text-left text-sm">
            <thead class="bg-neutral-50 text-xs uppercase tracking-wide text-neutral-500">
              <tr>
                <th class="px-4 py-3">Тип</th>
                <th class="px-4 py-3">Путь</th>
                <th class="px-4 py-3">Сообщение</th>
                <th class="px-4 py-3">Браузер</th>
                <th class="px-4 py-3">Время</th>
              </tr>
            </thead>
            <tbody>
              <% pageLogs.forEach((log) => { %>
              <tr class="border-t border-neutral-100 align-top">
                <td class="px-4 py-3"><%= log.type %></td>
                <td class="px-4 py-3 font-mono text-xs"><%= log.path %></td>
                <td class="px-4 py-3 text-xs text-neutral-700"><%= log.message || '-' %></td>
                <td class="px-4 py-3 text-xs text-neutral-700"><%= log.userAgent || '-' %></td>
                <td class="px-4 py-3 text-xs" data-dynamic-time="1"><%= new Date(log.occurredAt).toLocaleString('ru-RU') %></td>
              </tr>
              <% }); %>

              <% if (!pageLogs.length) { %>
              <tr>
                <td colspan="5" class="px-4 py-8 text-center text-neutral-500">Логи не найдены</td>
              </tr>
              <% } %>
            </tbody>
          </table>
          </div>
        </div>

        <div class="flex flex-col gap-3 text-sm text-neutral-600 sm:flex-row sm:items-center sm:justify-between">
          <span>Страница <%= pageNumber %> из <%= pageTotalPages %> (всего <%= pageTotal %>)</span>
          <div class="flex gap-2">
            <a
              href="<%= pageBuildLogsUrl(Math.max(1, pageNumber - 1)) %>"
              class="rounded-lg border border-neutral-300 px-3 py-1.5 transition hover:bg-neutral-100"
            >
              Назад
            </a>
            <a
              href="<%= pageBuildLogsUrl(Math.min(pageTotalPages, pageNumber + 1)) %>"
              class="rounded-lg border border-neutral-300 px-3 py-1.5 transition hover:bg-neutral-100"
            >
              Вперёд
            </a>
          </div>
        </div>
      </div>
  <%- include('../partials/admin-layout-end') %>

  <script nonce="<%= cspNonce %>" src="/js/admin-layout.js"></script>
  <script nonce="<%= cspNonce %>" src="/js/admin-logs.js"></script>
</body>
</html>
