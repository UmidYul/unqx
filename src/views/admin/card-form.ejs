<%
  const pageTitle = typeof title === "string" && title ? title : "Форма визитки";
  const pageMode = typeof mode === "string" && mode ? mode : "create";
  const pageCardId = typeof cardId === "string" && cardId ? cardId : "";
  const pageInitialAvatarUrl = typeof initialAvatarUrl === "string" && initialAvatarUrl ? initialAvatarUrl : "";

  const pageInitialValuesRaw = typeof initialValues === "object" && initialValues ? initialValues : {};
  const pageInitialValues = {
    slug: pageInitialValuesRaw.slug || "",
    isActive: typeof pageInitialValuesRaw.isActive === "boolean" ? pageInitialValuesRaw.isActive : true,
    name: pageInitialValuesRaw.name || "",
    phone: pageInitialValuesRaw.phone || "",
    verified: typeof pageInitialValuesRaw.verified === "boolean" ? pageInitialValuesRaw.verified : false,
    hashtag: pageInitialValuesRaw.hashtag || "",
    address: pageInitialValuesRaw.address || "",
    postcode: pageInitialValuesRaw.postcode || "",
    email: pageInitialValuesRaw.email || "",
    extraPhone: pageInitialValuesRaw.extraPhone || "",
    tags: Array.isArray(pageInitialValuesRaw.tags) ? pageInitialValuesRaw.tags : [],
    buttons: Array.isArray(pageInitialValuesRaw.buttons) ? pageInitialValuesRaw.buttons : [],
  };

  const pageStats = typeof stats === "object" && stats ? stats : null;
%>
<!doctype html>
<html lang="ru">
<head>
  <%- include('../partials/head', { title: pageTitle, styles: ['/css/admin.css'] }) %>
  <link rel="stylesheet" href="/vendor/cropperjs/cropper.min.css" />
</head>
<body class="antialiased" data-page="admin-card-editor" data-mode="<%= pageMode %>" data-card-id="<%= pageCardId %>">
  <div class="min-h-screen bg-neutral-100">
    <%- include('../partials/admin-header') %>

    <div class="mx-auto w-full max-w-6xl px-4 py-6">
      <div class="space-y-4">
        <h1 class="text-2xl font-black"><%= pageMode === 'create' ? 'Создать визитку' : `Редактирование #${pageInitialValues.slug}` %></h1>

        <form id="card-editor-form" class="space-y-5" novalidate>
          <section class="rounded-2xl border border-neutral-200 bg-white p-4">
            <h2 class="text-lg font-bold">Основные данные</h2>

            <div class="mt-4 grid gap-3 md:grid-cols-2">
              <label class="text-sm font-medium text-neutral-700">
                Slug
                <div class="mt-1 flex gap-2">
                  <input
                    id="field-slug"
                    type="text"
                    value="<%= pageInitialValues.slug %>"
                    class="w-full rounded-xl border border-neutral-300 px-3 py-2"
                    placeholder="AAA001"
                    maxlength="6"
                    required
                  />
                  <button
                    type="button"
                    id="generate-slug-btn"
                    class="rounded-xl border border-neutral-300 px-3 py-2 text-xs font-semibold transition hover:bg-neutral-100"
                  >
                    Авто
                  </button>
                </div>
                <p class="mt-1 hidden text-xs text-red-600" id="field-slug-error"></p>
              </label>

              <label class="mt-7 flex items-center gap-2 text-sm font-medium text-neutral-700 md:mt-0 md:self-end">
                <input id="field-is-active" type="checkbox" <%= pageInitialValues.isActive ? 'checked' : '' %> />
                Активна
              </label>

              <label class="text-sm font-medium text-neutral-700">
                Имя клиента
                <input id="field-name" type="text" value="<%= pageInitialValues.name %>" class="mt-1 w-full rounded-xl border border-neutral-300 px-3 py-2" required />
                <p class="mt-1 hidden text-xs text-red-600" id="field-name-error"></p>
              </label>

              <label class="text-sm font-medium text-neutral-700">
                Телефон
                <input
                  id="field-phone"
                  type="text"
                  value="<%= pageInitialValues.phone %>"
                  class="mt-1 w-full rounded-xl border border-neutral-300 px-3 py-2"
                  inputmode="numeric"
                  autocomplete="tel"
                  placeholder="+998 (90) 123-45-67"
                  required
                />
                <p class="mt-1 hidden text-xs text-red-600" id="field-phone-error"></p>
              </label>

              <label class="text-sm font-medium text-neutral-700">
                Нижний хэштег
                <input id="field-hashtag" type="text" value="<%= pageInitialValues.hashtag %>" class="mt-1 w-full rounded-xl border border-neutral-300 px-3 py-2" />
              </label>

              <label class="mt-7 flex items-center gap-2 text-sm font-medium text-neutral-700 md:mt-0 md:self-end">
                <input id="field-verified" type="checkbox" <%= pageInitialValues.verified ? 'checked' : '' %> />
                Верифицирован
              </label>
            </div>

            <div class="mt-4 space-y-3 rounded-2xl border border-neutral-200 bg-white p-4">
              <h3 class="text-sm font-semibold text-neutral-800">Аватар</h3>

              <div class="rounded-xl border border-dashed border-neutral-300 bg-neutral-50 p-4 text-center text-sm text-neutral-600">
                <p>Перетащите файл сюда или выберите вручную</p>
                <label
                  for="avatar-file-input"
                  id="pick-avatar-btn"
                  class="mt-2 inline-flex cursor-pointer rounded-lg border border-neutral-300 px-3 py-1.5 text-xs font-semibold transition hover:bg-neutral-100"
                >
                  Выбрать файл
                </label>
                <input
                  id="avatar-file-input"
                  type="file"
                  accept="image/png,image/jpeg,image/webp"
                  class="hidden"
                />
              </div>

              <div id="avatar-crop-wrap" class="avatar-crop-wrap rounded-xl border border-neutral-200 bg-neutral-50 p-3" hidden>
                <div class="avatar-crop-stage mx-auto">
                  <img id="avatar-crop-image" alt="Crop preview" class="avatar-crop-image" />
                </div>
              </div>

              <div class="rounded-xl border border-neutral-200 bg-neutral-50 p-3">
                <img
                  id="avatar-current-image"
                  src="<%= pageInitialAvatarUrl %>"
                  alt="Avatar"
                  class="h-24 w-24 rounded-full object-cover"
                  <%= pageInitialAvatarUrl ? '' : 'hidden' %>
                />
                <span id="avatar-fallback" class="text-xs text-neutral-600" <%= pageInitialAvatarUrl ? 'hidden' : '' %>>Нет аватара</span>
              </div>

              <button
                type="button"
                id="upload-avatar-btn"
                class="rounded-xl bg-neutral-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-neutral-700 disabled:opacity-60"
              >
                <%= pageCardId ? 'Сохранить обрезку' : 'Подготовить аватар' %>
              </button>

              <button
                type="button"
                id="remove-avatar-btn"
                class="rounded-xl border border-red-200 px-4 py-2 text-sm font-semibold text-red-700 transition hover:bg-red-50 disabled:opacity-60"
                <%= !pageCardId || !pageInitialAvatarUrl ? 'disabled' : '' %>
              >
                Удалить аватар
              </button>
            </div>
          </section>

          <section class="rounded-2xl border border-neutral-200 bg-white p-4">
            <div class="flex flex-wrap items-center justify-between gap-2">
              <h2 class="text-lg font-bold">Теги-ссылки</h2>
              <button
                type="button"
                id="add-tag-btn"
                class="w-full rounded-xl border border-neutral-300 px-3 py-1.5 text-xs font-semibold transition hover:bg-neutral-100 sm:w-auto"
              >
                + Добавить тег
              </button>
            </div>

            <div id="tags-list" class="mt-3 space-y-2">
              <% pageInitialValues.tags.forEach((tag) => { %>
              <div class="grid gap-2 rounded-xl border border-neutral-200 bg-neutral-50 p-3 md:grid-cols-[auto_1fr_1fr_auto]" data-item="tag">
                <button type="button" class="mt-2 h-7 w-7 rounded-lg border border-neutral-300 text-neutral-500" data-drag-handle>≡</button>

                <label class="text-xs font-medium text-neutral-600">
                  Текст тега
                  <input
                    type="text"
                    class="tag-label mt-1 w-full rounded-lg border border-neutral-300 bg-white px-2.5 py-2 text-sm"
                    value="<%= tag.label || '' %>"
                    placeholder="Top Dawg"
                  />
                </label>

                <label class="text-xs font-medium text-neutral-600">
                  Ссылка (необязательно)
                  <input
                    type="text"
                    class="tag-url mt-1 w-full rounded-lg border border-neutral-300 bg-white px-2.5 py-2 text-sm"
                    value="<%= tag.url || '' %>"
                    placeholder="https://..."
                  />
                </label>

                <button
                  type="button"
                  data-remove-row
                  class="mt-6 rounded-lg border border-red-200 px-3 py-2 text-xs font-semibold text-red-700 transition hover:bg-red-50"
                >
                  Удалить
                </button>
              </div>
              <% }); %>
            </div>

            <p id="tags-preview" class="mt-3 text-sm text-blue-700">Предпросмотр: теги появятся после ввода</p>
          </section>

          <section class="rounded-2xl border border-neutral-200 bg-white p-4">
            <div class="flex flex-wrap items-center justify-between gap-2">
              <h2 class="text-lg font-bold">Кнопки</h2>
              <button
                type="button"
                id="add-button-btn"
                class="w-full rounded-xl border border-neutral-300 px-3 py-1.5 text-xs font-semibold transition hover:bg-neutral-100 sm:w-auto"
              >
                + Добавить кнопку
              </button>
            </div>

            <div id="buttons-list" class="mt-3 space-y-2">
              <% pageInitialValues.buttons.forEach((button) => { %>
              <div class="grid gap-2 rounded-xl border border-neutral-200 bg-neutral-50 p-3 md:grid-cols-[auto_1fr_1fr_160px_auto]" data-item="button">
                <button type="button" class="mt-2 h-7 w-7 rounded-lg border border-neutral-300 text-neutral-500" data-drag-handle>≡</button>

                <label class="text-xs font-medium text-neutral-600">
                  Текст кнопки
                  <input
                    type="text"
                    class="button-label mt-1 w-full rounded-lg border border-neutral-300 bg-white px-2.5 py-2 text-sm"
                    value="<%= button.label || '' %>"
                    placeholder="TELEGRAM"
                  />
                </label>

                <label class="text-xs font-medium text-neutral-600">
                  Ссылка
                  <input
                    type="text"
                    class="button-url mt-1 w-full rounded-lg border border-neutral-300 bg-white px-2.5 py-2 text-sm"
                    value="<%= button.url || '' %>"
                    placeholder="https://..."
                  />
                </label>

                <label class="mt-6 flex items-center gap-2 text-xs font-semibold text-neutral-700">
                  <input type="checkbox" class="button-active" <%= button.isActive ? 'checked' : '' %> />
                  Показывать
                </label>

                <button
                  type="button"
                  data-remove-row
                  class="mt-6 rounded-lg border border-red-200 px-3 py-2 text-xs font-semibold text-red-700 transition hover:bg-red-50"
                >
                  Удалить
                </button>

                <p class="button-row-error hidden text-xs text-red-600 md:col-span-5"></p>
              </div>
              <% }); %>
            </div>
          </section>

          <section class="rounded-2xl border border-neutral-200 bg-white p-4">
            <h2 class="text-lg font-bold">Контакты</h2>
            <div class="mt-4 grid gap-3 md:grid-cols-2">
              <label class="text-sm font-medium text-neutral-700">
                Адрес
                <input id="field-address" type="text" value="<%= pageInitialValues.address %>" class="mt-1 w-full rounded-xl border border-neutral-300 px-3 py-2" />
              </label>

              <label class="text-sm font-medium text-neutral-700">
                Индекс
                <input id="field-postcode" type="text" value="<%= pageInitialValues.postcode %>" class="mt-1 w-full rounded-xl border border-neutral-300 px-3 py-2" />
              </label>

              <label class="text-sm font-medium text-neutral-700">
                Email
                <input id="field-email" type="email" value="<%= pageInitialValues.email %>" class="mt-1 w-full rounded-xl border border-neutral-300 px-3 py-2" />
                <p class="mt-1 hidden text-xs text-red-600" id="field-email-error"></p>
              </label>

              <label class="text-sm font-medium text-neutral-700">
                Дополнительный телефон
                <input
                  id="field-extra-phone"
                  type="text"
                  value="<%= pageInitialValues.extraPhone %>"
                  class="mt-1 w-full rounded-xl border border-neutral-300 px-3 py-2"
                  inputmode="numeric"
                  autocomplete="tel"
                  placeholder="+998 (90) 123-45-67"
                />
              </label>
            </div>
          </section>

          <% if (pageMode === 'edit' && pageStats) { %>
          <section class="rounded-2xl border border-neutral-200 bg-white p-4">
            <h2 class="text-lg font-bold">Статистика</h2>
            <div class="mt-3 grid gap-2 text-sm text-neutral-700 md:grid-cols-3">
              <p><span class="font-semibold">Всего просмотров:</span> <%= pageStats.totalViews %></p>
              <p><span class="font-semibold">Уникальные просмотры:</span> <%= pageStats.totalUniqueViews %></p>
              <p>
                <span class="font-semibold">Последний просмотр:</span>
                <%= pageStats.lastViewAt ? new Date(pageStats.lastViewAt).toLocaleString('ru-RU') : 'Нет данных' %>
              </p>
              <p>
                <span class="font-semibold">Mobile/Desktop:</span>
                <%= pageStats.deviceSplit.mobile %>/<%= pageStats.deviceSplit.desktop %>
              </p>
            </div>

            <div class="mt-3 h-[220px]">
              <canvas id="card-stats-chart"></canvas>
            </div>
          </section>
          <% } %>

          <p id="card-form-error" class="hidden text-sm text-red-600"></p>

          <div class="flex flex-col gap-2 sm:flex-row sm:flex-wrap">
            <button
              type="submit"
              id="save-card-btn"
              class="w-full rounded-xl bg-neutral-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-neutral-700 disabled:opacity-60 sm:w-auto"
            >
              Сохранить
            </button>

            <button
              type="button"
              id="preview-card-btn"
              class="w-full rounded-xl border border-neutral-300 px-4 py-2 text-sm font-semibold text-neutral-800 transition hover:bg-neutral-100 sm:w-auto"
            >
              Предпросмотр
            </button>

            <a
              href="/admin/dashboard"
              class="w-full rounded-xl border border-neutral-300 px-4 py-2 text-center text-sm font-semibold text-neutral-800 transition hover:bg-neutral-100 sm:w-auto"
            >
              Отмена
            </a>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script nonce="<%= cspNonce %>" id="card-editor-initial" type="application/json"><%- JSON.stringify(pageInitialValues) %></script>
  <script nonce="<%= cspNonce %>" id="card-editor-stats" type="application/json"><%- JSON.stringify(pageStats) %></script>
  <script nonce="<%= cspNonce %>" src="/vendor/sortablejs/Sortable.min.js"></script>
  <script nonce="<%= cspNonce %>" src="/vendor/cropperjs/cropper.min.js"></script>
  <script nonce="<%= cspNonce %>" src="/vendor/chartjs/chart.umd.min.js"></script>
  <script nonce="<%= cspNonce %>" src="/js/admin-card-editor.js"></script>
</body>
</html>
