<% const pageTitle=typeof title==="string" && title.trim() ? title.trim() : "Отсчёт до релиза" ; const message=typeof
    reportMessage==="string" && reportMessage.trim() ? reportMessage.trim()
    : "Мы готовим релиз и финализируем проверку. Скоро вернемся с обновлением." ; const
    lines=message.split(/\r?\n/).map((line)=> line.trim()).filter(Boolean);
    const opensAtIso = typeof opensAt === "string" ? opensAt.trim() : "";
    const opensAtDate = opensAtIso ? new Date(opensAtIso) : null;
    const hasOpenDate = Boolean(opensAtDate) && Number.isFinite(opensAtDate.getTime());
    %>
    <!doctype html>
    <html lang="ru">

    <head>
        <%- include('../partials/head', { title: pageTitle, styles: ['/css/public-card.css'], noindex: true }) %>
    </head>

    <body class="antialiased bg-neutral-50">
        <main class="mx-auto flex min-h-screen w-full max-w-5xl items-center px-4 py-8">
            <section class="w-full rounded-3xl border border-neutral-200 bg-white p-6 shadow-sm md:p-10">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-neutral-500">UNQX</p>
                <h1 class="mt-3 text-3xl font-black tracking-tight text-neutral-900 md:text-4xl">
                    <%= pageTitle %>
                </h1>

                <div class="mt-8 grid gap-3 sm:grid-cols-4">
                    <div class="rounded-2xl border border-neutral-200 bg-neutral-50 px-4 py-3 text-center">
                        <p id="count-days" class="text-3xl font-black text-neutral-900">00</p>
                        <p class="mt-1 text-xs uppercase tracking-[0.12em] text-neutral-500">Дни</p>
                    </div>
                    <div class="rounded-2xl border border-neutral-200 bg-neutral-50 px-4 py-3 text-center">
                        <p id="count-hours" class="text-3xl font-black text-neutral-900">00</p>
                        <p class="mt-1 text-xs uppercase tracking-[0.12em] text-neutral-500">Часы</p>
                    </div>
                    <div class="rounded-2xl border border-neutral-200 bg-neutral-50 px-4 py-3 text-center">
                        <p id="count-mins" class="text-3xl font-black text-neutral-900">00</p>
                        <p class="mt-1 text-xs uppercase tracking-[0.12em] text-neutral-500">Минуты</p>
                    </div>
                    <div class="rounded-2xl border border-neutral-200 bg-neutral-50 px-4 py-3 text-center">
                        <p id="count-secs" class="text-3xl font-black text-neutral-900">00</p>
                        <p class="mt-1 text-xs uppercase tracking-[0.12em] text-neutral-500">Секунды</p>
                    </div>
                </div>

                <% if (hasOpenDate) { %>
                    <p class="mt-4 text-sm text-neutral-600">Открытие сайта: <strong>
                            <%= opensAtDate.toLocaleString('ru-RU') %>
                        </strong></p>
                    <% } else { %>
                        <p class="mt-4 text-sm text-neutral-600">Дата открытия пока не задана в настройках.</p>
                        <% } %>

                            <% if (lines.length> 1) { %>
                                <div class="mt-6 space-y-2 text-sm leading-relaxed text-neutral-700">
                                    <% lines.forEach((line)=> { %>
                                        <p>
                                            <%= line %>
                                        </p>
                                        <% }) %>
                                </div>
                                <% } else { %>
                                    <p class="mt-6 text-sm leading-relaxed text-neutral-700">
                                        <%= message %>
                                    </p>
                                    <% } %>

                                        <p id="countdown-status" class="mt-6 text-xs text-neutral-500">Все страницы
                                            сайта временно закрыты до релиза.</p>
            </section>
        </main>

        <script nonce="<%= cspNonce %>">
            (function () {
                var targetIso = "<%= opensAtIso %>";
                var hasOpenDate = <%= hasOpenDate ? "true" : "false" %>;
                var statusNode = document.getElementById("countdown-status");
                var daysNode = document.getElementById("count-days");
                var hoursNode = document.getElementById("count-hours");
                var minsNode = document.getElementById("count-mins");
                var secsNode = document.getElementById("count-secs");
                if (!daysNode || !hoursNode || !minsNode || !secsNode) return;

                function pad(n) {
                    return String(Math.max(0, n)).padStart(2, "0");
                }

                function setValues(days, hours, mins, secs) {
                    daysNode.textContent = pad(days);
                    hoursNode.textContent = pad(hours);
                    minsNode.textContent = pad(mins);
                    secsNode.textContent = pad(secs);
                }

                if (!hasOpenDate) {
                    setValues(0, 0, 0, 0);
                    if (statusNode) {
                        statusNode.textContent = "Укажи дату и время открытия в админке, чтобы запустить обратный отсчет.";
                    }
                    return;
                }

                var targetTs = new Date(targetIso).getTime();
                if (!Number.isFinite(targetTs)) {
                    setValues(0, 0, 0, 0);
                    if (statusNode) {
                        statusNode.textContent = "Некорректная дата открытия. Проверь настройки.";
                    }
                    return;
                }

                function tick() {
                    var diffMs = targetTs - Date.now();
                    if (diffMs <= 0) {
                        setValues(0, 0, 0, 0);
                        if (statusNode) {
                            statusNode.textContent = "Релиз наступил. Открываем сайт...";
                        }
                        window.location.reload();
                        return;
                    }

                    var totalSec = Math.floor(diffMs / 1000);
                    var days = Math.floor(totalSec / 86400);
                    var hours = Math.floor((totalSec % 86400) / 3600);
                    var mins = Math.floor((totalSec % 3600) / 60);
                    var secs = totalSec % 60;
                    setValues(days, hours, mins, secs);
                }

                tick();
                setInterval(tick, 1000);
            })();
        </script>
    </body>

    </html>