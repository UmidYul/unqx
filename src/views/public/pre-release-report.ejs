<% const pageTitle=typeof title==="string" && title.trim() ? title.trim() : "Отчет до релиза" ; const message=typeof
    reportMessage==="string" && reportMessage.trim() ? reportMessage.trim()
    : "Мы готовим релиз и финализируем проверку. Скоро вернемся с обновлением." ; const
    lines=message.split(/\r?\n/).map((line)=> line.trim()).filter(Boolean);
    %>
    <!doctype html>
    <html lang="ru">

    <head>
        <%- include('../partials/head', { title: pageTitle, styles: ['/css/public-card.css'], noindex: true }) %>
    </head>

    <body class="antialiased">
        <main class="flex min-h-screen items-center justify-center px-4 py-10">
            <article class="w-full max-w-2xl rounded-2xl border border-neutral-200 bg-white p-8 shadow-sm">
                <div
                    class="inline-flex items-center rounded-full border border-neutral-300 bg-neutral-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-neutral-600">
                    Перед релизом
                </div>
                <h1 class="mt-4 text-3xl font-bold tracking-tight text-neutral-900">
                    <%= pageTitle %>
                </h1>

                <% if (lines.length> 1) { %>
                    <div class="mt-4 space-y-2 text-sm leading-relaxed text-neutral-700">
                        <% lines.forEach((line)=> { %>
                            <p>
                                <%= line %>
                            </p>
                            <% }) %>
                    </div>
                    <% } else { %>
                        <p class="mt-4 text-sm leading-relaxed text-neutral-700">
                            <%= message %>
                        </p>
                        <% } %>

                            <p class="mt-6 text-xs text-neutral-500">Страница временно отображается вместо публичных
                                разделов сайта.</p>
            </article>
        </main>
    </body>

    </html>