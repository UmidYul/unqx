<!doctype html>
<html lang="ru">
<head>
  <%- include('../partials/head', { title: title || "Новый пароль | UNQ+", description: typeof description === 'string' ? description : undefined, noindex: true }) %>
</head>
<body class="antialiased bg-neutral-50">
  <main class="mx-auto flex min-h-screen w-full max-w-md items-center px-4 py-10">
    <form id="reset-form" class="w-full rounded-2xl border border-neutral-200 bg-white p-5">
      <h1 class="text-2xl font-bold text-neutral-900">Установить новый пароль</h1>
      <label class="mt-4 block text-sm font-medium text-neutral-700">Email
        <input id="email" type="email" value="<%= typeof email === 'string' ? email : '' %>" class="mt-1 w-full rounded-xl border border-neutral-200 px-3 py-2 text-sm" required />
      </label>
      <label class="mt-3 block text-sm font-medium text-neutral-700">Код из письма
        <input id="code" inputmode="numeric" maxlength="24" class="mt-1 w-full rounded-xl border border-neutral-200 px-3 py-2 text-center font-mono text-xl tracking-[0.4em]" required />
      </label>
      <label class="mt-3 block text-sm font-medium text-neutral-700">Новый пароль
        <input id="newPassword" type="password" class="mt-1 w-full rounded-xl border border-neutral-200 px-3 py-2 text-sm" required />
      </label>
      <label class="mt-3 block text-sm font-medium text-neutral-700">Подтвердить пароль
        <input id="confirmPassword" type="password" class="mt-1 w-full rounded-xl border border-neutral-200 px-3 py-2 text-sm" required />
      </label>
      <p id="reset-error" class="mt-3 hidden text-sm text-red-700"></p>
      <button type="submit" class="interactive-btn mt-4 min-h-11 w-full rounded-xl bg-neutral-900 px-4 py-2 text-sm font-semibold text-white">Установить новый пароль</button>
      <p class="mt-3 text-sm text-neutral-600"><a href="/forgot-password" class="underline">Запросить новый код</a></p>
    </form>
  </main>
  <script nonce="<%= cspNonce %>">
    const csrf = document.querySelector('meta[name="csrf-token"]')?.getAttribute("content") || "";
    const errorNode = document.getElementById("reset-error");
    const codeInput = document.getElementById("code");
    codeInput?.addEventListener("input", () => {
      codeInput.value = String(codeInput.value || "").replace(/\D/g, "").slice(0, 6);
    });
    codeInput?.addEventListener("paste", (event) => {
      event.preventDefault();
      const raw = event.clipboardData?.getData("text") || "";
      codeInput.value = raw.replace(/\D/g, "").slice(0, 6);
    });
    document.getElementById("reset-form").addEventListener("submit", async (event) => {
      event.preventDefault();
      errorNode.classList.add("hidden");
      const normalizedCode = String(codeInput?.value || "").replace(/\D/g, "").slice(0, 6);
      codeInput.value = normalizedCode;
      const response = await fetch("/api/auth/reset-password", {
        method: "POST",
        headers: { "Content-Type": "application/json", "x-csrf-token": csrf },
        body: JSON.stringify({
          email: document.getElementById("email").value,
          code: normalizedCode,
          newPassword: document.getElementById("newPassword").value,
          confirmPassword: document.getElementById("confirmPassword").value,
        }),
      });
      const payload = await response.json().catch(() => ({}));
      if (!response.ok) {
        errorNode.textContent = payload?.error || "Ошибка сброса";
        errorNode.classList.remove("hidden");
        return;
      }
      window.location.href = "/login";
    });
  </script>
</body>
</html>
