<%
  const name = typeof ownerName === "string" && ownerName ? ownerName : "UNQ+ User";
  const username = typeof ownerUsername === "string" ? ownerUsername : "";
  const avatar = typeof ownerAvatar === "string" ? ownerAvatar : "";
  const message = typeof pauseMessage === "string" && pauseMessage ? pauseMessage : "Скоро вернусь · Пишите в Telegram";
  const social = primarySocial && typeof primarySocial === "object" ? primarySocial : null;
%>
<!doctype html>
<html lang="ru">
<head>
  <%- include('../partials/head', { title: title || 'Пауза', styles: ['/css/public-card.css'], noindex: typeof noindex === 'boolean' ? noindex : true }) %>
</head>
<body class="antialiased">
  <main class="flex min-h-screen items-center justify-center px-4">
    <div class="w-full max-w-lg rounded-2xl border border-neutral-200 bg-white p-8 text-center shadow-sm animate-card-enter">
      <a href="/" class="interactive-btn mb-3 inline-flex min-h-11 items-center gap-1.5 rounded-lg border border-neutral-200 bg-white px-3 py-1.5 text-xs font-semibold text-neutral-700">
        <svg class="icon-stroke h-4 w-4" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M15 18 9 12l6-6"></path>
        </svg>
        На главную
      </a>
      <p class="text-xs uppercase tracking-[0.18em] text-neutral-500">#<%= slug %></p>
      <div class="mt-4 flex flex-col items-center">
        <img src="<%= avatar || '/brand/logo.PNG' %>" alt="<%= name %>" class="h-20 w-20 rounded-full border border-neutral-200 object-cover" />
        <h1 class="mt-3 text-xl font-bold text-neutral-900"><%= name %></h1>
        <% if (username) { %><p class="text-sm text-neutral-500"><%= username %></p><% } %>
      </div>
      <p class="mt-4 text-sm text-neutral-700"><%= message %></p>
      <% if (social && social.url) { %>
      <a href="<%= social.url %>" target="_blank" rel="noopener noreferrer" class="interactive-btn mt-5 inline-flex min-h-11 items-center gap-1.5 rounded-xl border border-neutral-300 px-4 py-2 text-sm font-semibold text-neutral-700">
        <%= social.label || 'Открыть ссылку' %>
      </a>
      <% } %>
    </div>
  </main>
</body>
</html>
