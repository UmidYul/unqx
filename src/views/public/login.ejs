<!doctype html>
<html lang="ru">

<head>
  <%- include('../partials/head', { title: title || "Войти | UNQX" , description: typeof description==='string' ?
    description : undefined, noindex: true }) %>
</head>

<body class="antialiased bg-neutral-50">
  <main class="mx-auto flex min-h-screen w-full max-w-md items-center px-4 py-10">
    <form id="login-form" class="w-full rounded-2xl border border-neutral-200 bg-white p-5">
      <a href="/"
        class="inline-flex items-center gap-2 rounded-lg border border-neutral-200 bg-neutral-50 px-2.5 py-1.5 text-sm font-semibold text-neutral-700">
        <img src="/brand/logo.PNG" alt="UNQX" class="h-6 w-6 rounded-md border border-neutral-200 object-cover" />
        <span>UNQX</span>
      </a>
      <h1 class="mt-4 text-2xl font-bold text-neutral-900">Войти</h1>
      <p class="mt-1 text-sm text-neutral-500">Вход в UNQX по email и паролю</p>

      <label class="mt-4 block text-sm font-medium text-neutral-700">Email
        <input id="email" type="email" autocomplete="email" placeholder="you@example.com"
          class="mt-1 w-full rounded-xl border border-neutral-200 px-3 py-2 text-sm" required />
      </label>

      <label class="mt-3 block text-sm font-medium text-neutral-700">Пароль
        <input id="password" type="password" autocomplete="current-password"
          class="mt-1 w-full rounded-xl border border-neutral-200 px-3 py-2 text-sm" required />
      </label>

      <label class="mt-3 inline-flex items-center gap-2 text-sm text-neutral-700">
        <input id="remember-me" type="checkbox" />
        Запомнить меня
      </label>

      <p id="login-error" class="mt-3 hidden text-sm text-red-700"></p>
      <button type="submit"
        class="interactive-btn mt-4 min-h-11 w-full rounded-xl bg-neutral-900 px-4 py-2 text-sm font-semibold text-white">Войти</button>

      <div class="mt-4 flex items-center justify-between text-sm">
        <a href="/forgot-password" class="text-neutral-700 underline">Забыл пароль?</a>
        <a href="/register" class="text-neutral-700 underline">Нет аккаунта? Зарегистрироваться</a>
      </div>
    </form>
  </main>

  <script nonce="<%= cspNonce %>">
    const form = document.getElementById("login-form");
    const errorNode = document.getElementById("login-error");
    const loginErrorByCode = {
      ACCOUNT_DISABLED: "Аккаунт отключен. Обратитесь в поддержку.",
      LOCKED: "Слишком много попыток. Попробуйте позже.",
      UNVERIFIED: "Сначала подтвердите email.",
    };

    function resolveLoginError(payload) {
      if (payload && typeof payload.code === "string" && loginErrorByCode[payload.code]) {
        return loginErrorByCode[payload.code];
      }
      return payload?.error || "Неверный email или пароль";
    }

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      errorNode.classList.add("hidden");
      const email = document.getElementById("email").value;
      const password = document.getElementById("password").value;
      const rememberMe = document.getElementById("remember-me").checked;
      const csrf = document.querySelector('meta[name="csrf-token"]')?.getAttribute("content") || "";
      const response = await fetch("/api/auth/login", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "x-csrf-token": csrf,
        },
        body: JSON.stringify({ email, password, rememberMe }),
      });
      const payload = await response.json().catch(() => ({}));
      if (!response.ok) {
        errorNode.textContent = resolveLoginError(payload);
        errorNode.classList.remove("hidden");
        return;
      }
      window.location.href = "<%= typeof next === 'string' && next ? next : '/profile' %>";
    });
  </script>
</body>

</html>