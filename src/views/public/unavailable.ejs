<%
  const pageSlug = typeof slug === "string" && slug ? slug : "UNKNOWN";
%>
<!doctype html>
<html lang="ru">
<head>
  <%- include('../partials/head', { title: 'Визитка недоступна', styles: ['/css/public-card.css'], noindex: true }) %>
</head>
<body class="antialiased">
  <main class="flex min-h-screen items-center justify-center px-6">
    <div class="rounded-3xl border border-neutral-400 bg-white/70 px-8 py-10 text-center shadow-sm animate-card-enter">
      <a href="/" class="interactive-btn mb-3 inline-flex min-h-11 items-center gap-1.5 rounded-lg border border-neutral-200 bg-white px-3 py-1.5 text-xs font-semibold text-neutral-700">
        <svg class="icon-stroke h-4 w-4" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M15 18 9 12l6-6"></path>
        </svg>
        На главную
      </a>
      <p class="text-xs uppercase tracking-[0.24em] text-neutral-500">#<%= pageSlug %></p>
      <h1 class="mt-3 text-2xl font-bold text-neutral-900">Визитка недоступна</h1>
      <p class="mt-2 text-sm text-neutral-600">Эта визитка временно отключена администратором.</p>
    </div>
  </main>
</body>
</html>
