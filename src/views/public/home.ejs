<%
  const pageTitle = typeof title === "string" && title ? title : "UNQ+ Digital Business Cards";
  const highlights = [
    {
      title: "Быстрый запуск",
      description: "Публикация цифровой визитки за несколько минут без разработки и сложной настройки.",
    },
    {
      title: "Управление из админ-панели",
      description: "Редактирование контента, ссылок, аватаров и активности карточек в одном месте.",
    },
    {
      title: "Аналитика просмотров",
      description: "Отслеживание вовлеченности и эффективности карточек по дням и периодам.",
    },
  ];
  const flow = [
    "Создаете карточку с данными профиля, тегами и кнопками связи.",
    "Публикуете короткую ссылку и делитесь ей в соцсетях, мессенджерах и QR.",
    "Получаете просмотры и обновляете карточку в реальном времени.",
  ];
%>
<!doctype html>
<html lang="ru">
<head>
  <%- include('../partials/head', { title: pageTitle, styles: ['/css/public-card.css'] }) %>
</head>
<body class="antialiased">
  <main class="relative isolate overflow-hidden">
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div class="absolute left-1/2 top-[-180px] h-[420px] w-[800px] -translate-x-1/2 rounded-full bg-white/40 blur-3xl"></div>
      <div class="absolute bottom-0 left-1/2 h-[320px] w-[960px] -translate-x-1/2 rounded-full bg-black/5 blur-3xl"></div>
    </div>

    <section class="mx-auto flex min-h-[72vh] w-full max-w-6xl flex-col justify-center px-6 pb-14 pt-20 sm:px-8 lg:pt-24">
      <p class="animate-in text-sm font-semibold uppercase tracking-[0.24em] text-neutral-600">UNQ+ Platform</p>
      <h1 class="animate-in mt-4 max-w-4xl text-4xl font-black leading-tight tracking-tight sm:text-5xl lg:text-6xl" style="animation-delay: 80ms;">
        Цифровые визитки для команд, экспертов и брендов, которые работают 24/7
      </h1>
      <p class="animate-in mt-6 max-w-2xl text-base leading-relaxed text-neutral-700 sm:text-lg" style="animation-delay: 160ms;">
        UNQ+ объединяет персональный профиль, контакты, ссылки и аналитику в одном аккуратном публичном пространстве. Без бумаги,
        без потерь и без устаревших данных.
      </p>
      <div class="animate-in mt-8 w-full max-w-xl" style="animation-delay: 200ms;" data-page="public-home-search">
        <label for="home-search-input" class="mb-2 block text-xs font-semibold uppercase tracking-[0.2em] text-neutral-600">
          Поиск визитки по ID
        </label>
        <div class="relative">
          <input
            id="home-search-input"
            type="text"
            class="w-full rounded-2xl border border-black/15 bg-white/80 px-4 py-3 text-sm font-medium tracking-[0.08em] text-neutral-900 outline-none backdrop-blur transition focus:border-black/40 focus:bg-white"
            placeholder="Например: AAA001"
            autocomplete="off"
            spellcheck="false"
            maxlength="6"
          />
          <div
            id="home-search-results"
            class="absolute left-0 top-[calc(100%+8px)] z-20 hidden w-full overflow-hidden rounded-2xl border border-black/10 bg-white/95 shadow-lg backdrop-blur"
          ></div>
        </div>
        <p id="home-search-hint" class="mt-2 text-xs text-neutral-600">Введите ID и нажмите Enter для перехода.</p>
      </div>
      <div class="animate-in mt-10 grid max-w-3xl grid-cols-1 gap-4 text-sm text-neutral-700 sm:grid-cols-3" style="animation-delay: 240ms;">
        <div class="rounded-2xl border border-black/10 bg-white/55 px-4 py-4 backdrop-blur">
          <p class="text-2xl font-black text-neutral-900">1 мин</p>
          <p class="mt-1">на публикацию карточки</p>
        </div>
        <div class="rounded-2xl border border-black/10 bg-white/55 px-4 py-4 backdrop-blur">
          <p class="text-2xl font-black text-neutral-900">100%</p>
          <p class="mt-1">контроль актуальности данных</p>
        </div>
        <div class="rounded-2xl border border-black/10 bg-white/55 px-4 py-4 backdrop-blur">
          <p class="text-2xl font-black text-neutral-900">24/7</p>
          <p class="mt-1">доступ к профилю по одной ссылке</p>
        </div>
      </div>
    </section>

    <section class="mx-auto w-full max-w-6xl px-6 pb-6 sm:px-8">
      <div class="rounded-3xl border border-black/10 bg-white/65 p-6 backdrop-blur sm:p-8">
        <h2 class="text-2xl font-black tracking-tight sm:text-3xl">Почему выбирают UNQ+</h2>
        <div class="mt-6 grid gap-4 md:grid-cols-3">
          <% highlights.forEach((item) => { %>
          <article class="rounded-2xl bg-neutral-900 px-5 py-6 text-white">
            <h3 class="text-lg font-bold"><%= item.title %></h3>
            <p class="mt-3 text-sm leading-relaxed text-neutral-300"><%= item.description %></p>
          </article>
          <% }); %>
        </div>
      </div>
    </section>

    <section class="mx-auto w-full max-w-6xl px-6 py-8 sm:px-8 sm:py-10">
      <div class="grid gap-6 rounded-3xl border border-black/10 bg-white/55 p-6 backdrop-blur md:grid-cols-[1.1fr_0.9fr] md:gap-8 sm:p-8">
        <div>
          <h2 class="text-2xl font-black tracking-tight sm:text-3xl">Как это работает</h2>
          <ol class="mt-5 space-y-3 text-sm leading-relaxed text-neutral-700 sm:text-base">
            <% flow.forEach((step, index) => { %>
            <li class="flex gap-3">
              <span class="mt-0.5 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-neutral-900 text-xs font-bold text-white">
                <%= index + 1 %>
              </span>
              <span><%= step %></span>
            </li>
            <% }); %>
          </ol>
        </div>

        <div class="rounded-2xl border border-black/10 bg-black px-6 py-7 text-white">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-neutral-400">Подходит для</p>
          <ul class="mt-4 space-y-2 text-sm text-neutral-200 sm:text-base">
            <li>Агентств и sales-команд</li>
            <li>Экспертов и консультантов</li>
            <li>Руководителей и предпринимателей</li>
            <li>Событий и офлайн-нетворкинга</li>
          </ul>
        </div>
      </div>
    </section>

    <footer class="mx-auto w-full max-w-6xl px-6 pb-12 pt-2 text-sm text-neutral-600 sm:px-8">
      <div class="rounded-2xl border border-black/10 bg-white/45 px-5 py-4 backdrop-blur">
        UNQ+ • Digital Business Cards Platform • <%= new Date().getFullYear() %>
      </div>
    </footer>
  </main>
  <script src="/js/public-home-search.js"></script>
</body>
</html>
