<!doctype html>
<html lang="ru">

<head>
  <%- include("../partials/head", { title, description, image, styles: ["/css/public-card.css"], jsonLd }) %>
</head>

<body class="bg-neutral-50 antialiased">
  <main class="mx-auto w-full max-w-6xl px-4 py-8">
    <div class="mb-6 flex flex-wrap items-center justify-between gap-3">
      <a href="/guides"
        class="interactive-btn inline-flex min-h-11 items-center gap-1.5 rounded-lg border border-neutral-300 px-3 py-1.5 text-sm font-semibold text-neutral-700">
        <svg class="icon-stroke h-4 w-4" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M15 18 9 12l6-6"></path>
        </svg>
        Все гайды
      </a>
      <div class="inline-flex items-center gap-2 text-xs text-neutral-500">
        <img src="/brand/logo.PNG" alt="UNQX" class="h-5 w-5 rounded border border-neutral-200 object-cover" />
        Обновлено: <strong class="text-neutral-700">
          <%= updatedAt %>
        </strong> · <%= readingMinutes %> мин чтения
      </div>
    </div>

    <article class="rounded-2xl border border-neutral-200 bg-white p-6 md:p-8">
      <h1 class="text-3xl font-black tracking-tight text-neutral-900 md:text-4xl">
        <%= heading %>
      </h1>
      <p class="mt-3 max-w-4xl text-sm leading-6 text-neutral-600 md:text-base">
        <%= lead %>
      </p>

      <% sections.forEach((section)=> { %>
        <section class="mt-8 border-t border-neutral-200 pt-6">
          <h2 class="text-2xl font-bold tracking-tight text-neutral-900">
            <%= section.title %>
          </h2>
          <% if (Array.isArray(section.paragraphs)) { %>
            <% section.paragraphs.forEach((p)=> { %>
              <p class="mt-3 text-sm leading-7 text-neutral-700 md:text-base">
                <%= p %>
              </p>
              <% }) %>
                <% } %>
                  <% if (Array.isArray(section.bullets) && section.bullets.length) { %>
                    <ul class="mt-4 space-y-2">
                      <% section.bullets.forEach((point)=> { %>
                        <li class="flex items-start gap-2.5 text-sm leading-6 text-neutral-700 md:text-base">
                          <svg class="icon-stroke mt-1 h-4 w-4 shrink-0 text-neutral-900" viewBox="0 0 24 24"
                            aria-hidden="true">
                            <path d="m20 6-11 11-5-5"></path>
                          </svg>
                          <span>
                            <%= point %>
                          </span>
                        </li>
                        <% }) %>
                    </ul>
                    <% } %>
        </section>
        <% }) %>

          <% if (Array.isArray(faqs) && faqs.length) { %>
            <section class="mt-10 border-t border-neutral-200 pt-6">
              <h2 class="text-2xl font-bold tracking-tight text-neutral-900">FAQ</h2>
              <div class="mt-4 space-y-3">
                <% faqs.forEach((item)=> { %>
                  <details class="rounded-xl border border-neutral-200 bg-neutral-50 p-4">
                    <summary class="cursor-pointer list-none text-sm font-semibold text-neutral-900">
                      <%= item.question %>
                    </summary>
                    <p class="mt-2 text-sm leading-6 text-neutral-700">
                      <%= item.answer %>
                    </p>
                  </details>
                  <% }) %>
              </div>
            </section>
            <% } %>
    </article>

    <section class="mt-6 rounded-2xl border border-neutral-200 bg-white p-5">
      <h2 class="text-lg font-bold text-neutral-900">Читайте также</h2>
      <div class="mt-3 grid gap-2 md:grid-cols-2">
        <a href="/guides/digital-business-card"
          class="rounded-lg border border-neutral-200 px-3 py-2 text-sm text-neutral-700 hover:border-neutral-300">Цифровая
          визитка: полный гайд</a>
        <a href="/guides/nfc-business-card"
          class="rounded-lg border border-neutral-200 px-3 py-2 text-sm text-neutral-700 hover:border-neutral-300">NFC
          визитка: внедрение</a>
        <a href="/guides/unq-slug"
          class="rounded-lg border border-neutral-200 px-3 py-2 text-sm text-neutral-700 hover:border-neutral-300">UNQ
          slug: стратегия выбора</a>
        <a href="/guides/cases"
          class="rounded-lg border border-neutral-200 px-3 py-2 text-sm text-neutral-700 hover:border-neutral-300">Кейсы
          UNQX</a>
        <a href="/faq"
          class="rounded-lg border border-neutral-200 px-3 py-2 text-sm text-neutral-700 hover:border-neutral-300">FAQ
          по платформе</a>
      </div>
      <div class="mt-4 flex flex-wrap gap-2 text-xs text-neutral-500">
        <span class="text-neutral-400">Правовые страницы:</span>
        <a href="/terms"
          class="rounded-md border border-neutral-200 px-2 py-1 transition-colors hover:text-neutral-700">Условия
          использования</a>
        <a href="/policy"
          class="rounded-md border border-neutral-200 px-2 py-1 transition-colors hover:text-neutral-700">Политика
          конфиденциальности и возврата</a>
      </div>
    </section>
  </main>
</body>

</html>