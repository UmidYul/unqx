<%
  const pageTitle = typeof title === "string" && title ? title : "Временная ошибка сервера";
%>
<!doctype html>
<html lang="ru">
<head>
  <%- include('../partials/head', { title: pageTitle, styles: ['/css/public-card.css'], noindex: true }) %>
</head>
<body class="antialiased">
  <main class="flex min-h-screen items-center justify-center px-4">
    <div class="w-full max-w-lg rounded-2xl border border-neutral-200 bg-white p-8 text-center shadow-sm animate-card-enter">
      <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full border border-neutral-200 bg-neutral-50">
        <svg class="icon-stroke h-6 w-6 text-neutral-700" viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="12" cy="12" r="9"></circle>
          <path d="M12 8h0M12 11v5"></path>
        </svg>
      </div>
      <h1 class="mt-4 text-2xl font-bold text-neutral-900">500 · Временная ошибка сервера</h1>
      <p class="mt-2 text-sm text-neutral-600">Попробуй обновить страницу через пару секунд или вернись на главную.</p>
      <div class="mt-5 flex flex-wrap items-center justify-center gap-2">
        <a href="" class="interactive-btn inline-flex min-h-11 items-center rounded-xl border border-neutral-300 px-4 py-2 text-sm font-semibold text-neutral-700">Повторить</a>
        <a href="/" class="interactive-btn inline-flex min-h-11 items-center rounded-xl bg-neutral-900 px-4 py-2 text-sm font-semibold text-white">На главную</a>
      </div>
    </div>
  </main>
</body>
</html>
