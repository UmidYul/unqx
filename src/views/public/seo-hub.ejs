<!doctype html>
<html lang="ru">
<head>
  <%- include("../partials/head", { title, description, image, styles: ["/css/public-card.css"], jsonLd }) %>
</head>
<body class="bg-neutral-50 antialiased">
  <main class="mx-auto w-full max-w-6xl px-4 py-8">
    <div class="mb-6 flex items-center justify-between gap-3">
      <a href="/" class="interactive-btn inline-flex min-h-11 items-center gap-1.5 rounded-lg border border-neutral-300 px-3 py-1.5 text-sm font-semibold text-neutral-700">
        <svg class="icon-stroke h-4 w-4" viewBox="0 0 24 24" aria-hidden="true"><path d="M15 18 9 12l6-6"></path></svg>
        На главную
      </a>
      <a href="/faq" class="interactive-btn inline-flex min-h-11 items-center gap-2 rounded-lg border border-neutral-300 px-3 py-1.5 text-sm font-semibold text-neutral-700">
        <img src="/brand/logo.PNG" alt="UNQX" class="h-5 w-5 rounded border border-neutral-200 object-cover" />
        <span>FAQ</span>
      </a>
    </div>

    <header class="rounded-2xl border border-neutral-200 bg-white p-6 md:p-8">
      <p class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.16em] text-neutral-500">
        <img src="/brand/logo.PNG" alt="UNQX" class="h-5 w-5 rounded border border-neutral-200 object-cover" />
        <span>SEO HUB</span>
      </p>
      <h1 class="mt-3 text-3xl font-black tracking-tight text-neutral-900 md:text-4xl"><%= heading %></h1>
      <p class="mt-3 max-w-3xl text-sm leading-6 text-neutral-600 md:text-base"><%= lead %></p>
    </header>

    <section class="mt-6 grid gap-4 md:grid-cols-2">
      <% cards.forEach((card) => { %>
        <article class="rounded-2xl border border-neutral-200 bg-white p-5">
          <h2 class="text-xl font-bold text-neutral-900"><a class="hover:underline" href="<%= card.href %>"><%= card.title %></a></h2>
          <p class="mt-2 text-sm leading-6 text-neutral-600"><%= card.description %></p>
          <a href="<%= card.href %>" class="interactive-btn mt-4 inline-flex min-h-11 items-center gap-2 rounded-lg border border-neutral-300 px-3 py-1.5 text-sm font-semibold text-neutral-800">
            Читать
            <svg class="icon-stroke h-4 w-4" viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"></path></svg>
          </a>
        </article>
      <% }) %>
    </section>
  </main>
</body>
</html>
