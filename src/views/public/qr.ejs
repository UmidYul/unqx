<!doctype html>
<html lang="ru">
<head>
  <%- include('../partials/head', { title: title || 'QR UNQ+', description: 'QR-визитка UNQ+', styles: ['/css/public-card.css'], noindex: Boolean(noindex) }) %>
</head>
<body class="bg-white antialiased">
  <main class="mx-auto flex min-h-screen w-full max-w-xl flex-col items-center justify-center px-4 py-8 text-center">
    <% if (unavailable) { %>
      <h1 class="text-xl font-bold text-neutral-900">Эта визитка временно недоступна</h1>
    <% } else { %>
      <img src="/brand/unq-mark.svg" alt="UNQ+" class="mb-4 h-8 w-8" />
      <div id="qr-box" class="rounded-2xl border border-neutral-200 p-4"></div>
      <p class="mt-3 font-mono text-sm text-neutral-700"><%= url %></p>
      <p class="mt-2 text-sm text-neutral-500"><%= ownerName || 'UNQ+ User' %><% if (ownerRole) { %> · <%= ownerRole %><% } %></p>
      <% if (Number(score || 0) > 0) { %>
        <p class="mt-2 inline-flex rounded-full border border-neutral-300 px-2.5 py-1 text-xs font-semibold text-neutral-700">UNQ Score: <%= Number(score) %></p>
      <% } %>
    <% } %>
  </main>
  <% if (!unavailable) { %>
    <script nonce="<%= cspNonce %>" src="/vendor/qrcode/qrcode.min.js"></script>
    <script nonce="<%= cspNonce %>">
      (function () {
        var box = document.getElementById("qr-box");
        if (!box || typeof QRCode === "undefined") return;
        QRCode.toCanvas("<%= url %>", { width: 340, margin: 2 }, function (error, canvas) {
          if (error || !canvas) return;
          box.appendChild(canvas);
        });
      })();
    </script>
  <% } %>
</body>
</html>
