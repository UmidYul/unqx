<%
  const pageTitle = typeof title === "string" && title ? title : "UNQ+";
  const pageDescription =
    typeof description === "string" && description ? description : "UNQ+ platform for digital business cards";
  const pageImage = typeof image === "string" && image ? image : null;
  const pageCardRaw = typeof card === "object" && card ? card : {};
  const pageBaseUrl = typeof baseUrl === "string" && baseUrl ? baseUrl : "";
  const pageCanonicalUrl =
    typeof canonicalUrl === "string" && canonicalUrl ? canonicalUrl : `${pageBaseUrl}/${pageCardRaw.slug || "UNKNOWN"}`;
  const pageCard = {
    slug: pageCardRaw.slug || "UNKNOWN",
    avatarUrl: pageCardRaw.avatarUrl || null,
    name: pageCardRaw.name || "Unknown",
    verified: Boolean(pageCardRaw.verified),
    phone: pageCardRaw.phone || "",
    tags: Array.isArray(pageCardRaw.tags) ? pageCardRaw.tags : [],
    buttons: Array.isArray(pageCardRaw.buttons)
      ? pageCardRaw.buttons
          .map((button) => ({
            label: typeof button.label === "string" ? button.label.trim() : "",
            url: typeof button.url === "string" ? button.url.trim() : "",
            isActive: Boolean(button.isActive),
          }))
          .filter((button) => button.isActive && button.label.length > 0 && /^https?:\/\//i.test(button.url))
      : [],
    hashtag: pageCardRaw.hashtag || "",
    address: pageCardRaw.address || "",
    postcode: pageCardRaw.postcode || "",
    email: pageCardRaw.email || "",
    extraPhone: pageCardRaw.extraPhone || "",
  };
  const pageJsonLd = {
    "@context": "https://schema.org",
    "@type": "ProfilePage",
    url: pageCanonicalUrl,
    name: pageTitle,
    mainEntity: {
      "@type": "Person",
      name: pageCard.name,
      telephone: pageCard.phone,
      email: pageCard.email || undefined,
      image: pageImage || undefined,
      sameAs: pageCard.buttons.map((button) => button.url),
    },
  };
  const initials = (pageCard.name || "")
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((part) => (part[0] ? part[0].toUpperCase() : ""))
    .join("");
  const mediaPattern = /(music|youtube|yt|spotify|soundcloud|apple\s*music|track|song)/i;
  const mediaButton = pageCard.buttons.find((button) => mediaPattern.test(button.label) || mediaPattern.test(button.url)) || null;
  const socialButtons = pageCard.buttons.filter((button) => !mediaButton || button.url !== mediaButton.url);
  const primaryButtons = socialButtons.slice(0, 5);
  const extraButtons = socialButtons.slice(5);
  const stickyCta = socialButtons.length > 5 ? socialButtons[0] : null;
  const fallbackHashtags = [`#${pageCard.slug}`, "#UnqPower2026"];
  const hashtags = [pageCard.hashtag, ...fallbackHashtags]
    .map((item) => (typeof item === "string" ? item.trim() : ""))
    .filter(Boolean)
    .map((item) => (item.startsWith("#") ? item : `#${item}`))
    .filter((item, idx, arr) => arr.indexOf(item) === idx);
  const poweredByNick = pageCard.slug.toLowerCase();
  const hasArabic = /[\u0600-\u06FF]/.test(pageCard.name || "");
  const documentDir = hasArabic ? "rtl" : "ltr";
%>
<!doctype html>
<html lang="ru" dir="<%= documentDir %>">
<head>
  <%- include('../partials/head', { title: pageTitle, description: pageDescription, image: pageImage, styles: ['/css/public-card.css'], ogType: 'profile', jsonLd: pageJsonLd }) %>
</head>
<body class="public-card-body antialiased">
  <main class="public-card-shell" data-slug="<%= pageCard.slug %>" data-dir="<%= documentDir %>">
    <header class="public-card-header">
      <div class="public-avatar" data-avatar-wrapper>
        <% if (pageCard.avatarUrl) { %>
        <img src="<%= pageCard.avatarUrl %>" alt="<%= pageCard.name %>" class="public-avatar-image" data-avatar-image />
        <% } %>
        <div class="public-avatar-fallback <%= pageCard.avatarUrl ? 'is-hidden' : '' %>" data-avatar-fallback aria-hidden="<%= pageCard.avatarUrl ? 'true' : 'false' %>">
          <%= initials || "UNQ" %>
        </div>
      </div>

      <h1 class="public-card-name">
        <%= pageCard.name %>
        <% if (pageCard.verified) { %>
        <span class="public-card-verified" aria-label="verified">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2.4l2.1 1.7 2.7-.3 1.1 2.5 2.5 1.1-.3 2.7L21.6 12l-1.7 2.1.3 2.7-2.5 1.1-1.1 2.5-2.7-.3L12 21.6l-2.1-1.7-2.7.3-1.1-2.5-2.5-1.1.3-2.7L2.4 12l1.7-2.1-.3-2.7 2.5-1.1 1.1-2.5 2.7.3L12 2.4zm-1.1 13.2l5.1-5.1-1.2-1.2-3.9 3.9-1.8-1.8-1.2 1.2 3 3z"></path>
          </svg>
        </span>
        <% } %>
      </h1>

      <p class="public-card-phone">
        <span class="public-card-phone-value"><%= pageCard.phone %></span>
        <button
          type="button"
          data-copy-phone="<%= pageCard.phone %>"
          class="public-copy-phone"
          aria-label="Скопировать телефон"
          title="Скопировать телефон"
        >
          <span data-copy-default>
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M16 1H6a2 2 0 0 0-2 2v12h2V3h10V1zm3 4H10a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h9a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2zm0 16H10V7h9v14z"></path>
            </svg>
          </span>
          <span class="is-hidden" data-copy-success>copied</span>
        </button>
      </p>
    </header>

    <section class="public-links" aria-label="Social links">
      <% if (primaryButtons.length === 0 && !mediaButton && extraButtons.length === 0) { %>
      <p class="public-links-placeholder">Coming soon</p>
      <% } %>

      <% primaryButtons.forEach((button) => { %>
      <a href="<%= button.url %>" target="_blank" rel="noopener noreferrer" class="public-link-button">
        <span class="public-link-label"><%= button.label %></span>
        <span class="public-link-icon" aria-hidden="true">↗</span>
      </a>
      <% }); %>

      <% if (extraButtons.length > 0) { %>
      <details class="public-links-more">
        <summary>Show more</summary>
        <div class="public-links-more-list">
          <% extraButtons.forEach((button) => { %>
          <a href="<%= button.url %>" target="_blank" rel="noopener noreferrer" class="public-link-button public-link-button-compact">
            <span class="public-link-label"><%= button.label %></span>
            <span class="public-link-icon" aria-hidden="true">↗</span>
          </a>
          <% }); %>
        </div>
      </details>
      <% } %>
    </section>

    <% if (mediaButton) { %>
    <section class="public-media-link" aria-label="Media link">
      <a href="<%= mediaButton.url %>" target="_blank" rel="noopener noreferrer" class="public-link-button public-link-button-media">
        <span class="public-link-label">* <%= mediaButton.label %></span>
        <span class="public-link-icon" aria-hidden="true">▶</span>
      </a>
    </section>
    <% } %>

    <section class="public-powered">
      <p>powered by <span><%= poweredByNick %></span></p>
      <div class="public-brand-mark">
        <img src="/brand/unq-mark.svg" alt="UNQ mark" data-brand-image />
      </div>
    </section>

    <section class="public-hashtags" aria-label="Hashtags">
      <% hashtags.forEach((item) => { %>
      <p><%= item %></p>
      <% }); %>
    </section>

    <section class="public-contact" aria-label="Contact info">
      <h2>Contact</h2>
      <div class="public-contact-grid">
        <% if (pageCard.email) { %><p><span>Email</span><a href="mailto:<%= pageCard.email %>"><%= pageCard.email %></a></p><% } %>
        <% if (pageCard.extraPhone || pageCard.phone) { %><p><span>Phone</span><span><%= pageCard.extraPhone || pageCard.phone %></span></p><% } %>
        <% if (pageCard.postcode) { %><p><span>Postcode</span><span><%= pageCard.postcode %></span></p><% } %>
        <% if (pageCard.address) { %><p><span>Address</span><span><%= pageCard.address %></span></p><% } %>
        <% if (!pageCard.email && !pageCard.extraPhone && !pageCard.phone && !pageCard.postcode && !pageCard.address) { %>
        <p class="public-empty">Contact details will appear here.</p>
        <% } %>
      </div>
    </section>

    <section class="public-about" aria-label="About info">
      <h2>About info</h2>
      <% if (pageCard.tags.length > 0) { %>
      <ul>
        <% pageCard.tags.forEach((tag) => { %>
        <li>
          <% if (tag.url) { %>
          <a href="<%= tag.url %>" target="_blank" rel="noopener noreferrer"><%= tag.label %></a>
          <% } else { %>
          <span><%= tag.label %></span>
          <% } %>
        </li>
        <% }); %>
      </ul>
      <% } else { %>
      <p class="public-empty">Profile details are being updated.</p>
      <% } %>
    </section>

    <section class="public-extra-photo" aria-label="Additional photo">
      <% if (pageCard.avatarUrl) { %>
      <img src="<%= pageCard.avatarUrl %>" alt="Additional profile view" data-extra-photo />
      <% } else { %>
      <div class="public-extra-photo-placeholder" aria-hidden="true"></div>
      <% } %>
    </section>

    <footer class="public-card-footer">
      <a href="https://tilda.cc/" target="_blank" rel="noopener noreferrer">Made on Tilda</a>
    </footer>
  </main>

  <% if (stickyCta) { %>
  <a href="<%= stickyCta.url %>" target="_blank" rel="noopener noreferrer" class="public-sticky-cta">
    <span><%= stickyCta.label %></span>
    <span aria-hidden="true">↗</span>
  </a>
  <% } %>

  <script nonce="<%= cspNonce %>" src="/js/public-card.js"></script>
</body>
</html>
