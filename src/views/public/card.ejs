<%
  const pageTitle = typeof title === "string" && title ? title : "UNQ+";
  const pageDescription =
    typeof description === "string" && description ? description : "UNQ+ platform for digital business cards";
  const pageImage = typeof image === "string" && image ? image : null;
  const pageCardRaw = typeof card === "object" && card ? card : {};
  const pageBaseUrl = typeof baseUrl === "string" && baseUrl ? baseUrl : "";
  const pageCanonicalUrl =
    typeof canonicalUrl === "string" && canonicalUrl ? canonicalUrl : `${pageBaseUrl}/${pageCardRaw.slug || "unknown"}`;

  const pageCard = {
    slug: (typeof pageCardRaw.slug === "string" ? pageCardRaw.slug : "unknown").toUpperCase(),
    avatarUrl: pageCardRaw.avatarUrl || null,
    name: pageCardRaw.name || "Unknown",
    verified: Boolean(pageCardRaw.verified),
    tariff: pageCardRaw.tariff === "premium" ? "premium" : "basic",
    theme:
      typeof pageCardRaw.theme === "string" &&
      ["default_dark", "light_minimal", "gradient", "neon", "corporate"].includes(pageCardRaw.theme)
        ? pageCardRaw.theme
        : "default_dark",
    phone: pageCardRaw.phone || "",
    tags: Array.isArray(pageCardRaw.tags)
      ? pageCardRaw.tags
          .map((tag) => ({
            label: typeof tag.label === "string" ? tag.label.trim() : "",
          }))
          .filter((tag) => tag.label.length > 0)
      : [],
    buttons: Array.isArray(pageCardRaw.buttons)
      ? pageCardRaw.buttons
          .map((button) => ({
            label: typeof button.label === "string" ? button.label.trim() : "",
            url: typeof button.url === "string" ? button.url.trim() : "",
            isActive: Boolean(button.isActive),
          }))
          .filter((button) => button.isActive && button.label.length > 0 && /^https?:\/\//i.test(button.url))
      : [],
    hashtag: pageCardRaw.hashtag || "",
    address: pageCardRaw.address || "",
    postcode: pageCardRaw.postcode || "",
    email: pageCardRaw.email || "",
    extraPhone: pageCardRaw.extraPhone || "",
    viewsCount: Number(pageCardRaw.viewsCount) || 0,
    showBranding: typeof pageCardRaw.showBranding === "boolean" ? pageCardRaw.showBranding : true,
  };

  const pageJsonLd = {
    "@context": "https://schema.org",
    "@type": "ProfilePage",
    url: pageCanonicalUrl,
    name: pageTitle,
    mainEntity: {
      "@type": "Person",
      name: pageCard.name,
      telephone: pageCard.phone || undefined,
      email: pageCard.email || undefined,
      image: pageImage || undefined,
      sameAs: pageCard.buttons.map((button) => button.url),
    },
  };

  const initials = (pageCard.name || "")
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((part) => (part[0] ? part[0].toUpperCase() : ""))
    .join("");

  const actionButtons = pageCard.buttons.slice(0, 4).map((button) => {
    const signature = `${button.label} ${button.url}`.toLowerCase();
    let icon = "arrow";
    if (/(telegram|t\.me|message|chat)/.test(signature)) {
      icon = "message";
    } else if (/(instagram|insta)/.test(signature)) {
      icon = "instagram";
    } else if (/(click|pay|payment|card|kaspi|merchant)/.test(signature)) {
      icon = "click";
    } else if (/(phone|call|tel)/.test(signature)) {
      icon = "phone";
    } else if (/(site|web|link|globe|www)/.test(signature)) {
      icon = "globe";
    } else if (/(steam|trade|shop|store|market)/.test(signature)) {
      icon = "arrow";
    }

    return {
      label: button.label,
      url: button.url,
      icon,
    };
  });

  function findSocialUrl(patterns) {
    const found = pageCard.buttons.find((button) => patterns.some((pattern) => pattern.test(`${button.label} ${button.url}`)));
    return found ? found.url : "#";
  }

  const socialLinks = [
    { label: "Instagram", url: findSocialUrl([/instagram/i, /insta/i]), icon: "instagram" },
    { label: "LinkedIn", url: findSocialUrl([/linkedin/i]), icon: "linkedin" },
    { label: "TikTok", url: findSocialUrl([/tiktok/i, /tik tok/i]), icon: "tiktok" },
    { label: "YouTube", url: findSocialUrl([/youtube/i, /youtu\.be/i]), icon: "youtube" },
  ];

  const mainHashtag = pageCard.hashtag
    ? pageCard.hashtag.startsWith("#")
      ? pageCard.hashtag
      : `#${pageCard.hashtag}`
    : "#UnqPower2026";
  const aboutAddress = pageCard.address || "Farghona, Mustaqillik 13";
  const aboutEmail = pageCard.email || "unq@uz.com";
  const aboutPhone = pageCard.extraPhone || pageCard.phone || "+998200001360";
  const aboutPostcode = pageCard.postcode || "150100";
  const documentDir = /[\u0600-\u06FF]/.test(pageCard.name || "") ? "rtl" : "ltr";
  const formattedViews = new Intl.NumberFormat("ru-RU").format(Math.max(0, pageCard.viewsCount));
  const pageCardTheme = pageCard.tariff === "premium" ? pageCard.theme : "default_dark";
%>
<!doctype html>
<html lang="ru" dir="<%= documentDir %>">
<head>
  <%- include('../partials/head', { title: pageTitle, description: pageDescription, image: pageImage, styles: ['/css/public-card.css'], ogType: 'profile', jsonLd: pageJsonLd, noindex: typeof noindex === 'boolean' ? noindex : false }) %>
</head>
<body class="antialiased" data-card-theme="<%= pageCardTheme %>">
  <main class="relative flex min-h-screen items-center justify-center overflow-hidden px-4 py-12">
    <div class="pointer-events-none absolute inset-0 bg-neutral-50"></div>

    <div
      class="pointer-events-none absolute inset-0 opacity-[0.35]"
      style="
        background-image:
          linear-gradient(rgba(0,0,0,0.03) 1px, transparent 1px),
          linear-gradient(90deg, rgba(0,0,0,0.03) 1px, transparent 1px);
        background-size: 40px 40px;
      "
    ></div>

    <div class="pointer-events-none absolute -left-32 -top-32 h-96 w-96 rounded-full bg-neutral-200/50 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-32 -right-32 h-96 w-96 rounded-full bg-neutral-300/30 blur-3xl"></div>
    <div class="pointer-events-none absolute left-1/2 top-1/2 h-[600px] w-[600px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-white/60 blur-3xl"></div>

      <div
        class="relative z-10 w-full max-w-[520px] animate-card-enter"
        data-slug="<%= pageCard.slug %>"
        data-share-url="<%= pageCanonicalUrl %>"
      >
      <div class="animate-fade-up mb-4 flex items-center justify-between px-1" style="animation-delay: 0.1s;">
        <span class="flex items-center gap-1.5 text-[11px] font-mono uppercase tracking-wider text-neutral-400">
          <svg class="icon-stroke h-3 w-3" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 9h16M9 4v16M15 4v16M4 15h16"></path>
          </svg>
          <%= pageCard.slug %>
        </span>
        <button
          type="button"
          data-share-card
          class="flex items-center gap-1.5 text-[11px] text-neutral-400 transition-colors hover:text-neutral-900"
          aria-label="Поделиться"
        >
          <svg class="icon-stroke h-3 w-3" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="18" cy="5" r="3"></circle>
            <circle cx="6" cy="12" r="3"></circle>
            <circle cx="18" cy="19" r="3"></circle>
            <path d="M8.7 10.9 15.3 6.1M8.7 13.1l6.6 4.8"></path>
          </svg>
          <span data-share-label>Share</span>
        </button>
      </div>

      <div class="public-card-shell animate-fade-up rounded-2xl border border-neutral-200 bg-white p-8 shadow-sm" style="animation-delay: 0.2s;">
        <div class="animate-fade-up text-center" style="animation-delay: 0.3s;">
          <h2 class="text-2xl font-black tracking-tight text-neutral-900">UNQ+</h2>
          <p class="mt-0.5 text-[10px] uppercase tracking-widest text-neutral-400">powered by scxr</p>
        </div>

        <div class="animate-fade-up mt-8 flex flex-col items-center" style="animation-delay: 0.4s;">
          <div class="relative">
            <% if (pageCard.avatarUrl) { %>
            <img
              src="<%= pageCard.avatarUrl %>"
              alt="<%= pageCard.name %>"
              class="h-20 w-20 rounded-full object-cover"
              data-avatar-image
            />
            <% } %>
            <div
              class="flex h-20 w-20 items-center justify-center rounded-full bg-neutral-100 text-lg font-bold text-neutral-700 <%= pageCard.avatarUrl ? 'hidden' : '' %>"
              data-avatar-fallback
              aria-hidden="<%= pageCard.avatarUrl ? 'true' : 'false' %>"
            >
              <%= initials || "UN" %>
            </div>
          </div>

          <div class="mt-4 text-center">
            <div class="flex items-center justify-center gap-1.5">
              <h1 class="text-lg font-semibold text-neutral-900"><%= pageCard.name %></h1>
              <% if (pageCard.verified) { %>
              <svg class="h-4 w-4 text-neutral-900" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2.4l2.1 1.7 2.7-.3 1.1 2.5 2.5 1.1-.3 2.7L21.6 12l-1.7 2.1.3 2.7-2.5 1.1-1.1 2.5-2.7-.3L12 21.6l-2.1-1.7-2.7.3-1.1-2.5-2.5-1.1.3-2.7L2.4 12l1.7-2.1-.3-2.7 2.5-1.1 1.1-2.5 2.7.3L12 2.4zm-1.1 13.2l5.1-5.1-1.2-1.2-3.9 3.9-1.8-1.8-1.2 1.2 3 3z"></path>
              </svg>
              <% } %>
            </div>
            <a
              href="tel:<%= pageCard.phone.replace(/\s+/g, '') %>"
              class="mt-1 flex items-center justify-center gap-1 text-sm text-neutral-500 transition-colors hover:text-neutral-900"
            >
              <svg class="icon-stroke h-3 w-3" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.4 19.4 0 0 1-6-6 19.8 19.8 0 0 1-3.1-8.7A2 2 0 0 1 4 2h3a2 2 0 0 1 2 1.7c.1 1 .3 2 .7 3a2 2 0 0 1-.4 2.1L8 10.2a16 16 0 0 0 5.8 5.8l1.4-1.3a2 2 0 0 1 2.1-.4c1 .4 2 .6 3 .7A2 2 0 0 1 22 16.9z"></path>
              </svg>
              <%= pageCard.phone %>
            </a>
          </div>
        </div>

        <% if (pageCard.tags.length > 0) { %>
        <div class="animate-fade-up mt-5 flex flex-wrap justify-center gap-1.5" style="animation-delay: 0.5s;">
          <% pageCard.tags.forEach((tag) => { %>
          <span class="rounded-full bg-neutral-100 px-3 py-1 text-[11px] font-medium text-neutral-600"><%= tag.label %></span>
          <% }); %>
        </div>
        <% } %>

        <div class="my-6 h-px bg-neutral-100"></div>

        <div class="animate-fade-up flex flex-col gap-2.5" style="animation-delay: 0.6s;">
          <% if (actionButtons.length === 0) { %>
          <p class="py-2 text-center text-xs uppercase tracking-wider text-neutral-400">Coming soon</p>
          <% } %>
          <% actionButtons.forEach((button) => { %>
          <a
            href="<%= button.url %>"
            target="_blank"
            rel="noopener noreferrer"
            class="public-card-button btn-shimmer flex items-center justify-center gap-2.5 rounded-xl bg-neutral-900 px-5 py-3.5 text-sm font-medium uppercase tracking-wide text-white transition-colors hover:bg-neutral-800"
          >
            <% if (button.icon === "message") { %>
            <svg class="icon-stroke h-4 w-4" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M21 11.5a8.5 8.5 0 0 1-8.5 8.5 8.7 8.7 0 0 1-3.7-.8L3 21l1.8-5.8a8.7 8.7 0 0 1-.8-3.7A8.5 8.5 0 0 1 12.5 3 8.5 8.5 0 0 1 21 11.5z"></path>
            </svg>
            <% } else if (button.icon === "instagram") { %>
            <svg class="icon-stroke h-4 w-4" viewBox="0 0 24 24" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5"></rect>
              <circle cx="12" cy="12" r="4.5"></circle>
              <circle cx="17.5" cy="6.5" r="1"></circle>
            </svg>
            <% } else if (button.icon === "click") { %>
            <svg class="icon-stroke h-4 w-4" viewBox="0 0 24 24" aria-hidden="true">
              <path d="m9 11 3-8 3 8 7 1-6 5 2 7-6-4-6 4 2-7-6-5 7-1Z"></path>
            </svg>
            <% } else if (button.icon === "phone") { %>
            <svg class="icon-stroke h-4 w-4" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.4 19.4 0 0 1-6-6 19.8 19.8 0 0 1-3.1-8.7A2 2 0 0 1 4 2h3a2 2 0 0 1 2 1.7c.1 1 .3 2 .7 3a2 2 0 0 1-.4 2.1L8 10.2a16 16 0 0 0 5.8 5.8l1.4-1.3a2 2 0 0 1 2.1-.4c1 .4 2 .6 3 .7A2 2 0 0 1 22 16.9z"></path>
            </svg>
            <% } else if (button.icon === "globe") { %>
            <svg class="icon-stroke h-4 w-4" viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="12" cy="12" r="9"></circle>
              <path d="M3 12h18M12 3a15 15 0 0 1 0 18M12 3a15 15 0 0 0 0 18"></path>
            </svg>
            <% } else { %>
            <svg class="icon-stroke h-4 w-4" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M7 17 17 7M7 7h10v10"></path>
            </svg>
            <% } %>
            <%= button.label %>
          </a>
          <% }); %>
        </div>

        <div class="my-6 h-px bg-neutral-100"></div>

        <div class="animate-fade-up" style="animation-delay: 0.7s;">
          <p class="text-center text-xs font-medium tracking-wide text-neutral-400"><%= mainHashtag %></p>
        </div>

        <div class="animate-fade-up mt-6 rounded-xl bg-neutral-50 p-5" style="animation-delay: 0.8s;">
          <h3 class="text-[11px] font-semibold uppercase tracking-widest text-neutral-400">About info</h3>
          <div class="mt-3 flex flex-col gap-2">
            <div class="flex items-start gap-2 text-sm text-neutral-600">
              <svg class="icon-stroke mt-0.5 h-3.5 w-3.5 shrink-0 text-neutral-400" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 21s7-6 7-11a7 7 0 1 0-14 0c0 5 7 11 7 11Z"></path>
                <circle cx="12" cy="10" r="2.5"></circle>
              </svg>
              <span><%= aboutAddress %></span>
            </div>
            <div class="flex items-center gap-2 text-sm text-neutral-600">
              <svg class="icon-stroke h-3.5 w-3.5 shrink-0 text-neutral-400" viewBox="0 0 24 24" aria-hidden="true">
                <rect x="3" y="5" width="18" height="14" rx="2"></rect>
                <path d="m3 7 9 6 9-6"></path>
              </svg>
              <span><%= aboutEmail %></span>
            </div>
            <div class="flex items-center gap-2 text-sm text-neutral-600">
              <svg class="icon-stroke h-3.5 w-3.5 shrink-0 text-neutral-400" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.4 19.4 0 0 1-6-6 19.8 19.8 0 0 1-3.1-8.7A2 2 0 0 1 4 2h3a2 2 0 0 1 2 1.7c.1 1 .3 2 .7 3a2 2 0 0 1-.4 2.1L8 10.2a16 16 0 0 0 5.8 5.8l1.4-1.3a2 2 0 0 1 2.1-.4c1 .4 2 .6 3 .7A2 2 0 0 1 22 16.9z"></path>
              </svg>
              <span><%= aboutPhone %></span>
            </div>
            <div class="flex items-center gap-2 text-sm text-neutral-600">
              <svg class="icon-stroke h-3.5 w-3.5 shrink-0 text-neutral-400" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M4 9h16M9 4v16M15 4v16M4 15h16"></path>
              </svg>
              <span>Postcode: <%= aboutPostcode %></span>
            </div>
          </div>
        </div>

        <div class="animate-fade-up mt-6 flex items-center justify-center gap-2" style="animation-delay: 0.9s;">
          <% socialLinks.forEach((item) => { %>
          <a
            href="<%= item.url %>"
            <% if (item.url !== '#') { %>target="_blank" rel="noopener noreferrer"<% } %>
            aria-label="<%= item.label %>"
            class="flex h-10 w-10 items-center justify-center rounded-full border border-neutral-200 text-neutral-500 transition-colors hover:border-neutral-900 hover:text-neutral-900"
          >
            <% if (item.icon === "instagram") { %>
            <svg class="icon-stroke h-4 w-4" viewBox="0 0 24 24" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5"></rect>
              <circle cx="12" cy="12" r="4.5"></circle>
              <circle cx="17.5" cy="6.5" r="1"></circle>
            </svg>
            <% } else if (item.icon === "linkedin") { %>
            <svg class="icon-stroke h-4 w-4" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 1 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"></path>
              <rect x="2" y="9" width="4" height="12"></rect>
              <circle cx="4" cy="4" r="2"></circle>
            </svg>
            <% } else if (item.icon === "tiktok") { %>
            <svg class="icon-stroke h-4 w-4" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path>
            </svg>
            <% } else { %>
            <svg class="icon-stroke h-4 w-4" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M22 12a10 10 0 1 1-11.5-9.9"></path>
              <path d="m10 15 5.2-3L10 9v6Z"></path>
            </svg>
            <% } %>
          </a>
          <% }); %>
        </div>

        <div class="animate-fade-up mt-5 text-center" style="animation-delay: 1s;">
          <a
            href="/api/cards/<%= pageCard.slug %>/vcf"
            class="inline-flex items-center gap-1.5 text-[11px] text-neutral-400 transition-colors hover:text-neutral-900"
          >
            <svg class="icon-stroke h-3 w-3" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 3v12M7 10l5 5 5-5M5 21h14"></path>
            </svg>
            Save contact (.vcf)
          </a>
        </div>
      </div>

      <div class="animate-fade-up mt-4 flex items-center justify-between px-1" style="animation-delay: 1.1s;">
        <div class="flex items-center gap-1.5 text-[11px] text-neutral-400">
          <svg class="icon-stroke h-3 w-3" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M1.5 12s4-7 10.5-7 10.5 7 10.5 7-4 7-10.5 7S1.5 12 1.5 12Z"></path>
            <circle cx="12" cy="12" r="3"></circle>
          </svg>
          <%= formattedViews %> views
        </div>
        <% if (pageCard.showBranding) { %>
        <a href="/" class="text-[10px] text-neutral-400 hover:text-neutral-700">Создать свою →</a>
        <% } else { %>
        <div class="flex items-center gap-1 text-[10px] text-neutral-400">
          <span class="inline-block h-1 w-1 rounded-full bg-neutral-400"></span>
          UNQ+
        </div>
        <% } %>
      </div>
    </div>
  </main>

  <script nonce="<%= cspNonce %>" src="/js/public-card.js"></script>
</body>
</html>
