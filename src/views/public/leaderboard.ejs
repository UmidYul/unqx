<!doctype html>
<html lang="ru">

<head>
  <% const pageBaseUrl=typeof baseUrl==="string" ? baseUrl : "" ; const leaderboardJsonLd={ "@context"
    : "https://schema.org" , "@type" : "ItemList" , name: "Лидерборд UNQ" ,
    itemListOrder: "https://schema.org/ItemListOrderDescending" , itemListElement: (Array.isArray(items) ? items :
    []).slice(0, 10).map((item, index)=> ({
    "@type": "ListItem",
    position: index + 1,
    url: `${pageBaseUrl}/${item.slug}`,
    name: item.ownerName,
    })),
    };
    %>
    <%- include('../partials/head', { title: title || 'Топ визиток недели · UNQX' , description: description
      || 'Топ визиток UNQX' , image: typeof image==='string' ? image : undefined, styles: ['/css/public-card.css'],
      jsonLd: leaderboardJsonLd }) %>
</head>

<body class="antialiased bg-neutral-50" data-page="leaderboard" data-period="<%= period %>">
  <main class="mx-auto w-full max-w-6xl px-4 py-8">
    <div class="mb-6 flex items-center justify-between gap-3">
      <a href="/"
        class="interactive-btn inline-flex min-h-11 items-center gap-1.5 rounded-lg border border-neutral-300 px-3 py-1.5 text-sm font-semibold text-neutral-600 hover:text-neutral-900">
        <svg class="icon-stroke h-4 w-4" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M15 18 9 12l6-6"></path>
        </svg>
        На главную
      </a>
      <div class="inline-flex rounded-xl border border-neutral-200 bg-white p-1 text-sm" role="tablist"
        aria-label="Период рейтинга">
        <a href="/leaderboard?period=week"
          class="interactive-btn inline-flex min-h-11 items-center rounded-lg px-3 py-1.5 <%= period === 'week' ? 'bg-neutral-900 text-white' : 'text-neutral-600' %>"
          role="tab" aria-selected="<%= period === 'week' ? 'true' : 'false' %>">Неделя</a>
        <a href="/leaderboard?period=month"
          class="interactive-btn inline-flex min-h-11 items-center rounded-lg px-3 py-1.5 <%= period === 'month' ? 'bg-neutral-900 text-white' : 'text-neutral-600' %>"
          role="tab" aria-selected="<%= period === 'month' ? 'true' : 'false' %>">Месяц</a>
        <a href="/leaderboard?period=all"
          class="interactive-btn inline-flex min-h-11 items-center rounded-lg px-3 py-1.5 <%= period === 'all' ? 'bg-neutral-900 text-white' : 'text-neutral-600' %>"
          role="tab" aria-selected="<%= period === 'all' ? 'true' : 'false' %>">Всё время</a>
      </div>
    </div>

    <header class="mb-6 rounded-2xl border border-neutral-200 bg-white p-6">
      <h1 class="inline-flex items-center gap-2 text-3xl font-black tracking-tight text-neutral-900">
        <img src="/brand/logo.PNG" alt="UNQX" class="h-8 w-8 rounded-md border border-neutral-200 object-cover" />
        <span>Лидерборд по просмотрам</span>
      </h1>
      <p class="mt-2 text-sm text-neutral-500">Обновляется каждый день в полночь</p>
    </header>

    <% const topThree=items.slice(0, 3); const rest=items.slice(3); const currentTelegramId=(typeof
      viewerTelegramId==="string" && viewerTelegramId) ? viewerTelegramId : (typeof userSession !=="undefined" &&
      userSession && userSession.telegramId ? userSession.telegramId : "" ); const rankBadgeByPlace={
      1: "border-neutral-900 bg-neutral-900 text-white" , 2: "border-neutral-400 bg-neutral-200 text-neutral-900" ,
      3: "border-neutral-300 bg-neutral-100 text-neutral-800" , }; const isMissingAvatar=(url)=> !url ||
      String(url).trim() === "" || String(url).includes("/brand/logo.PNG");
      %>
      <section class="grid gap-4 md:grid-cols-3">
        <% if (!topThree.length) { %>
          <article class="col-span-full rounded-2xl border border-neutral-200 bg-white p-8 text-center">
            <p class="text-sm text-neutral-600">Рейтинг пока пуст. Данные появятся после первых уникальных просмотров.
            </p>
          </article>
          <% } %>
            <% topThree.forEach((item, idx)=> { %>
              <article class="interactive-card rounded-2xl border border-neutral-200 bg-white p-5">
                <p
                  class="inline-flex items-center gap-1.5 rounded-full border px-2.5 py-1 text-xs font-bold <%= rankBadgeByPlace[item.rank] || 'border-neutral-300 bg-neutral-100 text-neutral-800' %>">
                  <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor"
                    stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="8.5" r="4.25"></circle>
                    <path d="m9.2 13.8-1.4 5.6L12 17l4.2 2.4-1.4-5.6"></path>
                  </svg>
                  <span>
                    <%= item.rank %>
                  </span>
                </p>
                <div class="mt-3 flex items-center gap-3">
                  <% if (isMissingAvatar(item.avatarUrl)) { %>
                    <span
                      class="inline-flex h-12 w-12 items-center justify-center rounded-full border border-neutral-200 bg-white text-neutral-400"
                      aria-hidden="true">
                      <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none">
                        <circle cx="12" cy="8.5" r="3.75" stroke="currentColor" stroke-width="1.5"></circle>
                        <path d="M5.5 19c.8-3 3.5-4.8 6.5-4.8s5.7 1.8 6.5 4.8" stroke="currentColor" stroke-width="1.5"
                          stroke-linecap="round"></path>
                      </svg>
                    </span>
                    <% } else { %>
                      <img src="<%= item.avatarUrl %>" alt="avatar"
                        class="h-12 w-12 rounded-full border border-neutral-200 object-cover" />
                      <% } %>
                        <div>
                          <p class="inline-flex items-center gap-1.5 font-semibold text-neutral-900">
                            <span>
                              <%= item.ownerName %>
                            </span>
                            <% if (item.isVerified) { %>
                              <svg class="h-4 w-4 shrink-0 text-neutral-500" viewBox="0 0 24 24" aria-hidden="true"
                                fill="currentColor">
                                <path
                                  d="M12 2.5l2.2 1.8 2.8-.3 1.2 2.5 2.5 1.2-.3 2.8L21.5 12l-1.8 2.2.3 2.8-2.5 1.2-1.2 2.5-2.8-.3L12 21.5l-2.2-1.8-2.8.3-1.2-2.5-2.5-1.2.3-2.8L2.5 12l1.8-2.2-.3-2.8 2.5-1.2 1.2-2.5 2.8.3L12 2.5Zm-1.1 13.1 5-5-1.1-1.1-3.9 3.9-1.8-1.8-1.1 1.1 2.9 2.9Z">
                                </path>
                              </svg>
                              <% } %>
                          </p>
                          <a href="/<%= item.slug %>" class="text-sm text-neutral-500 hover:underline">unqx.uz/<%=
                              item.slug %></a>
                        </div>
                </div>
                <div class="mt-4 flex items-center justify-between text-sm">
                  <span class="text-neutral-500">Просмотры</span>
                  <span class="text-2xl font-black">
                    <%= Number(item.views || 0).toLocaleString('ru-RU') %>
                  </span>
                </div>
                <div class="mt-2 h-1.5 w-full rounded-full bg-neutral-200">
                  <div class="h-1.5 rounded-full bg-neutral-900"
                    style="width: <%= Math.max(0, Math.min(100, (Number(item.views || 0) / Math.max(1, Number(topThree[0]?.views || 0))) * 100)) %>%">
                  </div>
                </div>
                <div class="mt-2 flex items-center justify-between text-xs text-neutral-500">
                  <span>За выбранный период</span>
                  <span>Топ <%= Number(item.topPercent || 100) %>%</span>
                </div>
                <p class="mt-1 text-xs text-neutral-500">
                  UNQ Score: <%= Number(item.score || 0).toLocaleString('ru-RU') %>
                </p>
                <% if (currentTelegramId && item.telegramId===currentTelegramId) { %>
                  <button type="button" data-share-slug="<%= item.slug %>" data-share-rank="<%= item.rank %>"
                    class="interactive-btn mt-4 min-h-11 rounded-lg border border-neutral-300 px-3 py-1.5 text-xs font-semibold text-neutral-700">Поделиться</button>
                  <% } %>
              </article>
              <% }) %>
      </section>

      <section class="mt-6 overflow-hidden rounded-2xl border border-neutral-200 bg-white">
        <table class="min-w-full text-left text-sm">
          <thead class="bg-neutral-50 text-xs uppercase tracking-wide text-neutral-500">
            <tr>
              <th class="px-3 py-2">Место</th>
              <th class="px-3 py-2">Владелец</th>
              <th class="px-3 py-2">Slug</th>
              <th class="px-3 py-2">Просмотры</th>
              <th class="px-3 py-2">Топ</th>
              <th class="px-3 py-2">UNQ Score</th>
              <th class="px-3 py-2">Тариф</th>
              <th class="px-3 py-2">Действие</th>
            </tr>
          </thead>
          <tbody>
            <% if (!rest.length) { %>
              <tr>
                <td colspan="8" class="px-3 py-8 text-center text-neutral-500">Нет данных</td>
              </tr>
              <% } %>
                <% rest.forEach((item)=> { %>
                  <tr class="border-t border-neutral-100">
                    <td class="px-3 py-2">#<%= item.rank %>
                    </td>
                    <td class="px-3 py-2">
                      <div class="flex items-center gap-2">
                        <% if (isMissingAvatar(item.avatarUrl)) { %>
                          <span
                            class="inline-flex h-7 w-7 items-center justify-center rounded-full border border-neutral-200 bg-white text-neutral-400"
                            aria-hidden="true">
                            <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none">
                              <circle cx="12" cy="8.5" r="3.75" stroke="currentColor" stroke-width="1.5"></circle>
                              <path d="M5.5 19c.8-3 3.5-4.8 6.5-4.8s5.7 1.8 6.5 4.8" stroke="currentColor"
                                stroke-width="1.5" stroke-linecap="round"></path>
                            </svg>
                          </span>
                          <% } else { %>
                            <img src="<%= item.avatarUrl %>" alt="avatar"
                              class="h-7 w-7 rounded-full border border-neutral-200 object-cover" />
                            <% } %>
                              <span class="inline-flex items-center gap-1.5">
                                <span>
                                  <%= item.ownerName %>
                                </span>
                                <% if (item.isVerified) { %>
                                  <svg class="h-4 w-4 shrink-0 text-neutral-500" viewBox="0 0 24 24" aria-hidden="true"
                                    fill="currentColor">
                                    <path
                                      d="M12 2.5l2.2 1.8 2.8-.3 1.2 2.5 2.5 1.2-.3 2.8L21.5 12l-1.8 2.2.3 2.8-2.5 1.2-1.2 2.5-2.8-.3L12 21.5l-2.2-1.8-2.8.3-1.2-2.5-2.5-1.2.3-2.8L2.5 12l1.8-2.2-.3-2.8 2.5-1.2 1.2-2.5 2.8.3L12 2.5Zm-1.1 13.1 5-5-1.1-1.1-3.9 3.9-1.8-1.8-1.1 1.1 2.9 2.9Z">
                                    </path>
                                  </svg>
                                  <% } %>
                              </span>
                      </div>
                    </td>
                    <td class="px-3 py-2"><a href="/<%= item.slug %>" class="hover:underline">
                        <%= item.slug %>
                      </a></td>
                    <td class="px-3 py-2">
                      <%= Number(item.views || 0).toLocaleString('ru-RU') %>
                    </td>
                    <td class="px-3 py-2">Топ <%= Number(item.topPercent || 100) %>%</td>
                    <td class="px-3 py-2">
                      <%= Number(item.score || 0).toLocaleString('ru-RU') %>
                    </td>
                    <td class="px-3 py-2">
                      <%= item.plan==='premium' ? 'ПРЕМИУМ' : 'БАЗОВЫЙ' %>
                    </td>
                    <td class="px-3 py-2">
                      <% if (currentTelegramId && item.telegramId===currentTelegramId) { %>
                        <button type="button" data-share-slug="<%= item.slug %>" data-share-rank="<%= item.rank %>"
                          class="interactive-btn min-h-11 rounded-lg border border-neutral-300 px-2 py-1 text-xs font-semibold text-neutral-700">Поделиться</button>
                        <% } %>
                    </td>
                  </tr>
                  <% }) %>
          </tbody>
        </table>
      </section>

      <% if (userSummary) { %>
        <section class="mt-6 rounded-2xl border border-neutral-200 bg-white p-4 text-sm text-neutral-700">
          Твои просмотры: <%= Number(userSummary.views || 0).toLocaleString('ru-RU') %> · Позиция #<%= userSummary.rank
              %> ·
              До топ-<%= userSummary.limit %> нужно ещё <%= Number(userSummary.toTopViews || 0).toLocaleString('ru-RU')
                  %> просмотров
                  <div class="mt-2 h-1.5 w-full rounded-full bg-neutral-200">
                    <div class="h-1.5 rounded-full bg-neutral-900"
                      style="width: <%= Math.max(0, Math.min(100, (Number(userSummary.views || 0) / (Number(userSummary.views || 0) + Number(userSummary.toTopViews || 0) || 1)) * 100)) %>%">
                    </div>
                  </div>
        </section>
        <% } %>
  </main>
  <div id="leaderboard-toast-region" aria-live="polite" class="sr-only"></div>

  <script nonce="<%= cspNonce %>" src="/js/leaderboard.js"></script>
</body>

</html>