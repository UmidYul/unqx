<!doctype html>
<html lang="ru">
<head>
  <%- include('../partials/head', { title: title || 'Топ визиток недели · UNQ+', description: description || 'Топ визиток UNQ+', styles: ['/css/public-card.css'] }) %>
</head>
<body class="antialiased bg-neutral-50" data-page="leaderboard" data-period="<%= period %>">
  <main class="mx-auto w-full max-w-6xl px-4 py-8">
    <div class="mb-6 flex items-center justify-between gap-3">
      <a href="/" class="text-sm font-semibold text-neutral-600 hover:text-neutral-900">← На главную</a>
      <div class="inline-flex rounded-xl border border-neutral-200 bg-white p-1 text-sm">
        <a href="/leaderboard?period=week" class="rounded-lg px-3 py-1.5 <%= period === 'week' ? 'bg-neutral-900 text-white' : 'text-neutral-600' %>">Неделя</a>
        <a href="/leaderboard?period=month" class="rounded-lg px-3 py-1.5 <%= period === 'month' ? 'bg-neutral-900 text-white' : 'text-neutral-600' %>">Месяц</a>
        <a href="/leaderboard?period=all" class="rounded-lg px-3 py-1.5 <%= period === 'all' ? 'bg-neutral-900 text-white' : 'text-neutral-600' %>">Всё время</a>
      </div>
    </div>

    <header class="mb-6 rounded-2xl border border-neutral-200 bg-white p-6">
      <h1 class="text-3xl font-black tracking-tight text-neutral-900">Топ визиток недели</h1>
      <p class="mt-2 text-sm text-neutral-500">Обновляется каждый день в полночь</p>
    </header>

    <% const topThree = items.slice(0, 3); const rest = items.slice(3); %>
    <section class="grid gap-4 md:grid-cols-3">
      <% topThree.forEach((item, idx) => { const medal = idx === 0 ? '🥇' : idx === 1 ? '🥈' : '🥉'; %>
      <article class="rounded-2xl border border-neutral-200 bg-white p-5">
        <p class="text-2xl"><%= medal %></p>
        <div class="mt-3 flex items-center gap-3">
          <img src="<%= item.avatarUrl %>" alt="avatar" class="h-12 w-12 rounded-full border border-neutral-200 object-cover" />
          <div>
            <p class="font-semibold text-neutral-900"><%= item.ownerName %></p>
            <a href="/<%= item.slug %>" class="text-sm text-neutral-500 hover:underline">unqx.uz/<%= item.slug %></a>
          </div>
        </div>
        <div class="mt-4 flex items-center justify-between text-sm">
          <span>#<%= item.rank %></span>
          <span><%= Number(item.views || 0).toLocaleString('ru-RU') %> просмотров</span>
        </div>
        <div class="mt-2 flex items-center justify-between text-xs text-neutral-500">
          <span><%= item.plan === 'premium' ? 'ПРЕМИУМ' : 'БАЗОВЫЙ' %></span>
          <span>
            <% if (item.delta === null) { %>—<% } else if (item.delta > 0) { %>↑ +<%= item.delta %><% } else if (item.delta < 0) { %>↓ <%= item.delta %><% } else { %>→ 0<% } %>
          </span>
        </div>
        <button type="button" data-share-slug="<%= item.slug %>" data-share-rank="<%= item.rank %>" class="mt-4 rounded-lg border border-neutral-300 px-3 py-1.5 text-xs font-semibold text-neutral-700">Поделиться</button>
      </article>
      <% }) %>
    </section>

    <section class="mt-6 overflow-hidden rounded-2xl border border-neutral-200 bg-white">
      <table class="min-w-full text-left text-sm">
        <thead class="bg-neutral-50 text-xs uppercase tracking-wide text-neutral-500">
          <tr>
            <th class="px-3 py-2">Место</th>
            <th class="px-3 py-2">Владелец</th>
            <th class="px-3 py-2">Slug</th>
            <th class="px-3 py-2">Просмотры</th>
            <th class="px-3 py-2">Динамика</th>
            <th class="px-3 py-2">Тариф</th>
            <th class="px-3 py-2">Действие</th>
          </tr>
        </thead>
        <tbody>
          <% if (!rest.length) { %>
          <tr><td colspan="7" class="px-3 py-8 text-center text-neutral-500">Нет данных</td></tr>
          <% } %>
          <% rest.forEach((item) => { %>
          <tr class="border-t border-neutral-100">
            <td class="px-3 py-2">#<%= item.rank %></td>
            <td class="px-3 py-2">
              <div class="flex items-center gap-2">
                <img src="<%= item.avatarUrl %>" alt="avatar" class="h-7 w-7 rounded-full border border-neutral-200 object-cover" />
                <span><%= item.ownerName %></span>
              </div>
            </td>
            <td class="px-3 py-2"><a href="/<%= item.slug %>" class="hover:underline"><%= item.slug %></a></td>
            <td class="px-3 py-2"><%= Number(item.views || 0).toLocaleString('ru-RU') %></td>
            <td class="px-3 py-2">
              <% if (item.delta === null) { %>—<% } else if (item.delta > 0) { %>↑ +<%= item.delta %><% } else if (item.delta < 0) { %>↓ <%= item.delta %><% } else { %>→ 0<% } %>
            </td>
            <td class="px-3 py-2"><%= item.plan === 'premium' ? 'ПРЕМИУМ' : 'БАЗОВЫЙ' %></td>
            <td class="px-3 py-2">
              <button type="button" data-share-slug="<%= item.slug %>" data-share-rank="<%= item.rank %>" class="rounded-lg border border-neutral-300 px-2 py-1 text-xs font-semibold text-neutral-700">Поделиться</button>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </section>

    <% if (userSummary) { %>
    <section class="mt-6 rounded-2xl border border-neutral-200 bg-white p-4 text-sm text-neutral-700">
      Твоя позиция: #<%= userSummary.rank %> · <%= Number(userSummary.views || 0).toLocaleString('ru-RU') %> просмотра · До топ-<%= userSummary.limit %> осталось <%= userSummary.toTopViews %> просмотров
    </section>
    <% } %>
  </main>

  <script nonce="<%= cspNonce %>" src="/js/leaderboard.js"></script>
</body>
</html>
