<!doctype html>
<html lang="ru">
<head>
  <%
    const pageCanonicalUrl = typeof canonicalUrl === "string" ? canonicalUrl : "";
    const dropsJsonLd = {
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      name: title || "Дропы slug · UNQ+",
      description: description || "Актуальные и прошедшие дропы slug на UNQ+",
      url: pageCanonicalUrl,
    };
  %>
  <%- include('../partials/head', { title: title || 'Дропы slug · UNQ+', description: description || 'Дропы slug UNQ+', image: typeof image === 'string' ? image : undefined, styles: ['/css/public-card.css'], jsonLd: dropsJsonLd }) %>
</head>
<body class="antialiased bg-neutral-50" data-page="drops-page" data-telegram-bot-username="<%= telegramBotUsername || '' %>">
  <% const hasDrops = Array.isArray(drops) && drops.length > 0; %>
  <main class="mx-auto w-full max-w-6xl px-4 <%= hasDrops ? 'py-8' : 'relative min-h-[100dvh] py-8' %>">
    <div class="<%= hasDrops ? 'mb-6 flex items-center justify-between gap-3' : 'pointer-events-none absolute left-0 right-0 top-8 z-10 flex items-center justify-between gap-3 px-4' %>">
      <a href="/" class="interactive-btn <%= hasDrops ? '' : 'pointer-events-auto' %> inline-flex min-h-11 items-center gap-1.5 rounded-lg border border-neutral-300 px-3 py-1.5 text-sm font-semibold text-neutral-600 hover:text-neutral-900">
        <svg class="icon-stroke h-4 w-4" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M15 18 9 12l6-6"></path>
        </svg>
        На главную
      </a>
      <a href="/leaderboard" class="interactive-btn <%= hasDrops ? '' : 'pointer-events-auto' %> inline-flex min-h-11 items-center rounded-lg border border-neutral-300 px-3 py-1.5 text-sm text-neutral-500 hover:text-neutral-900">Топ визиток</a>
    </div>

    <% if (!hasDrops) { %>
    <section class="flex min-h-[100dvh] items-center justify-center pt-20 md:pt-24">
      <article class="w-full max-w-md rounded-2xl border border-neutral-200 bg-white p-8 text-center">
        <p class="text-xs uppercase tracking-[0.18em] text-neutral-500">Дропы</p>
        <h1 class="mt-3 text-2xl font-bold text-neutral-900">Пока нет активных дропов</h1>
        <p class="mt-2 text-sm text-neutral-600">Следующие запуски появятся здесь совсем скоро.</p>
      </article>
    </section>
    <% } else { %>
    <header class="mb-6 rounded-2xl border border-neutral-200 bg-white p-6">
      <h1 class="text-3xl font-black tracking-tight text-neutral-900">Дропы slug</h1>
      <p class="mt-2 text-sm text-neutral-500">Подписывайся на уведомления и забирай slug в первые минуты старта.</p>
    </header>

    <section class="grid gap-4 md:grid-cols-2">
      <% (drops || []).forEach((drop) => {
        const pool = Array.isArray(drop.slugsPool) ? drop.slugsPool : [];
        const sold = Array.isArray(drop.soldSlugs) ? drop.soldSlugs : [];
        const remaining = Math.max(0, pool.length - sold.length);
      %>
      <article class="interactive-card rounded-2xl border border-neutral-200 bg-white p-5" data-drop-card data-drop-id="<%= drop.id %>" data-drop-at="<%= drop.dropAt.toISOString() %>">
        <div class="flex items-start justify-between gap-2">
          <div>
            <h2 class="text-lg font-bold text-neutral-900"><%= drop.title %></h2>
            <p class="mt-1 text-sm text-neutral-500"><%= drop.description || '' %></p>
          </div>
          <span class="rounded-full border border-neutral-300 px-2 py-1 text-[11px] font-semibold"><%= drop.isLive ? 'LIVE' : drop.isFinished ? 'Завершён' : 'Ожидается' %></span>
        </div>
        <p class="mt-4 text-sm text-neutral-700"><strong><%= new Date(drop.dropAt).toLocaleString('ru-RU') %></strong> · <%= drop.slugCount %> slug</p>
        <p class="mt-1 text-sm text-neutral-600" data-drop-remaining>Осталось <%= remaining %> из <%= drop.slugCount %></p>
        <p class="mt-2 inline-flex items-center gap-1.5 text-sm font-semibold text-red-700 <%= drop.isLive ? '' : 'hidden' %>" data-drop-live-label>
          <span class="status-dot is-private" aria-hidden="true"></span>
          ДРОП НАЧАЛСЯ
        </p>
        <p class="mt-2 text-sm text-neutral-500 <%= drop.isLive ? 'hidden' : '' %>" data-drop-countdown>Старт через --:--:--</p>
        <div class="mt-4 flex flex-wrap items-center gap-2">
          <button type="button" data-drop-join="<%= drop.id %>" class="interactive-btn min-h-11 rounded-lg border border-neutral-300 px-3 py-1.5 text-xs font-semibold text-neutral-700">Уведомить меня</button>
          <a href="#drop-order" class="interactive-btn inline-flex min-h-11 items-center rounded-lg border border-neutral-300 px-3 py-1.5 text-xs font-semibold text-neutral-700">Смотреть доступные slug</a>
        </div>
      </article>
      <% }) %>
    </section>

    <section id="drop-order" class="mt-8 rounded-2xl border border-neutral-200 bg-white p-6">
      <h2 class="text-lg font-bold">Форма заказа для дропа</h2>
      <p class="mt-2 text-sm text-neutral-500">Когда дроп активен, здесь можно выбрать slug только из пула дропа и отправить заявку.</p>
      <div class="mt-4" id="drops-live-pool">
        <p class="text-sm text-neutral-500">Загрузка активных дропов...</p>
      </div>
    </section>
    <% } %>
  </main>

  <div id="drops-toast-region" aria-live="polite" class="sr-only"></div>
  <%- include('../partials/order-modal') %>
  <script nonce="<%= cspNonce %>" src="/js/site-dialogs.js"></script>
  <script nonce="<%= cspNonce %>" src="/js/order-modal.js"></script>
  <script nonce="<%= cspNonce %>" src="/js/drops.js"></script>
</body>
</html>

