<%
  const pageTitle = typeof title === "string" && title ? title : "UNQX Demo";
  const pageTheme = typeof theme === "string" ? theme : "default_dark";
  const isEmbed = Boolean(embed);
%>
<!doctype html>
<html lang="ru">
<head>
  <%- include('../partials/head', { title: pageTitle, description: typeof description === 'string' ? description : undefined, image: typeof image === 'string' ? image : undefined, styles: ['/css/public-card.css'], noindex: isEmbed }) %>
</head>
<body class="antialiased" data-card-theme="<%= pageTheme %>">
  <main class="<%= isEmbed ? 'p-2' : 'min-h-screen bg-neutral-50 p-8' %>">
    <div class="<%= isEmbed ? '' : 'mx-auto max-w-3xl' %>">
      <% if (!isEmbed) { %>
      <h1 class="mb-6 text-3xl font-bold text-neutral-900">Живой пример темы: <%= pageTheme %></h1>
      <% } %>

      <article class="public-card-shell overflow-hidden rounded-2xl border border-neutral-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between">
          <span class="text-[11px] font-mono uppercase tracking-wider text-neutral-400">DEMO001</span>
          <span class="text-[11px] text-neutral-400">UNQX</span>
        </div>

        <div class="mt-5 text-center">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-neutral-100 text-sm font-semibold text-neutral-700">DK</div>
          <h2 class="mt-3 text-lg font-semibold text-neutral-900">Demo Karimov</h2>
          <p class="mt-1 text-sm text-neutral-500">+998 90 123 45 67</p>
        </div>

        <div class="mt-5 flex flex-col gap-2">
          <a href="#" class="public-card-button btn-shimmer rounded-xl bg-neutral-900 px-4 py-3 text-center text-sm font-medium text-white">TELEGRAM</a>
          <a href="#" class="public-card-button btn-shimmer rounded-xl bg-neutral-900 px-4 py-3 text-center text-sm font-medium text-white">WEBSITE</a>
        </div>
      </article>
    </div>
  </main>
</body>
</html>
