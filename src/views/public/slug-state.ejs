<%
  const pageSlug = typeof slug === "string" ? slug : "";
  const pageHeading = typeof heading === "string" ? heading : "Страница";
  const pageMessage = typeof message === "string" ? message : "";
  const pageCtaLabel = typeof ctaLabel === "string" ? ctaLabel : "";
  const pageCtaHref = typeof ctaHref === "string" ? ctaHref : "";
  const pageCtaOrderLink = Boolean(ctaOrderLink);
  const pageCtaOrderPrefill = typeof ctaOrderPrefill === "string" ? ctaOrderPrefill : "";
  const pageCtaWaitlistSlug = typeof ctaWaitlistSlug === "string" ? ctaWaitlistSlug : "";
%>
<!doctype html>
<html lang="ru">
<head>
  <%- include('../partials/head', { title: title || pageHeading, styles: ['/css/public-card.css'], noindex: typeof noindex === 'boolean' ? noindex : true }) %>
</head>
<body class="antialiased" data-telegram-bot-username="<%= telegramBotUsername || '' %>">
  <main class="flex min-h-screen items-center justify-center px-4">
    <div class="w-full max-w-lg rounded-2xl border border-neutral-200 bg-white p-8 text-center shadow-sm animate-card-enter">
      <a href="/" class="interactive-btn mb-3 inline-flex min-h-11 items-center gap-1.5 rounded-lg border border-neutral-200 bg-white px-3 py-1.5 text-xs font-semibold text-neutral-700">
        <svg class="icon-stroke h-4 w-4" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M15 18 9 12l6-6"></path>
        </svg>
        На главную
      </a>
      <p class="text-xs uppercase tracking-[0.18em] text-neutral-500">#<%= pageSlug %></p>
      <h1 class="mt-3 text-2xl font-bold text-neutral-900"><%= pageHeading %></h1>
      <p class="mt-2 text-sm text-neutral-600"><%= pageMessage %></p>
      <% if (pageCtaLabel && pageCtaHref) { %>
      <a
        href="<%= pageCtaHref %>"
        class="interactive-btn mt-5 inline-flex min-h-11 items-center gap-1.5 rounded-xl bg-neutral-900 px-4 py-2 text-sm font-semibold text-white"
        <%= pageCtaOrderLink ? 'data-order-link' : '' %>
        <%= pageCtaOrderPrefill ? `data-order-prefill="${pageCtaOrderPrefill}"` : '' %>
        <%= pageCtaWaitlistSlug ? `data-waitlist-slug="${pageCtaWaitlistSlug}"` : '' %>
      >
        <%= pageCtaLabel %>
      </a>
      <% } %>
    </div>
  </main>
  <%- include('../partials/order-modal') %>
  <script nonce="<%= cspNonce %>" src="/js/order-modal.js"></script>
</body>
</html>
