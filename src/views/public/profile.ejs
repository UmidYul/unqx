<!doctype html>
<html lang="ru">
<head>
  <%- include('../partials/head', { title: title || "Мой профиль | UNQ+", styles: ['/css/public-card.css'], noindex: true }) %>
  <link rel="stylesheet" href="/vendor/cropperjs/cropper.min.css" />
</head>
<body class="antialiased" data-page="profile-page" data-telegram-bot-username="<%= telegramBotUsername || '' %>">
  <main class="min-h-screen bg-neutral-50 px-3 py-4 sm:px-4 sm:py-6 md:px-6">
    <div class="mx-auto mb-3 w-full max-w-6xl sm:mb-4">
      <a href="/" class="interactive-btn inline-flex min-h-11 items-center gap-1.5 rounded-lg border border-neutral-200 bg-white px-3 py-1.5 text-xs font-semibold text-neutral-700">
        <svg class="icon-stroke h-4 w-4" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M15 18 9 12l6-6"></path>
        </svg>
        На главную
      </a>
    </div>
    <div class="mx-auto grid min-w-0 w-full max-w-6xl gap-4 md:gap-6 lg:grid-cols-[300px_1fr]">
      <aside class="min-w-0 rounded-2xl border border-neutral-200 bg-white p-4 sm:p-5">
        <div class="flex items-center gap-3">
          <img id="profile-sidebar-avatar" src="/brand/unq-mark.svg" alt="avatar" class="h-14 w-14 rounded-full border border-neutral-200 object-cover" />
          <div>
            <p id="profile-sidebar-name" class="text-base font-semibold text-neutral-900">Загрузка...</p>
            <p id="profile-sidebar-username" class="text-sm text-neutral-500">@—</p>
          </div>
        </div>
        <div class="mt-4 space-y-2 rounded-xl border border-neutral-200 bg-neutral-50 p-3">
          <p id="profile-sidebar-plan" class="inline-flex rounded-full border border-neutral-300 px-2.5 py-1 text-xs font-semibold">БАЗОВЫЙ</p>
          <p id="profile-sidebar-expiry" class="text-xs text-neutral-500">до —</p>
        </div>
        <nav class="mt-4 grid grid-cols-2 gap-2 sm:grid-cols-3 lg:mt-5 lg:grid-cols-1">
          <button type="button" data-tab-target="slugs" class="profile-tab-btn interactive-btn min-h-11 rounded-xl border border-neutral-200 px-3 py-2 text-center text-xs font-medium sm:text-sm lg:text-left">МОИ UNQ</button>
          <button type="button" data-tab-target="card" class="profile-tab-btn interactive-btn min-h-11 rounded-xl border border-neutral-200 px-3 py-2 text-center text-xs font-medium sm:text-sm lg:text-left">МОЯ ВИЗИТКА</button>
          <button type="button" data-tab-target="requests" class="profile-tab-btn interactive-btn min-h-11 rounded-xl border border-neutral-200 px-3 py-2 text-center text-xs font-medium sm:text-sm lg:text-left">ЗАЯВКИ</button>
          <button type="button" data-tab-target="referrals" class="profile-tab-btn interactive-btn min-h-11 rounded-xl border border-neutral-200 px-3 py-2 text-center text-xs font-medium sm:text-sm lg:text-left">РЕФЕРАЛЫ</button>
          <button type="button" data-tab-target="settings" class="profile-tab-btn interactive-btn min-h-11 rounded-xl border border-neutral-200 px-3 py-2 text-center text-xs font-medium sm:text-sm lg:text-left">НАСТРОЙКИ</button>
        </nav>
        <button id="profile-logout-btn" type="button" class="interactive-btn mt-4 min-h-11 w-full rounded-xl border border-red-200 px-3 py-2 text-sm font-semibold text-red-700 lg:mt-5">
          Выйти
        </button>
      </aside>

      <section class="min-w-0 space-y-4">
        <div id="profile-upgrade-banner" class="hidden rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
          Твой Премиум истёк. Некоторые функции недоступны.
          <a href="#" data-order-link data-order-plan="premium" class="ml-1 underline">Улучшить тариф →</a>
        </div>

        <article data-tab-panel="slugs" class="profile-tab-panel min-w-0 rounded-2xl border border-neutral-200 bg-white p-4 sm:p-5">
          <div class="flex flex-col items-start justify-between gap-2 sm:flex-row sm:items-center">
            <h2 class="text-lg font-bold">МОИ UNQ</h2>
            <button id="profile-add-slug-btn" type="button" class="interactive-btn min-h-11 w-full rounded-xl border border-neutral-300 px-3 py-2 text-sm font-semibold sm:w-auto">Добавить UNQ</button>
          </div>
          <p id="profile-add-slug-note" class="mt-2 text-xs text-neutral-500"></p>
          <div id="profile-slugs-list" class="mt-4 space-y-3"></div>
        </article>

        <article data-tab-panel="card" class="profile-tab-panel hidden min-w-0 rounded-2xl border border-neutral-200 bg-white p-4 sm:p-5">
          <h2 class="text-lg font-bold">МОЯ ВИЗИТКА</h2>
          <section id="profile-score-panel" class="mt-4 rounded-xl border border-neutral-200 bg-neutral-50 p-4">
            <div class="grid gap-4 xl:grid-cols-[280px_1fr]">
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">UNQ SCORE</p>
                <p id="profile-score-value" class="mt-2 text-5xl font-black text-neutral-900">0</p>
                <p id="profile-score-top" class="mt-1 text-sm text-neutral-500">Топ 100%</p>
                <p id="profile-score-updated" class="mt-1 text-xs text-neutral-500">Обновлено —</p>
              </div>
              <div id="profile-score-breakdown" class="space-y-2"></div>
            </div>
            <details id="profile-score-tips" class="mt-4 rounded-xl border border-neutral-200 bg-white p-3">
              <summary class="cursor-pointer text-sm font-semibold text-neutral-800">Как повысить Score</summary>
              <div id="profile-score-tips-list" class="mt-2 space-y-2 text-sm text-neutral-600"></div>
            </details>
            <div class="mt-4 rounded-xl border border-neutral-200 bg-white p-3">
              <div class="relative">
                <canvas id="profile-score-history-chart" height="120"></canvas>
                <div id="profile-score-history-lock" class="hidden absolute inset-0 rounded-xl bg-white/80 p-4 backdrop-blur-sm">
                  <p class="text-sm font-semibold text-neutral-800">История Score доступна на Премиум</p>
                  <button type="button" data-order-link data-order-plan="premium" class="interactive-btn mt-2 min-h-11 rounded-lg border border-neutral-300 px-3 py-1.5 text-xs font-semibold">Улучшить тариф</button>
                </div>
              </div>
            </div>
          </section>
          <div class="mt-4 grid items-start gap-4 xl:grid-cols-[1fr_340px]">
            <div class="space-y-4">
              <div>
                <label class="mb-1 block text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Аватар</label>
                <div class="flex flex-wrap items-center gap-3">
                  <img id="profile-card-avatar-preview" src="/brand/unq-mark.svg" alt="avatar" class="h-16 w-16 rounded-full border border-neutral-200 object-cover" />
                  <div class="flex flex-wrap gap-2">
                    <label for="profile-card-avatar-file" class="cursor-pointer rounded-lg border border-neutral-300 px-3 py-1.5 text-xs font-semibold">Загрузить</label>
                    <input id="profile-card-avatar-file" type="file" accept="image/png,image/jpeg,image/webp" class="hidden" />
                    <button id="profile-card-avatar-remove" type="button" class="interactive-btn min-h-11 rounded-lg border border-red-200 px-3 py-1.5 text-xs font-semibold text-red-700">Удалить</button>
                  </div>
                </div>
                <div id="profile-card-avatar-crop-wrap" class="mt-3 hidden rounded-xl border border-neutral-200 bg-neutral-50 p-3">
                  <img id="profile-card-avatar-crop-image" alt="crop" class="max-h-[320px] w-full object-contain" />
                  <button id="profile-card-avatar-crop-save" type="button" class="interactive-btn mt-2 min-h-11 rounded-lg bg-neutral-900 px-3 py-1.5 text-xs font-semibold text-white">Сохранить обрезку</button>
                </div>
              </div>

              <div>
                <label class="mb-1 block text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Имя <span class="text-red-600">*</span></label>
                <input id="profile-card-name" type="text" class="w-full rounded-xl border border-neutral-200 px-3 py-2 text-sm" />
                <p id="profile-card-name-error" class="mt-1 hidden text-xs text-red-700">Имя обязательно.</p>
              </div>
              <div>
                <label class="mb-1 block text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Должность / роль</label>
                <input id="profile-card-role" type="text" class="w-full rounded-xl border border-neutral-200 px-3 py-2 text-sm" />
              </div>
              <div>
                <label class="mb-1 block text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Bio</label>
                <textarea id="profile-card-bio" maxlength="120" rows="3" class="w-full rounded-xl border border-neutral-200 px-3 py-2 text-sm"></textarea>
                <p id="profile-card-bio-counter" class="mt-1 text-xs text-neutral-500">0/120</p>
              </div>
              <div class="grid gap-3 md:grid-cols-2">
                <div class="md:col-span-2">
                  <label class="mb-1 block text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Нижний хэштег</label>
                  <input id="profile-card-hashtag" type="text" placeholder="#UnqPower2026" class="w-full rounded-xl border border-neutral-200 px-3 py-2 text-sm" />
                </div>
              </div>
              <div>
                <label class="mb-1 block text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Теги</label>
                <div class="flex flex-col gap-2 sm:flex-row">
                  <input id="profile-card-tag-input" type="text" placeholder="#Дизайнер" class="w-full rounded-xl border border-neutral-200 px-3 py-2 text-sm" />
                  <button id="profile-card-tag-add" type="button" class="interactive-btn min-h-11 rounded-xl border border-neutral-300 px-3 py-2 text-sm sm:w-auto">Добавить</button>
                </div>
                <div id="profile-card-tags-list" class="mt-2 flex flex-wrap gap-2"></div>
              </div>

              <div>
                <div class="mb-2 flex items-center justify-between">
                  <label class="block text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Кнопки</label>
                  <button id="profile-card-button-add" type="button" class="interactive-btn min-h-11 rounded-lg border border-neutral-300 px-2.5 py-1 text-xs font-semibold">Добавить кнопку</button>
                </div>
                <div id="profile-card-buttons-list" class="space-y-2"></div>
              </div>

              <div class="grid gap-3 md:grid-cols-2">
                <div class="md:col-span-2">
                  <label class="mb-1 block text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Адрес</label>
                  <input id="profile-card-address" type="text" placeholder="Farghona, Mustaqillik 13" class="w-full rounded-xl border border-neutral-200 px-3 py-2 text-sm" />
                </div>
                <div>
                  <label class="mb-1 block text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Индекс</label>
                  <input id="profile-card-postcode" type="text" placeholder="150100" class="w-full rounded-xl border border-neutral-200 px-3 py-2 text-sm" />
                </div>
                <div>
                  <label class="mb-1 block text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Email</label>
                  <input id="profile-card-email" type="email" placeholder="unq@uz.com" class="w-full rounded-xl border border-neutral-200 px-3 py-2 text-sm" />
                </div>
                <div class="md:col-span-2">
                  <label class="mb-1 block text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Дополнительный телефон</label>
                  <input id="profile-card-extra-phone" type="text" placeholder="+998200001360" class="w-full rounded-xl border border-neutral-200 px-3 py-2 text-sm" />
                </div>
              </div>

              <div id="profile-card-theme-wrap">
                <label class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Тема</label>
                <div id="profile-card-theme-options" class="grid grid-cols-2 gap-2 sm:grid-cols-5">
                  <button type="button" data-theme="default_dark" class="profile-theme-btn rounded-lg border border-neutral-200 px-2 py-1.5 text-xs">Default Dark</button>
                  <button type="button" data-theme="light_minimal" class="profile-theme-btn rounded-lg border border-neutral-200 px-2 py-1.5 text-xs">Light</button>
                  <button type="button" data-theme="gradient" class="profile-theme-btn rounded-lg border border-neutral-200 px-2 py-1.5 text-xs">Gradient</button>
                  <button type="button" data-theme="neon" class="profile-theme-btn rounded-lg border border-neutral-200 px-2 py-1.5 text-xs">Neon</button>
                  <button type="button" data-theme="corporate" class="profile-theme-btn rounded-lg border border-neutral-200 px-2 py-1.5 text-xs">Corporate</button>
                </div>
                <p id="profile-card-theme-lock-note" class="mt-1 hidden text-xs text-neutral-500">Доступно на Премиум</p>
              </div>

              <div>
                <label class="mb-1 block text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Кастомный цвет акцента</label>
                <input id="profile-card-custom-color" type="color" value="#111111" class="h-10 w-14 rounded-lg border border-neutral-200 p-1" />
              </div>

              <label class="inline-flex items-center gap-2 text-sm">
                <input id="profile-card-show-branding" type="checkbox" checked />
                Скрыть брендинг UNQ+
              </label>

              <button id="profile-card-save" type="button" class="interactive-btn min-h-11 rounded-xl bg-neutral-900 px-4 py-2 text-sm font-semibold text-white">Сохранить визитку</button>
              <p id="profile-card-save-status" class="text-sm"></p>
              <p id="profile-card-slug-note" class="text-xs text-neutral-500"></p>
            </div>

            <div class="xl:mt-2">
              <div class="mb-2 flex flex-col items-start justify-between gap-2 sm:flex-row sm:items-center">
                <p class="text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Так выглядит твоя визитка на <span id="profile-preview-slug-label">unqx.uz/[UNQ]</span></p>
                <a id="profile-preview-open-link" href="#" target="_blank" rel="noopener noreferrer" class="text-xs font-semibold text-neutral-700 hover:underline">Открыть →</a>
              </div>
              <div id="profile-card-live-preview" class="rounded-2xl border border-neutral-200 bg-white p-3 sm:p-4"></div>
            </div>
          </div>
        </article>

        <article data-tab-panel="requests" class="profile-tab-panel hidden min-w-0 rounded-2xl border border-neutral-200 bg-white p-4 sm:p-5">
          <div class="flex flex-col items-start justify-between gap-2 sm:flex-row sm:items-center">
            <h2 class="text-lg font-bold">ЗАЯВКИ</h2>
            <button id="profile-new-request-btn" type="button" class="interactive-btn min-h-11 w-full rounded-xl border border-neutral-300 px-3 py-2 text-sm font-semibold sm:w-auto">Подать новую заявку</button>
          </div>
          <div id="profile-requests-banner" class="hidden mt-3 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800"></div>
          <div class="mt-4 overflow-auto rounded-xl border border-neutral-200">
            <table class="min-w-full text-left text-sm">
              <thead class="bg-neutral-50 text-xs uppercase tracking-wide text-neutral-500">
                <tr>
                  <th class="px-3 py-2">Дата</th>
                  <th class="px-3 py-2">UNQ</th>
                  <th class="px-3 py-2">Цена</th>
                  <th class="px-3 py-2">Тариф</th>
                  <th class="px-3 py-2">Браслет</th>
                  <th class="px-3 py-2">Статус</th>
                  <th class="px-3 py-2">Примечание</th>
                </tr>
              </thead>
              <tbody id="profile-requests-table"></tbody>
            </table>
          </div>
        </article>

        <article data-tab-panel="referrals" class="profile-tab-panel hidden min-w-0 rounded-2xl border border-neutral-200 bg-white p-4 sm:p-5">
          <h2 class="text-lg font-bold">РЕФЕРАЛЫ</h2>
          <div class="mt-4 grid gap-3 rounded-xl border border-neutral-200 bg-neutral-50 p-3 sm:p-4 md:grid-cols-[1fr_auto_auto]">
            <input id="profile-ref-link" type="text" readonly class="min-w-0 rounded-xl border border-neutral-200 bg-white px-3 py-2 text-sm" />
            <button id="profile-ref-copy" type="button" class="interactive-btn min-h-11 rounded-xl border border-neutral-300 px-3 py-2 text-sm font-semibold">Скопировать ссылку</button>
            <a id="profile-ref-tg" href="#" class="interactive-btn min-h-11 rounded-xl border border-neutral-300 px-3 py-2 text-sm font-semibold text-center">Поделиться в Telegram</a>
          </div>

          <div class="mt-4 grid gap-3 md:grid-cols-3">
            <div class="rounded-xl border border-neutral-200 p-3"><p class="text-xs text-neutral-500">Приглашено друзей</p><p id="profile-ref-stat-invited" class="mt-1 text-xl font-black">0</p></div>
            <div class="rounded-xl border border-neutral-200 p-3"><p class="text-xs text-neutral-500">Из них оплатили</p><p id="profile-ref-stat-paid" class="mt-1 text-xl font-black">0</p></div>
            <div class="rounded-xl border border-neutral-200 p-3"><p class="text-xs text-neutral-500">Заработано бонусов</p><p id="profile-ref-stat-rewarded" class="mt-1 text-xl font-black">0</p></div>
          </div>

          <div class="mt-4 overflow-auto rounded-xl border border-neutral-200">
            <table class="min-w-full text-left text-sm">
              <thead class="bg-neutral-50 text-xs uppercase tracking-wide text-neutral-500">
                <tr>
                  <th class="px-3 py-2">Имя</th>
                  <th class="px-3 py-2">Дата регистрации</th>
                  <th class="px-3 py-2">Статус</th>
                  <th class="px-3 py-2">Награда</th>
                </tr>
              </thead>
              <tbody id="profile-ref-table"></tbody>
            </table>
          </div>

          <div id="profile-ref-rewards" class="mt-4 grid gap-3 md:grid-cols-3"></div>
        </article>

        <article data-tab-panel="settings" class="profile-tab-panel hidden min-w-0 rounded-2xl border border-neutral-200 bg-white p-4 sm:p-5">
          <h2 class="text-lg font-bold">НАСТРОЙКИ</h2>
          <div class="mt-4 space-y-4">
            <div>
              <label class="mb-1 block text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Имя отображения</label>
              <input id="profile-settings-display-name" type="text" class="w-full rounded-xl border border-neutral-200 px-3 py-2 text-sm" />
            </div>
            <div>
              <label class="mb-1 block text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Telegram</label>
              <input id="profile-settings-telegram" type="text" readonly class="w-full rounded-xl border border-neutral-200 bg-neutral-50 px-3 py-2 text-sm" />
            </div>
            <label class="inline-flex items-center gap-2 text-sm">
              <input id="profile-settings-notifications" type="checkbox" />
              Получать уведомления от бота
            </label>
            <button id="profile-settings-save" type="button" class="interactive-btn min-h-11 rounded-xl border border-neutral-300 px-4 py-2 text-sm font-semibold">Сохранить настройки</button>
            <p id="profile-settings-status" class="text-sm"></p>
          </div>
          <div class="mt-8 rounded-xl border border-red-200 bg-red-50 p-4">
            <h3 class="text-sm font-semibold text-red-800">Опасная зона</h3>
            <p class="mt-1 text-xs text-red-700">Все твои UNQ станут недоступны</p>
            <button id="profile-settings-deactivate" type="button" class="interactive-btn mt-3 min-h-11 rounded-lg border border-red-300 px-3 py-1.5 text-xs font-semibold text-red-700">Деактивировать аккаунт</button>
          </div>
        </article>
      </section>
    </div>
  </main>

  <div id="profile-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4">
    <div id="profile-modal-dialog" class="w-full max-w-md rounded-2xl bg-white p-5" role="dialog" aria-modal="true" tabindex="-1">
      <button id="profile-modal-close-top" type="button" class="interactive-btn ml-auto inline-flex h-9 w-9 items-center justify-center rounded-lg border border-neutral-300 text-neutral-600" aria-label="Закрыть окно">
        <svg class="icon-stroke h-4 w-4" viewBox="0 0 24 24" aria-hidden="true">
          <path d="m6 6 12 12M18 6 6 18"></path>
        </svg>
      </button>
      <h3 id="profile-modal-title" class="text-lg font-bold text-neutral-900"></h3>
      <p id="profile-modal-text" class="mt-2 text-sm text-neutral-600"></p>
      <div class="mt-4 flex flex-col gap-2 sm:flex-row">
        <button id="profile-modal-confirm" type="button" class="interactive-btn min-h-11 rounded-lg bg-neutral-900 px-3 py-1.5 text-sm font-semibold text-white sm:min-w-[120px]">Ок</button>
        <button id="profile-modal-close" type="button" class="interactive-btn min-h-11 rounded-lg border border-neutral-300 px-3 py-1.5 text-sm font-semibold sm:min-w-[120px]">Закрыть</button>
      </div>
    </div>
  </div>

  <%- include('../partials/order-modal') %>

  <script nonce="<%= cspNonce %>" src="/vendor/sortablejs/Sortable.min.js"></script>
  <script nonce="<%= cspNonce %>" src="/vendor/cropperjs/cropper.min.js"></script>
  <script nonce="<%= cspNonce %>" src="/vendor/chartjs/chart.umd.min.js"></script>
  <script nonce="<%= cspNonce %>" src="/js/site-dialogs.js"></script>
  <script nonce="<%= cspNonce %>" src="/js/order-modal.js"></script>
  <script nonce="<%= cspNonce %>" src="/js/card-view.js"></script>
  <script nonce="<%= cspNonce %>" src="/js/profile.js"></script>
</body>
</html>


