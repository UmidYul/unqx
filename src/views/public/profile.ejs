<!doctype html>
<html lang="ru">

<head>
  <%- include('../partials/head', { title: title || "Мой профиль | UNQX" , description: typeof description==='string' ?
    description : undefined, image: typeof image==='string' ? image : undefined, styles: ['/css/public-card.css'],
    noindex: true }) %>
    <link rel="stylesheet" href="/vendor/cropperjs/cropper.min.css" />
</head>

<body class="antialiased" data-page="profile-page" data-telegram-bot-username="<%= telegramBotUsername || '' %>">
  <main class="min-h-screen bg-neutral-50 px-3 py-4 sm:px-4 sm:py-6 md:px-6">
    <div class="mx-auto mb-3 w-full max-w-6xl sm:mb-4">
      <a href="/"
        class="interactive-btn inline-flex min-h-11 items-center gap-1.5 rounded-lg border border-neutral-200 bg-white px-3 py-1.5 text-xs font-semibold text-neutral-700">
        <svg class="icon-stroke h-4 w-4" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M15 18 9 12l6-6"></path>
        </svg>
        На главную
      </a>
    </div>
    <section id="profile-welcome-banner"
      class="mx-auto mb-4 hidden w-full max-w-6xl rounded-2xl border border-neutral-200 bg-white p-4 sm:p-5">
      <div class="flex items-start justify-between gap-3">
        <div>
          <h2 class="text-base font-bold text-neutral-900">Добро пожаловать в UNQX</h2>
          <p class="mt-1 text-sm text-neutral-600">Ты зарегистрирован. Следующий шаг — займи свой slug и выбери тариф.
          </p>
        </div>
        <button id="profile-welcome-dismiss" type="button"
          class="interactive-btn inline-flex h-8 w-8 items-center justify-center rounded-lg border border-neutral-300 text-neutral-600"
          aria-label="Закрыть приветствие">
          <svg class="icon-stroke h-4 w-4" viewBox="0 0 24 24" aria-hidden="true">
            <path d="m6 6 12 12M18 6 6 18"></path>
          </svg>
        </button>
      </div>
      <button type="button" data-order-link
        class="interactive-btn mt-3 min-h-11 rounded-xl bg-neutral-900 px-4 py-2 text-sm font-semibold text-white">Занять
        slug →</button>
    </section>
    <div class="mx-auto grid min-w-0 w-full max-w-6xl gap-4 md:gap-6 lg:grid-cols-[300px_1fr]">
      <aside class="min-w-0 rounded-2xl border border-neutral-200 bg-white p-4 sm:p-5">
        <div class="flex items-center gap-3">
          <img id="profile-sidebar-avatar" src="/brand/profile-thin.svg" alt="avatar"
            class="h-14 w-14 rounded-full border border-neutral-200 object-cover" />
          <div>
            <p id="profile-sidebar-name" class="text-base font-semibold text-neutral-900">Загрузка...</p>
            <p id="profile-sidebar-username" class="text-sm text-neutral-500">@—</p>
          </div>
        </div>
        <div class="mt-4 space-y-2 rounded-xl border border-neutral-200 bg-neutral-50 p-3">
          <p id="profile-sidebar-plan"
            class="inline-flex rounded-full border border-neutral-300 px-2.5 py-1 text-xs font-semibold">БАЗОВЫЙ</p>
          <p id="profile-sidebar-expiry" class="hidden text-xs text-neutral-500">Куплено: —</p>
          <button id="profile-sidebar-choose-plan" type="button" data-order-link data-order-plan="basic"
            class="interactive-btn hidden min-h-11 rounded-lg border border-neutral-300 px-3 py-1.5 text-xs font-semibold text-left">
            Купить тариф →
          </button>
        </div>
        <nav class="mt-4 grid grid-cols-2 gap-2 sm:grid-cols-3 lg:mt-5 lg:grid-cols-1">
          <button type="button" data-tab-target="slugs"
            class="profile-tab-btn interactive-btn min-h-11 rounded-xl border border-neutral-200 px-3 py-2 text-center text-xs font-medium sm:text-sm lg:text-left">МОИ
            UNQ</button>
          <button type="button" data-tab-target="card"
            class="profile-tab-btn interactive-btn min-h-11 rounded-xl border border-neutral-200 px-3 py-2 text-center text-xs font-medium sm:text-sm lg:text-left">МОЯ
            ВИЗИТКА</button>
          <button type="button" data-tab-target="analytics"
            class="profile-tab-btn interactive-btn min-h-11 rounded-xl border border-neutral-200 px-3 py-2 text-center text-xs font-medium sm:text-sm lg:text-left">АНАЛИТИКА</button>
          <button type="button" data-tab-target="requests"
            class="profile-tab-btn interactive-btn min-h-11 rounded-xl border border-neutral-200 px-3 py-2 text-center text-xs font-medium sm:text-sm lg:text-left">ЗАЯВКИ</button>
          <button type="button" data-tab-target="referrals"
            class="profile-tab-btn interactive-btn min-h-11 rounded-xl border border-neutral-200 px-3 py-2 text-center text-xs font-medium sm:text-sm lg:text-left">РЕФЕРАЛЫ</button>
          <button type="button" data-tab-target="settings"
            class="profile-tab-btn interactive-btn min-h-11 rounded-xl border border-neutral-200 px-3 py-2 text-center text-xs font-medium sm:text-sm lg:text-left">НАСТРОЙКИ</button>
        </nav>
        <button id="profile-logout-btn" type="button"
          class="interactive-btn mt-4 min-h-11 w-full rounded-xl border border-red-200 px-3 py-2 text-sm font-semibold text-red-700 lg:mt-5">
          Выйти
        </button>
      </aside>

      <section class="min-w-0 space-y-4">
        <div id="profile-upgrade-banner"
          class="hidden rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
          Открыть Премиум · 80 000 сум единоразово.
          <a href="#" data-order-link data-order-plan="premium" class="ml-1 underline">Купить Премиум →</a>
        </div>

        <article data-tab-panel="slugs"
          class="profile-tab-panel min-w-0 rounded-2xl border border-neutral-200 bg-white p-4 sm:p-5">
          <div class="flex flex-col items-start justify-between gap-2 sm:flex-row sm:items-center">
            <h2 class="text-lg font-bold">МОИ UNQ</h2>
            <button id="profile-add-slug-btn" type="button"
              class="interactive-btn min-h-11 w-full rounded-xl border border-neutral-300 px-3 py-2 text-sm font-semibold sm:w-auto">Добавить
              UNQ</button>
          </div>
          <p id="profile-add-slug-note" class="mt-2 text-xs text-neutral-500"></p>
          <div id="profile-slugs-list" class="mt-4 space-y-3"></div>
        </article>

        <article data-tab-panel="card"
          class="profile-tab-panel hidden min-w-0 rounded-2xl border border-neutral-200 bg-white p-4 sm:p-5">
          <h2 class="text-lg font-bold">МОЯ ВИЗИТКА</h2>
          <section id="profile-card-empty-state"
            class="hidden mt-5 rounded-xl border border-neutral-200 bg-neutral-50 px-4 py-10 text-center"></section>
          <div id="profile-card-content">
            <section id="profile-score-panel" class="mt-4 rounded-xl border border-neutral-200 bg-neutral-50 p-4">
              <div class="grid gap-4 xl:grid-cols-[280px_1fr]">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">UNQ SCORE</p>
                  <p id="profile-score-value" class="mt-2 text-5xl font-black text-neutral-900">0</p>
                  <p id="profile-score-top" class="mt-1 text-sm text-neutral-500">Топ 100%</p>
                  <p id="profile-score-updated" class="mt-1 text-xs text-neutral-500">Обновлено —</p>
                </div>
                <div id="profile-score-breakdown" class="space-y-2"></div>
              </div>
              <details id="profile-score-tips" class="mt-4 rounded-xl border border-neutral-200 bg-white p-3">
                <summary class="cursor-pointer text-sm font-semibold text-neutral-800">Как повысить Score</summary>
                <div id="profile-score-tips-list" class="mt-2 space-y-2 text-sm text-neutral-600"></div>
              </details>
              <div class="mt-4 rounded-xl border border-neutral-200 bg-white p-3">
                <div class="relative">
                  <canvas id="profile-score-history-chart" height="120"></canvas>
                  <div id="profile-score-history-lock"
                    class="hidden absolute inset-0 rounded-xl bg-white/80 p-4 backdrop-blur-sm">
                    <p class="text-sm font-semibold text-neutral-800">Открыть Премиум · 80 000 сум единоразово</p>
                    <button type="button" data-order-link data-order-plan="premium"
                      class="interactive-btn mt-2 min-h-11 rounded-lg border border-neutral-300 px-3 py-1.5 text-xs font-semibold">Купить
                      Премиум →</button>
                  </div>
                </div>
              </div>
            </section>
            <div class="mt-4 grid items-start gap-4 xl:grid-cols-[1fr_340px]">
              <div class="space-y-4">
                <div>
                  <label
                    class="mb-1 block text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Аватар</label>
                  <div class="flex flex-wrap items-center gap-3">
                    <img id="profile-card-avatar-preview" src="/brand/profile-thin.svg" alt="avatar"
                      class="h-16 w-16 rounded-full border border-neutral-200 object-cover" />
                    <div class="flex flex-wrap gap-2">
                      <label for="profile-card-avatar-file"
                        class="inline-flex min-h-11 cursor-pointer items-center justify-center rounded-lg border border-neutral-300 px-3 py-1.5 text-xs font-semibold">Загрузить</label>
                      <input id="profile-card-avatar-file" type="file" accept="image/png,image/jpeg,image/webp"
                        class="hidden" />
                      <button id="profile-card-avatar-remove" type="button"
                        class="interactive-btn min-h-11 rounded-lg border border-red-200 px-3 py-1.5 text-xs font-semibold text-red-700">Удалить</button>
                    </div>
                  </div>
                  <div id="profile-card-avatar-crop-wrap"
                    class="mt-3 hidden rounded-xl border border-neutral-200 bg-neutral-50 p-3">
                    <img id="profile-card-avatar-crop-image" alt="crop" class="max-h-[320px] w-full object-contain" />
                    <button id="profile-card-avatar-crop-save" type="button"
                      class="interactive-btn mt-2 min-h-11 rounded-lg bg-neutral-900 px-3 py-1.5 text-xs font-semibold text-white">Сохранить
                      обрезку</button>
                  </div>
                </div>

                <div>
                  <label class="mb-1 block text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Имя <span
                      class="text-red-600">*</span></label>
                  <input id="profile-card-name" type="text"
                    class="w-full rounded-xl border border-neutral-200 px-3 py-2 text-sm" />
                  <p id="profile-card-name-error" class="mt-1 hidden text-xs text-red-700">Имя обязательно.</p>
                </div>
                <div>
                  <label
                    class="mb-1 block text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Bio</label>
                  <textarea id="profile-card-bio" maxlength="120" rows="3"
                    class="w-full rounded-xl border border-neutral-200 px-3 py-2 text-sm"></textarea>
                  <p id="profile-card-bio-counter" class="mt-1 text-xs text-neutral-500">0/120</p>
                </div>
                <div class="grid gap-3 md:grid-cols-2">
                  <div class="md:col-span-2">
                    <label class="mb-1 block text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Нижний
                      хэштег</label>
                    <input id="profile-card-hashtag" type="text" placeholder="#UnqPower2026"
                      class="w-full rounded-xl border border-neutral-200 px-3 py-2 text-sm" />
                  </div>
                </div>
                <div>
                  <label
                    class="mb-1 block text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Теги</label>
                  <div class="flex flex-col gap-2 sm:flex-row">
                    <input id="profile-card-tag-input" type="text" placeholder="#Дизайнер"
                      class="w-full rounded-xl border border-neutral-200 px-3 py-2 text-sm" />
                    <button id="profile-card-tag-add" type="button"
                      class="interactive-btn min-h-11 rounded-xl border border-neutral-300 px-3 py-2 text-sm sm:w-auto">Добавить</button>
                  </div>
                  <div id="profile-card-tags-list" class="mt-2 flex flex-wrap gap-2"></div>
                </div>

                <div>
                  <div class="mb-2 flex items-center justify-between">
                    <label
                      class="block text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Кнопки</label>
                    <button id="profile-card-button-add" type="button"
                      class="interactive-btn min-h-11 rounded-lg border border-neutral-300 px-2.5 py-1 text-xs font-semibold">Добавить
                      кнопку</button>
                  </div>
                  <div id="profile-card-buttons-list" class="space-y-2"></div>
                </div>

                <div class="grid gap-3 md:grid-cols-2">
                  <div class="md:col-span-2">
                    <label
                      class="mb-1 block text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Адрес</label>
                    <input id="profile-card-address" type="text" placeholder="Farghona, Mustaqillik 13"
                      class="w-full rounded-xl border border-neutral-200 px-3 py-2 text-sm" />
                  </div>
                  <div>
                    <label
                      class="mb-1 block text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Индекс</label>
                    <input id="profile-card-postcode" type="text" placeholder="150100"
                      class="w-full rounded-xl border border-neutral-200 px-3 py-2 text-sm" />
                  </div>
                  <div>
                    <label
                      class="mb-1 block text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Email</label>
                    <input id="profile-card-email" type="email" placeholder="unq@uz.com"
                      class="w-full rounded-xl border border-neutral-200 px-3 py-2 text-sm" />
                  </div>
                  <div class="md:col-span-2">
                    <label
                      class="mb-1 block text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Дополнительный
                      телефон</label>
                    <input id="profile-card-extra-phone" type="text" placeholder="+998200001360"
                      class="w-full rounded-xl border border-neutral-200 px-3 py-2 text-sm" />
                  </div>
                </div>

                <div id="profile-card-theme-wrap">
                  <label
                    class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Тема</label>
                  <div id="profile-card-theme-options" class="grid grid-cols-1 gap-2 sm:grid-cols-2 lg:grid-cols-5">
                    <button type="button" data-theme="default_dark"
                      class="profile-theme-btn rounded-lg border border-neutral-200 px-2 py-1.5 text-xs">
                      <span class="flex min-w-0 items-center gap-2">
                        <span
                          class="relative inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-md border border-white bg-[#0a0a0a]"
                          data-theme-swatch>
                          <span
                            class="pointer-events-none absolute inset-0 hidden items-center justify-center rounded-md bg-black/35 text-[10px] text-white"
                            data-theme-lock>🔒</span>
                        </span>
                        <span class="min-w-0 flex-1 text-left">
                          <span class="block font-semibold leading-tight">Default Dark</span>
                          <span class="block truncate text-[10px] text-neutral-500">Classic UNQX dark</span>
                        </span>
                      </span>
                    </button>
                    <button type="button" data-theme="arctic" data-premium-required="1"
                      class="profile-theme-btn rounded-lg border border-neutral-200 px-2 py-1.5 text-xs">
                      <span class="flex min-w-0 items-center gap-2">
                        <span
                          class="relative inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-md border border-[#7a9db8] bg-[#f0f5f9]"
                          data-theme-swatch>
                          <span
                            class="pointer-events-none absolute inset-0 hidden items-center justify-center rounded-md bg-black/35 text-[10px] text-white"
                            data-theme-lock>🔒</span>
                        </span>
                        <span class="min-w-0 flex-1 text-left">
                          <span class="block truncate font-semibold">Arctic</span>
                          <span class="block truncate text-[10px] text-neutral-500">Cool silver tone</span>
                        </span>
                      </span>
                    </button>
                    <button type="button" data-theme="linen" data-premium-required="1"
                      class="profile-theme-btn rounded-lg border border-neutral-200 px-2 py-1.5 text-xs">
                      <span class="flex min-w-0 items-center gap-2">
                        <span
                          class="relative inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-md border border-[#c8a882] bg-[#f2ede6]"
                          data-theme-swatch>
                          <span
                            class="pointer-events-none absolute inset-0 hidden items-center justify-center rounded-md bg-black/35 text-[10px] text-white"
                            data-theme-lock>🔒</span>
                        </span>
                        <span class="min-w-0 flex-1 text-left">
                          <span class="block truncate font-semibold">Linen</span>
                          <span class="block truncate text-[10px] text-neutral-500">Warm editorial look</span>
                        </span>
                      </span>
                    </button>
                    <button type="button" data-theme="marble" data-premium-required="1"
                      class="profile-theme-btn rounded-lg border border-neutral-200 px-2 py-1.5 text-xs">
                      <span class="flex min-w-0 items-center gap-2">
                        <span
                          class="relative inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-md border border-[#0a0a0a] bg-white"
                          data-theme-swatch>
                          <span
                            class="pointer-events-none absolute inset-0 hidden items-center justify-center rounded-md bg-black/35 text-[10px] text-white"
                            data-theme-lock>🔒</span>
                        </span>
                        <span class="min-w-0 flex-1 text-left">
                          <span class="block truncate font-semibold">Marble</span>
                          <span class="block truncate text-[10px] text-neutral-500">Minimal monochrome</span>
                        </span>
                      </span>
                    </button>
                    <button type="button" data-theme="forest" data-premium-required="1"
                      class="profile-theme-btn rounded-lg border border-neutral-200 px-2 py-1.5 text-xs">
                      <span class="flex min-w-0 items-center gap-2">
                        <span
                          class="relative inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-md border border-[#c8b88a] bg-[#0e2010]"
                          data-theme-swatch>
                          <span
                            class="pointer-events-none absolute inset-0 hidden items-center justify-center rounded-md bg-black/35 text-[10px] text-white"
                            data-theme-lock>🔒</span>
                        </span>
                        <span class="min-w-0 flex-1 text-left">
                          <span class="block truncate font-semibold">Forest</span>
                          <span class="block truncate text-[10px] text-neutral-500">Deep organic style</span>
                        </span>
                      </span>
                    </button>
                  </div>
                  <p id="profile-card-theme-lock-note" class="mt-1 hidden text-xs text-neutral-500">Доступно на Премиум
                  </p>
                </div>

                <div>
                  <label class="mb-1 block text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Кастомный
                    цвет акцента</label>
                  <input id="profile-card-custom-color" type="color" value="#111111"
                    class="h-10 w-14 rounded-lg border border-neutral-200 p-1" />
                </div>

                <label class="inline-flex items-center gap-2 text-sm">
                  <input id="profile-card-show-branding" type="checkbox" checked />
                  Скрыть брендинг UNQX
                </label>

                <div class="mt-2 flex justify-end">
                  <button id="profile-card-save" type="button"
                    class="interactive-btn min-h-11 rounded-xl bg-neutral-900 px-4 py-2 text-sm font-semibold text-white">Сохранить
                    визитку</button>
                </div>
              </div>

              <div class="xl:mt-2">
                <div class="mb-2 flex flex-col items-start justify-between gap-2 sm:flex-row sm:items-center">
                  <a id="profile-preview-open-link" href="#" target="_blank" rel="noopener noreferrer"
                    class="text-xs font-semibold text-neutral-700 hover:underline">Открыть</a>
                </div>
                <div id="profile-card-live-preview" class="rounded-2xl border border-neutral-200 bg-white p-3 sm:p-4">
                </div>
              </div>
            </div>
          </div>
        </article>

        <article data-tab-panel="analytics"
          class="profile-tab-panel hidden min-w-0 rounded-2xl border border-neutral-200 bg-white p-4 sm:p-5">
          <h2 class="text-lg font-bold">АНАЛИТИКА</h2>
          <section id="profile-analytics-empty-state"
            class="hidden mt-5 rounded-xl border border-neutral-200 bg-neutral-50 px-4 py-10 text-center"></section>
          <section id="profile-analytics-content" class="mt-4 rounded-xl border border-neutral-200 bg-neutral-50 p-4">
            <div class="mb-4 grid gap-2 md:grid-cols-[1fr_auto]">
              <select id="profile-analytics-slug"
                class="rounded-xl border border-neutral-200 bg-white px-3 py-2 text-sm"></select>
              <div id="profile-analytics-periods" class="flex items-center gap-2"></div>
            </div>
            <div class="grid gap-4 sm:grid-cols-3">
              <article class="rounded-xl border border-neutral-200 bg-white p-3">
                <p class="text-xs uppercase tracking-[0.12em] text-neutral-500">Просмотры</p>
                <p id="profile-analytics-views" class="mt-2 text-2xl font-black text-neutral-900">0</p>
              </article>
              <article class="rounded-xl border border-neutral-200 bg-white p-3">
                <p class="text-xs uppercase tracking-[0.12em] text-neutral-500">Уникальные</p>
                <p id="profile-analytics-unique" class="mt-2 text-2xl font-black text-neutral-900">0</p>
              </article>
              <article class="rounded-xl border border-neutral-200 bg-white p-3">
                <p class="text-xs uppercase tracking-[0.12em] text-neutral-500">CTR</p>
                <p id="profile-analytics-ctr" class="mt-2 text-2xl font-black text-neutral-900">0%</p>
              </article>
            </div>
            <div class="mt-4 grid gap-4 lg:grid-cols-2">
              <article class="rounded-xl border border-neutral-200 bg-white p-3">
                <p class="text-xs uppercase tracking-[0.12em] text-neutral-500">Динамика просмотров</p>
                <div class="mt-2 h-[220px]"><canvas id="profile-analytics-views-chart"></canvas></div>
              </article>
              <article class="rounded-xl border border-neutral-200 bg-white p-3">
                <p class="text-xs uppercase tracking-[0.12em] text-neutral-500">Источники трафика</p>
                <div class="mt-2 h-[220px]"><canvas id="profile-analytics-sources-chart"></canvas></div>
              </article>
              <article class="rounded-xl border border-neutral-200 bg-white p-3">
                <p class="text-xs uppercase tracking-[0.12em] text-neutral-500">Устройства</p>
                <div class="mt-2 h-[220px]"><canvas id="profile-analytics-devices-chart"></canvas></div>
              </article>
              <article class="rounded-xl border border-neutral-200 bg-white p-3">
                <p class="text-xs uppercase tracking-[0.12em] text-neutral-500">Активность кнопок</p>
                <div class="mt-2 h-[220px]"><canvas id="profile-analytics-buttons-chart"></canvas></div>
              </article>
            </div>
            <article class="mt-4 rounded-xl border border-neutral-200 bg-white p-3">
              <p class="text-xs uppercase tracking-[0.12em] text-neutral-500">География (города)</p>
              <div class="mt-2 h-[220px]"><canvas id="profile-analytics-geo-chart"></canvas></div>
            </article>
            <div id="profile-analytics-lock"
              class="mt-4 hidden rounded-xl border border-neutral-200 bg-white/80 p-4 text-sm text-neutral-700">
              Расширенные периоды аналитики (30 и 90 дней) доступны на Премиум.
              <button type="button" data-order-link data-order-plan="premium"
                class="interactive-btn ml-2 min-h-11 rounded-lg border border-neutral-300 px-3 py-1.5 text-xs font-semibold">
                Улучшить тариф
              </button>
            </div>
          </section>
        </article>

        <article data-tab-panel="requests"
          class="profile-tab-panel hidden min-w-0 rounded-2xl border border-neutral-200 bg-white p-4 sm:p-5">
          <div class="flex flex-col items-start justify-between gap-2 sm:flex-row sm:items-center">
            <h2 class="text-lg font-bold">ЗАЯВКИ</h2>
            <button id="profile-new-request-btn" type="button"
              class="interactive-btn min-h-11 w-full rounded-xl border border-neutral-300 px-3 py-2 text-sm font-semibold sm:w-auto">Подать
              новую заявку</button>
          </div>
          <div id="profile-requests-banner"
            class="hidden mt-3 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800">
          </div>
          <section id="profile-requests-empty-state"
            class="hidden mt-5 rounded-xl border border-neutral-200 bg-neutral-50 px-4 py-10 text-center"></section>
          <div id="profile-requests-table-wrap" class="mt-4 overflow-auto rounded-xl border border-neutral-200">
            <table class="min-w-full text-left text-sm">
              <thead class="bg-neutral-50 text-xs uppercase tracking-wide text-neutral-500">
                <tr>
                  <th class="px-3 py-2">Дата</th>
                  <th class="px-3 py-2">Дата покупки</th>
                  <th class="px-3 py-2">UNQ</th>
                  <th class="px-3 py-2">Цена</th>
                  <th class="px-3 py-2">Тариф</th>
                  <th class="px-3 py-2">Браслет</th>
                  <th class="px-3 py-2">Статус</th>
                  <th class="px-3 py-2">Примечание</th>
                </tr>
              </thead>
              <tbody id="profile-requests-table"></tbody>
            </table>
          </div>
        </article>

        <article data-tab-panel="referrals"
          class="profile-tab-panel hidden min-w-0 rounded-2xl border border-neutral-200 bg-white p-4 sm:p-5">
          <h2 class="text-lg font-bold">РЕФЕРАЛЫ</h2>
          <div
            class="mt-4 grid gap-3 rounded-xl border border-neutral-200 bg-neutral-50 p-3 sm:p-4 md:grid-cols-[1fr_auto_auto]">
            <input id="profile-ref-link" type="text" readonly
              class="min-w-0 rounded-xl border border-neutral-200 bg-white px-3 py-2 text-sm" />
            <button id="profile-ref-copy" type="button"
              class="interactive-btn min-h-11 rounded-xl border border-neutral-300 px-3 py-2 text-sm font-semibold">Скопировать
              ссылку</button>
            <a id="profile-ref-tg" href="#"
              class="interactive-btn min-h-11 rounded-xl border border-neutral-300 px-3 py-2 text-sm font-semibold text-center">Поделиться
              в Telegram</a>
          </div>

          <div class="mt-4 grid gap-3 md:grid-cols-3">
            <div class="rounded-xl border border-neutral-200 p-3">
              <p class="text-xs text-neutral-500">Приглашено друзей</p>
              <p id="profile-ref-stat-invited" class="mt-1 text-xl font-black">0</p>
            </div>
            <div class="rounded-xl border border-neutral-200 p-3">
              <p class="text-xs text-neutral-500">Из них оплатили</p>
              <p id="profile-ref-stat-paid" class="mt-1 text-xl font-black">0</p>
            </div>
            <div class="rounded-xl border border-neutral-200 p-3">
              <p class="text-xs text-neutral-500">Заработано бонусов</p>
              <p id="profile-ref-stat-rewarded" class="mt-1 text-xl font-black">0</p>
            </div>
          </div>

          <div class="mt-4 overflow-auto rounded-xl border border-neutral-200">
            <table class="min-w-full text-left text-sm">
              <thead class="bg-neutral-50 text-xs uppercase tracking-wide text-neutral-500">
                <tr>
                  <th class="px-3 py-2">Имя</th>
                  <th class="px-3 py-2">Дата регистрации</th>
                  <th class="px-3 py-2">Статус</th>
                  <th class="px-3 py-2">Награда</th>
                </tr>
              </thead>
              <tbody id="profile-ref-table"></tbody>
            </table>
          </div>

          <div id="profile-ref-rewards" class="mt-4 grid gap-3 md:grid-cols-3"></div>
        </article>

        <article data-tab-panel="settings"
          class="profile-tab-panel hidden min-w-0 rounded-2xl border border-neutral-200 bg-white p-4 sm:p-5">
          <h2 class="text-lg font-bold">НАСТРОЙКИ</h2>
          <div class="mt-4 space-y-4">
            <div>
              <label class="mb-1 block text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Имя
                отображения</label>
              <input id="profile-settings-display-name" type="text"
                class="w-full rounded-xl border border-neutral-200 px-3 py-2 text-sm" />
            </div>
            <div>
              <label class="mb-1 block text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Город</label>
              <select id="profile-settings-city" class="w-full rounded-xl border border-neutral-200 px-3 py-2 text-sm">
                <option value="" selected disabled>Выберите город</option>
                <%- include('../partials/city-options') %>
              </select>
            </div>
            <div>
              <label class="mb-1 block text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Email</label>
              <div class="flex flex-col gap-2 sm:flex-row">
                <input id="profile-settings-email" type="email" readonly
                  class="w-full rounded-xl border border-neutral-200 bg-neutral-50 px-3 py-2 text-sm" />
                <button id="profile-settings-change-email" type="button"
                  class="interactive-btn min-h-11 rounded-lg border border-neutral-300 px-3 py-1.5 text-xs font-semibold">Изменить
                  email</button>
              </div>
            </div>
            <div>
              <button id="profile-settings-change-password" type="button"
                class="interactive-btn min-h-11 rounded-lg border border-neutral-300 px-3 py-1.5 text-xs font-semibold">Изменить
                пароль</button>
            </div>
            <div>
              <label
                class="mb-1 block text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Telegram</label>
              <input id="profile-settings-telegram" type="text"
                class="w-full rounded-xl border border-neutral-200 px-3 py-2 text-sm" placeholder="@username" />
              <p class="mt-1 text-xs text-neutral-500">Для связи по заявкам. Не используется для входа.</p>
              <div class="mt-2 flex flex-wrap gap-2">
                <button id="profile-settings-link-telegram" type="button"
                  class="interactive-btn min-h-11 rounded-lg border border-neutral-300 px-3 py-1.5 text-xs font-semibold">Подключить
                  уведомления</button>
                <button id="profile-settings-unlink-telegram" type="button"
                  class="interactive-btn min-h-11 rounded-lg border border-neutral-300 px-3 py-1.5 text-xs font-semibold">Отключить
                  уведомления</button>
              </div>
            </div>
            <label class="inline-flex items-center gap-2 text-sm">
              <input id="profile-settings-notifications" type="checkbox" />
              Получать уведомления от бота
            </label>
            <label class="inline-flex items-center gap-2 text-sm">
              <input id="profile-settings-directory" type="checkbox" />
              Показывать мою визитку в Directory
            </label>
            <div class="rounded-xl border border-neutral-200 bg-neutral-50 p-3">
              <div class="flex items-center justify-between gap-3">
                <div>
                  <p class="text-sm font-semibold text-neutral-900">Верификация</p>
                  <p id="profile-verification-status" class="text-xs text-neutral-500">Статус: не запрошено</p>
                  <p id="profile-verification-note" class="mt-1 hidden text-xs text-neutral-500"></p>
                </div>
                <button id="profile-verification-open" type="button"
                  class="interactive-btn min-h-11 rounded-lg border border-neutral-300 px-3 py-2 text-xs font-semibold">
                  Подать заявку
                </button>
              </div>
              <div id="profile-verification-correction-wrap" class="mt-3 hidden">
                <p class="text-xs text-neutral-600">Если в заявке допущена ошибка, отправьте правку через форму
                  исправления.</p>
                <textarea id="profile-verification-correction" rows="2" placeholder="Опишите исправление"
                  class="mt-2 w-full rounded-lg border border-neutral-200 px-3 py-2 text-sm"></textarea>
                <button id="profile-verification-correction-submit" type="button"
                  class="interactive-btn mt-2 min-h-11 rounded-lg border border-neutral-300 px-3 py-2 text-xs font-semibold">
                  Отправить исправление
                </button>
              </div>
            </div>
            <button id="profile-settings-save" type="button"
              class="interactive-btn min-h-11 rounded-xl border border-neutral-300 px-4 py-2 text-sm font-semibold">Сохранить
              настройки</button>
            <p id="profile-settings-status" class="text-sm"></p>
          </div>
          <div class="mt-8 rounded-xl border border-red-200 bg-red-50 p-4">
            <h3 class="text-sm font-semibold text-red-800">Опасная зона</h3>
            <p class="mt-1 text-xs text-red-700">Все твои UNQ станут недоступны</p>
            <button id="profile-settings-deactivate" type="button"
              class="interactive-btn mt-3 min-h-11 rounded-lg border border-red-300 px-3 py-1.5 text-xs font-semibold text-red-700">Деактивировать
              аккаунт</button>
          </div>
        </article>
      </section>
    </div>
  </main>

  <div id="profile-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4">
    <div id="profile-modal-dialog" class="w-full max-w-md rounded-2xl bg-white p-5" role="dialog" aria-modal="true"
      tabindex="-1">
      <button id="profile-modal-close-top" type="button"
        class="interactive-btn ml-auto inline-flex h-9 w-9 items-center justify-center rounded-lg border border-neutral-300 text-neutral-600"
        aria-label="Закрыть окно">
        <svg class="icon-stroke h-4 w-4" viewBox="0 0 24 24" aria-hidden="true">
          <path d="m6 6 12 12M18 6 6 18"></path>
        </svg>
      </button>
      <h3 id="profile-modal-title" class="text-lg font-bold text-neutral-900"></h3>
      <p id="profile-modal-text" class="mt-2 text-sm text-neutral-600"></p>
      <div class="mt-4 flex flex-col gap-2 sm:flex-row">
        <button id="profile-modal-confirm" type="button"
          class="interactive-btn min-h-11 rounded-lg bg-neutral-900 px-3 py-1.5 text-sm font-semibold text-white sm:min-w-[120px]">Ок</button>
        <button id="profile-modal-close" type="button"
          class="interactive-btn min-h-11 rounded-lg border border-neutral-300 px-3 py-1.5 text-sm font-semibold sm:min-w-[120px]">Закрыть</button>
      </div>
    </div>
  </div>

  <div id="profile-qr-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4">
    <div class="w-full max-w-md rounded-2xl bg-white p-5">
      <div class="mb-3 flex items-center justify-between">
        <h3 class="text-lg font-bold text-neutral-900">Мой QR</h3>
        <button id="profile-qr-close" type="button"
          class="interactive-btn inline-flex h-9 w-9 items-center justify-center rounded-lg border border-neutral-300"
          aria-label="Закрыть">
          <svg class="icon-stroke h-4 w-4" viewBox="0 0 24 24" aria-hidden="true">
            <path d="m6 6 12 12M18 6 6 18"></path>
          </svg>
        </button>
      </div>
      <div id="profile-qr-box"
        class="mx-auto flex min-h-[280px] items-center justify-center rounded-xl border border-neutral-200 p-3"></div>
      <p id="profile-qr-link" class="mt-3 truncate text-center font-mono text-xs text-neutral-600"></p>
      <div class="mt-3 grid gap-2 sm:grid-cols-2">
        <button id="profile-qr-copy" type="button"
          class="interactive-btn min-h-11 rounded-lg border border-neutral-300 px-3 py-2 text-sm font-semibold">Скопировать
          ссылку</button>
        <button id="profile-qr-download-png" type="button"
          class="interactive-btn min-h-11 rounded-lg bg-neutral-900 px-3 py-2 text-sm font-semibold text-white">Скачать
          PNG</button>
      </div>
    </div>
  </div>

  <div id="profile-verification-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4">
    <div class="w-full max-w-lg rounded-2xl bg-white p-5">
      <div class="mb-3 flex items-center justify-between">
        <h3 class="text-lg font-bold text-neutral-900">Заявка на верификацию</h3>
        <button id="profile-verification-close" type="button"
          class="interactive-btn inline-flex h-9 w-9 items-center justify-center rounded-lg border border-neutral-300"
          aria-label="Закрыть">
          <svg class="icon-stroke h-4 w-4" viewBox="0 0 24 24" aria-hidden="true">
            <path d="m6 6 12 12M18 6 6 18"></path>
          </svg>
        </button>
      </div>
      <div class="grid gap-2">
        <input id="profile-verification-company" type="text" placeholder="Компания"
          class="rounded-lg border border-neutral-200 px-3 py-2 text-sm" />
        <input id="profile-verification-role" type="text" placeholder="Роль"
          class="rounded-lg border border-neutral-200 px-3 py-2 text-sm" />
        <select id="profile-verification-sector" class="rounded-lg border border-neutral-200 px-3 py-2 text-sm">
          <option value="design">Сфера: Дизайн</option>
          <option value="sales">Сфера: Продажи</option>
          <option value="marketing">Сфера: Маркетинг</option>
          <option value="it">Сфера: IT</option>
          <option value="other" selected>Сфера: Другое</option>
        </select>
        <select id="profile-verification-proof-type" class="rounded-lg border border-neutral-200 px-3 py-2 text-sm">
          <option value="email">Email</option>
          <option value="linkedin">LinkedIn</option>
          <option value="website">Website</option>
        </select>
        <input id="profile-verification-proof-value" type="text" placeholder="Ссылка или контакт"
          class="rounded-lg border border-neutral-200 px-3 py-2 text-sm" />
        <textarea id="profile-verification-comment" rows="3" placeholder="Комментарий (необязательно)"
          class="rounded-lg border border-neutral-200 px-3 py-2 text-sm"></textarea>
      </div>
      <div class="mt-3">
        <button id="profile-verification-submit" type="button"
          class="interactive-btn min-h-11 rounded-lg bg-neutral-900 px-3 py-2 text-sm font-semibold text-white">Отправить
          заявку</button>
      </div>
    </div>
  </div>

  <%- include('../partials/order-modal') %>

    <script nonce="<%= cspNonce %>" src="/vendor/sortablejs/Sortable.min.js"></script>
    <script nonce="<%= cspNonce %>" src="/vendor/cropperjs/cropper.min.js"></script>
    <script nonce="<%= cspNonce %>" src="/vendor/chartjs/chart.umd.min.js"></script>
    <script nonce="<%= cspNonce %>" src="/vendor/qrcode/qrcode.min.js"></script>
    <script nonce="<%= cspNonce %>" src="/js/site-dialogs.js"></script>
    <script nonce="<%= cspNonce %>" src="/js/order-modal.js"></script>
    <script nonce="<%= cspNonce %>" src="/js/card-view.js"></script>
    <script nonce="<%= cspNonce %>" src="/js/profile.js"></script>
</body>

</html>