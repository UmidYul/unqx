<!doctype html>
<html lang="ru">
<head>
  <%- include('../partials/head', { title: title || "Сброс пароля | UNQ+", description: typeof description === 'string' ? description : undefined, noindex: true }) %>
</head>
<body class="antialiased bg-neutral-50">
  <main class="mx-auto flex min-h-screen w-full max-w-md items-center px-4 py-10">
    <form id="forgot-form" class="w-full rounded-2xl border border-neutral-200 bg-white p-5">
      <h1 class="text-2xl font-bold text-neutral-900">Сброс пароля</h1>
      <label class="mt-4 block text-sm font-medium text-neutral-700">Email
        <input id="email" type="email" placeholder="Введи свой email" class="mt-1 w-full rounded-xl border border-neutral-200 px-3 py-2 text-sm" required />
      </label>
      <p id="forgot-status" class="mt-3 text-sm text-neutral-600"></p>
      <button type="submit" class="interactive-btn mt-4 min-h-11 w-full rounded-xl bg-neutral-900 px-4 py-2 text-sm font-semibold text-white">Сбросить пароль</button>
    </form>
  </main>
  <script nonce="<%= cspNonce %>">
    const csrf = document.querySelector('meta[name="csrf-token"]')?.getAttribute("content") || "";
    document.getElementById("forgot-form").addEventListener("submit", async (event) => {
      event.preventDefault();
      const email = document.getElementById("email").value;
      const response = await fetch("/api/auth/forgot-password", {
        method: "POST",
        headers: { "Content-Type": "application/json", "x-csrf-token": csrf },
        body: JSON.stringify({ email }),
      });
      const payload = await response.json().catch(() => ({}));
      document.getElementById("forgot-status").textContent = payload?.message || "Если аккаунт с таким email существует, мы отправили код для сброса пароля.";
      setTimeout(() => {
        window.location.href = `/reset-password?email=${encodeURIComponent(email)}`;
      }, 700);
    });
  </script>
</body>
</html>

