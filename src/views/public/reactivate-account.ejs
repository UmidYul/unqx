<!doctype html>
<html lang="ru">

<head>
    <%- include('../partials/head', { title: title || "Восстановление аккаунта | UNQX" , description: typeof
        description==='string' ? description : undefined, noindex: true }) %>
</head>

<body class="antialiased bg-neutral-50">
    <main class="mx-auto flex min-h-screen w-full max-w-md items-center px-4 py-10">
        <form id="reactivate-form" class="w-full rounded-2xl border border-neutral-200 bg-white p-5"
            data-bwignore="true" data-lpignore="true" data-1p-ignore="true" autocomplete="off">
            <a href="/"
                class="inline-flex items-center gap-2 rounded-lg border border-neutral-200 bg-neutral-50 px-2.5 py-1.5 text-sm font-semibold text-neutral-700">
                <img src="/brand/logo.PNG" alt="UNQX"
                    class="h-6 w-6 rounded-md border border-neutral-200 object-cover" />
                <span>UNQX</span>
            </a>

            <h1 class="mt-4 text-2xl font-bold text-neutral-900">Восстановление аккаунта</h1>
            <p class="mt-1 text-sm text-neutral-500">Запроси код из письма и подтверди восстановление</p>

            <label class="mt-4 block text-sm font-medium text-neutral-700">Email
                <input id="email" type="email" value="<%= typeof email === 'string' ? email : '' %>"
                    autocomplete="email" class="mt-1 w-full rounded-xl border border-neutral-200 px-3 py-2 text-sm"
                    required />
            </label>

            <button id="reactivate-send-code" type="button"
                class="interactive-btn mt-3 min-h-11 w-full rounded-xl border border-neutral-300 px-4 py-2 text-sm font-semibold">Отправить
                код</button>

            <label class="mt-3 block text-sm font-medium text-neutral-700">Код из письма
                <input id="code" inputmode="numeric" maxlength="24"
                    class="mt-1 w-full rounded-xl border border-neutral-200 px-3 py-2 text-center font-mono text-xl tracking-[0.4em]"
                    required />
            </label>

            <p id="reactivate-status" class="mt-3 text-sm text-neutral-600"></p>
            <p id="reactivate-error" class="mt-2 hidden text-sm text-red-700"></p>

            <button type="submit"
                class="interactive-btn mt-4 min-h-11 w-full rounded-xl bg-neutral-900 px-4 py-2 text-sm font-semibold text-white">Восстановить
                аккаунт</button>
            <p class="mt-3 text-sm text-neutral-600"><a href="/login" class="underline">Вернуться ко входу</a></p>
        </form>
    </main>

    <script nonce="<%= cspNonce %>">
        const csrf = document.querySelector('meta[name="csrf-token"]')?.getAttribute("content") || "";
        const form = document.getElementById("reactivate-form");
        const emailInput = document.getElementById("email");
        const codeInput = document.getElementById("code");
        const statusNode = document.getElementById("reactivate-status");
        const errorNode = document.getElementById("reactivate-error");
        const sendBtn = document.getElementById("reactivate-send-code");

        function showError(message) {
            errorNode.textContent = message || "Ошибка";
            errorNode.classList.remove("hidden");
        }

        function hideError() {
            errorNode.classList.add("hidden");
            errorNode.textContent = "";
        }

        codeInput?.addEventListener("input", () => {
            codeInput.value = String(codeInput.value || "").replace(/\D/g, "").slice(0, 6);
        });

        sendBtn?.addEventListener("click", async () => {
            hideError();
            statusNode.textContent = "";
            const email = String(emailInput?.value || "").trim();
            if (!email) {
                showError("Email обязателен");
                return;
            }

            sendBtn.disabled = true;
            try {
                const response = await fetch("/api/auth/reactivate/request", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "x-csrf-token": csrf,
                    },
                    body: JSON.stringify({ email }),
                });
                const payload = await response.json().catch(() => ({}));
                if (!response.ok) {
                    showError(payload?.error || "Не удалось отправить код");
                    return;
                }
                statusNode.textContent = "Код отправлен на email";
            } finally {
                sendBtn.disabled = false;
            }
        });

        form?.addEventListener("submit", async (event) => {
            event.preventDefault();
            hideError();
            statusNode.textContent = "";

            const email = String(emailInput?.value || "").trim();
            const code = String(codeInput?.value || "").replace(/\D/g, "").slice(0, 6);
            if (!email || code.length !== 6) {
                showError("Проверь email и код");
                return;
            }

            const response = await fetch("/api/auth/reactivate/confirm", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "x-csrf-token": csrf,
                },
                body: JSON.stringify({ email, code }),
            });
            const payload = await response.json().catch(() => ({}));
            if (!response.ok) {
                showError(payload?.error || "Не удалось восстановить аккаунт");
                return;
            }

            window.location.href = "/profile";
        });
    </script>
</body>

</html>