<%
  const list = Array.isArray(items) ? items : [];
  const p = pagination || { page: 1, totalPages: 1, total: 0 };
  const f = filters || { q: "", sector: "all", sort: "score" };
  const pageBaseUrl = typeof baseUrl === "string" ? baseUrl : "";
  const jsonLd = {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "UNQ Directory",
    itemListElement: list.slice(0, 10).map((item, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: `${pageBaseUrl}/${item.slug}`,
      name: item.name,
    })),
  };
%>
<!doctype html>
<html lang="ru">
<head>
  <%- include('../partials/head', { title: title || "UNQ Directory", description: description || "Каталог UNQX", image: typeof image === 'string' ? image : undefined, noindex: false, jsonLd }) %>
</head>
<body class="bg-neutral-50 antialiased">
  <main class="mx-auto min-h-screen w-full max-w-6xl px-4 py-6">
    <div class="mb-4 flex items-center justify-between">
      <a href="/" class="inline-flex items-center gap-2 rounded-lg border border-neutral-200 bg-white px-3 py-2 text-sm font-semibold text-neutral-700">
        <svg class="icon-stroke h-4 w-4" viewBox="0 0 24 24" aria-hidden="true"><path d="M15 18 9 12l6-6"></path></svg>
        На главную
      </a>
      <h1 class="inline-flex items-center gap-2 text-xl font-black text-neutral-900">
        <img src="/brand/logo.PNG" alt="UNQX" class="h-7 w-7 rounded-md border border-neutral-200 object-cover" />
        <span>UNQ Directory</span>
      </h1>
    </div>

    <form class="mb-4 grid gap-2 rounded-xl border border-neutral-200 bg-white p-3 md:grid-cols-4" method="get" action="/directory">
      <input name="q" value="<%= f.q %>" placeholder="Поиск по имени, роли, slug" class="rounded-lg border border-neutral-200 px-3 py-2 text-sm" />
      <select name="sector" class="rounded-lg border border-neutral-200 px-3 py-2 text-sm">
        <option value="all" <%= f.sector === 'all' ? 'selected' : '' %>>Все сферы</option>
        <option value="design" <%= f.sector === 'design' ? 'selected' : '' %>>Дизайн</option>
        <option value="sales" <%= f.sector === 'sales' ? 'selected' : '' %>>Продажи</option>
        <option value="marketing" <%= f.sector === 'marketing' ? 'selected' : '' %>>Маркетинг</option>
        <option value="it" <%= f.sector === 'it' ? 'selected' : '' %>>IT</option>
        <option value="other" <%= f.sector === 'other' ? 'selected' : '' %>>Другое</option>
      </select>
      <select name="sort" class="rounded-lg border border-neutral-200 px-3 py-2 text-sm">
        <option value="score" <%= f.sort === 'score' ? 'selected' : '' %>>Сортировка: Score</option>
        <option value="date" <%= f.sort === 'date' ? 'selected' : '' %>>Сортировка: Новые</option>
        <option value="views" <%= f.sort === 'views' ? 'selected' : '' %>>Сортировка: Просмотры</option>
      </select>
      <button type="submit" class="rounded-lg bg-neutral-900 px-3 py-2 text-sm font-semibold text-white">Показать</button>
    </form>

    <% if (!list.length) { %>
      <div class="rounded-xl border border-neutral-200 bg-white px-4 py-10 text-center text-sm text-neutral-500">
        Ничего не найдено по текущим фильтрам.
      </div>
    <% } else { %>
      <div class="grid gap-3 md:grid-cols-2 lg:grid-cols-3">
        <% list.forEach((item) => { %>
          <a href="/<%= encodeURIComponent(item.slug) %>" target="_blank" rel="noopener noreferrer" class="rounded-xl border border-neutral-200 bg-white p-4 transition hover:border-neutral-300">
            <div class="flex items-start justify-between gap-2">
              <div class="flex items-center gap-3">
                <img
                  src="<%= item.avatarUrl || '/brand/logo.PNG' %>"
                  alt="<%= item.name %>"
                  onerror="this.onerror=null;this.src='/brand/logo.PNG';"
                  class="h-12 w-12 shrink-0 rounded-full border border-neutral-200 bg-white p-1 object-contain"
                />
                <div>
                  <p class="font-semibold text-neutral-900"><%= item.name %></p>
                  <% if (item.role) { %>
                    <p class="text-xs text-neutral-500"><%= item.role %></p>
                  <% } %>
                </div>
              </div>
              <% if (item.isVerified) { %>
                <span class="inline-flex items-center gap-1 rounded-full border border-[#0a0a0a] bg-transparent px-2 py-1 text-[11px] font-semibold text-[#0a0a0a]" title="Верифицирован на UNQX · Место работы подтверждено">
                  <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d="M12 2.5 14.2 4.3l2.8-.3 1.2 2.5 2.5 1.2-.3 2.8L21.5 12l-1.8 2.2.3 2.8-2.5 1.2-1.2 2.5-2.8-.3L12 21.5l-2.2-1.8-2.8.3-1.2-2.5-2.5-1.2.3-2.8L2.5 12l1.8-2.2-.3-2.8 2.5-1.2 1.2-2.5 2.8.3L12 2.5Zm-1.1 13.1 5-5-1.1-1.1-3.9 3.9-1.8-1.8-1.1 1.1 2.9 2.9Z"></path></svg>
                  Verified
                </span>
              <% } %>
            </div>
            <p class="mt-3 text-xs text-neutral-500">unqx.uz/<span class="font-mono"><%= item.slug %></span></p>
            <div class="mt-3 flex items-center gap-2 text-xs text-neutral-600">
              <span>Score: <strong><%= item.score %></strong></span>
              <span>Топ <strong><%= item.topPercent %>%</strong></span>
              <span>Views: <strong><%= item.views %></strong></span>
            </div>
          </a>
        <% }) %>
      </div>
    <% } %>

    <div class="mt-4 flex items-center justify-between text-sm">
      <span class="text-neutral-500">Найдено: <%= Number(p.total || 0).toLocaleString('ru-RU') %></span>
      <div class="flex items-center gap-2">
        <% if (p.page > 1) { %>
          <a class="rounded-lg border border-neutral-300 bg-white px-3 py-1.5" href="/directory?<%= new URLSearchParams({ q: f.q || '', sector: f.sector || 'all', sort: f.sort || 'score', page: String(p.page - 1) }).toString() %>">Назад</a>
        <% } %>
        <span class="text-neutral-500"><%= p.page %>/<%= p.totalPages %></span>
        <% if (p.page < p.totalPages) { %>
          <a class="rounded-lg border border-neutral-300 bg-white px-3 py-1.5" href="/directory?<%= new URLSearchParams({ q: f.q || '', sector: f.sector || 'all', sort: f.sort || 'score', page: String(p.page + 1) }).toString() %>">Вперёд</a>
        <% } %>
      </div>
    </div>
  </main>
</body>
</html>
