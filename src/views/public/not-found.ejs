<%
  const pageTitle = typeof title === "string" && title ? title : "Страница не найдена";
%>
<!doctype html>
<html lang="ru">
<head>
  <%- include('../partials/head', { title: pageTitle, styles: ['/css/public-card.css'], noindex: true }) %>
</head>
<body class="antialiased">
  <main class="relative flex min-h-screen items-center justify-center overflow-hidden bg-neutral-50 px-6 py-20">
    <div
      class="pointer-events-none absolute inset-0 opacity-[0.45]"
      style="
        background-image:
          radial-gradient(circle at 18% 26%, rgba(0, 0, 0, 0.06) 0, rgba(0, 0, 0, 0) 30%),
          radial-gradient(circle at 82% 70%, rgba(0, 0, 0, 0.08) 0, rgba(0, 0, 0, 0) 34%),
          linear-gradient(rgba(0,0,0,0.03) 1px, transparent 1px),
          linear-gradient(90deg, rgba(0,0,0,0.03) 1px, transparent 1px);
        background-size: auto, auto, 36px 36px, 36px 36px;
      "
    ></div>

    <section class="relative z-10 mx-auto w-full max-w-4xl text-center">
      <p class="text-xs font-mono uppercase tracking-[0.32em] text-neutral-500">UNQ+ ERROR</p>
      <h1 class="mt-3 text-[clamp(6rem,22vw,16rem)] font-black leading-[0.86] tracking-[-0.06em] text-neutral-900">
        404
      </h1>
      <p class="mx-auto mt-4 max-w-xl text-2xl font-semibold tracking-tight text-neutral-900 md:text-3xl">Страница не найдена</p>
      <p class="mx-auto mt-3 max-w-xl text-base text-neutral-600 md:text-lg">Проверь ссылку или вернись на главную страницу.</p>

      <div class="mt-8 flex items-center justify-center">
        <a href="/" class="interactive-btn btn-shimmer inline-flex min-h-11 items-center gap-2 rounded-xl bg-neutral-900 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-neutral-800">
          На главную
          <svg class="icon-stroke h-4 w-4" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M5 12h14M13 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>

      <p class="mt-8 text-xs uppercase tracking-[0.2em] text-neutral-500">Такой страницы больше нет или она переехала</p>
    </section>

    <div class="pointer-events-none absolute left-0 top-0 h-40 w-40 bg-[radial-gradient(circle,_rgba(0,0,0,0.14)_0%,_rgba(0,0,0,0)_68%)] blur-2xl"></div>
    <div class="pointer-events-none absolute bottom-0 right-0 h-52 w-52 bg-[radial-gradient(circle,_rgba(0,0,0,0.16)_0%,_rgba(0,0,0,0)_70%)] blur-2xl"></div>
  </main>
</body>
</html>
