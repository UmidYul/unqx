<header class="border-b border-neutral-200 bg-white">
  <div class="mx-auto w-full max-w-6xl px-4 py-3 md:py-4">
    <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
      <div class="flex flex-col gap-3 md:flex-row md:items-center md:gap-6">
      <a href="/admin/dashboard" class="text-lg font-black tracking-tight">UNQ+ Admin</a>
      <nav class="flex flex-wrap items-center gap-2 text-sm font-medium text-neutral-700 md:gap-3">
        <a href="/admin/dashboard?tab=analytics" class="rounded-full px-3 py-1.5 transition hover:bg-neutral-100">Аналитика</a>
        <a href="/admin/dashboard?tab=orders" class="rounded-full px-3 py-1.5 transition hover:bg-neutral-100">Заявки</a>
        <a href="/admin/dashboard?tab=users" class="rounded-full px-3 py-1.5 transition hover:bg-neutral-100">Пользователи</a>
        <a href="/admin/dashboard?tab=slugs" class="rounded-full px-3 py-1.5 transition hover:bg-neutral-100">Slug</a>
        <a href="/admin/dashboard?tab=cards" class="rounded-full px-3 py-1.5 transition hover:bg-neutral-100">Визитки</a>
        <a href="/admin/dashboard?tab=bracelets" class="rounded-full px-3 py-1.5 transition hover:bg-neutral-100">Браслеты</a>
        <a href="/admin/dashboard?tab=testimonials" class="rounded-full px-3 py-1.5 transition hover:bg-neutral-100">Отзывы</a>
        <a href="/admin/dashboard?tab=logs" class="rounded-full px-3 py-1.5 transition hover:bg-neutral-100">Логи</a>
        <a href="/admin/cards/new" class="rounded-full px-3 py-1.5 transition hover:bg-neutral-100">Создать</a>
      </nav>
    </div>

    <form method="post" action="/admin/logout" class="md:self-auto">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <button
        type="submit"
        class="w-full rounded-full border border-neutral-400 px-4 py-1.5 text-sm font-medium text-neutral-700 transition hover:bg-neutral-100 md:w-auto"
      >
        Выйти
      </button>
    </form>
    </div>
  </div>
</header>
